---
import type { ServiceDuration } from "../data/services";

export interface Props {
  durations: ServiceDuration[];
  initialMode?: "studio" | "mobile";
  initialTravelFeeChf?: number;
  initialDistanceKm?: number;
}

const {
  durations,
  initialMode = "studio",
  initialTravelFeeChf = 0,
  initialDistanceKm = 15,
} = Astro.props;
---

<ul
  class="kwiin-price-list"
  aria-label="Preise"
  data-i18n-aria-label="pricing.listAria"
  data-price-list
  data-mode={initialMode}
>
  {
    durations.map((duration) => {
      const mobilePrice = duration.priceChf + initialTravelFeeChf;
      const initialPrice = initialMode === "mobile" ? mobilePrice : duration.priceChf;

      return (
        <li
          class="kwiin-price-row"
          data-price-row
          data-minutes={duration.minutes}
          data-studio-price={duration.priceChf}
          aria-label={`${duration.minutes} Minuten, ${initialPrice} Schweizer Franken`}
        >
          <span class="kwiin-price-row__duration" data-price-duration>{duration.minutes} Min.</span>
          <span class="kwiin-price-row__leader" aria-hidden="true"></span>
          <span class="kwiin-price-row__cluster">
            <span class="kwiin-price-row__total" data-price-total>
              <span class="kwiin-price-row__currency">CHF</span>
              <span data-price-value>{initialPrice}</span>
            </span>
            <span
              class="kwiin-price-row__breakdown"
              data-travel-breakdown
              data-visible={initialMode === "mobile" ? "true" : "false"}
              aria-hidden={initialMode === "mobile" ? "false" : "true"}
            >
              (plus CHF {initialTravelFeeChf} Anfahrt · bis {initialDistanceKm} km)
            </span>
          </span>
        </li>
      );
    })
  }
</ul>

<style>
  .kwiin-price-list {
    display: flex;
    flex-direction: column;
    gap: 0.72rem;
  }

  .kwiin-price-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 2.7rem;
  }

  .kwiin-price-row__duration {
    flex: none;
    color: var(--color-kwiin-soft-grey);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .kwiin-price-row__leader {
    min-width: 0.5rem;
    flex: 1;
    border-bottom: 1px dotted rgba(116, 82, 29, 0.4);
    transform: translateY(-0.15rem);
  }

  .kwiin-price-row__cluster {
    display: flex;
    width: min(9.75rem, 52vw);
    min-width: 8.75rem;
    flex: none;
    flex-direction: column;
    align-items: flex-end;
  }

  .kwiin-price-row__total {
    display: inline-flex;
    align-items: baseline;
    gap: 0.26rem;
    font-family: var(--font-display);
    font-size: 1.2rem;
    line-height: 1;
    color: var(--color-kwiin-ivory);
    transform-origin: 100% 50%;
    transition:
      color 0.45s var(--ease-silk),
      text-shadow 0.45s var(--ease-silk);
  }

  .kwiin-price-list[data-mode="mobile"] .kwiin-price-row__total {
    color: #624660;
    text-shadow: 0 0 16px rgba(183, 180, 208, 0.34);
  }

  .kwiin-price-row__total.is-updating {
    animation: kwiin-price-pulse 0.48s var(--ease-silk);
  }

  .kwiin-price-row__currency {
    color: rgba(116, 82, 29, 0.82);
    font-family: var(--font-body);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .kwiin-price-row__breakdown {
    display: block;
    max-height: 0;
    margin-top: 0;
    overflow: hidden;
    color: rgba(78, 53, 77, 0.9);
    max-width: 10rem;
    font-size: 0.52rem;
    letter-spacing: 0.025em;
    line-height: 1.35;
    opacity: 0;
    transform: translateY(-0.2rem);
    text-align: right;
    white-space: normal;
    transition:
      max-height 0.5s var(--ease-silk),
      margin-top 0.5s var(--ease-silk),
      opacity 0.45s var(--ease-silk),
      transform 0.5s var(--ease-silk);
  }

  .kwiin-price-row__breakdown[data-visible="true"] {
    max-height: 2.8rem;
    margin-top: 0.3rem;
    opacity: 1;
    transform: translateY(0);
  }

  @keyframes kwiin-price-pulse {
    0% { opacity: 0.45; filter: blur(2px); transform: translateY(0.2rem) scale(0.96); }
    55% { opacity: 1; filter: blur(0); transform: translateY(-0.04rem) scale(1.035); }
    100% { opacity: 1; filter: blur(0); transform: translateY(0) scale(1); }
  }

  @media (max-width: 23rem) {
    .kwiin-price-row {
      gap: 0.5rem;
    }

    .kwiin-price-row__duration {
      font-size: 0.64rem;
    }

    .kwiin-price-row__cluster {
      min-width: 7.8rem;
    }

    .kwiin-price-row__breakdown {
      font-size: 0.45rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .kwiin-price-row__total,
    .kwiin-price-row__breakdown {
      animation: none !important;
      transition: none;
    }
  }
</style>
