  @keyframes kwiin-bloom-breathe {
    0%, 100% { transform: translate3d(-3%, 1%, 0) scale(0.88); opacity: 0.42; }
    50% { transform: translate3d(4%, -3%, 0) scale(1.13); opacity: 0.76; }
  }

  @keyframes kwiin-content-float {
    0%, 100% { transform: translate3d(0, 3px, 52px) rotateZ(-0.08deg); }
    50% { transform: translate3d(0, -6px, 58px) rotateZ(0.12deg); }
  }

  @keyframes kwiin-emblem-breathe {
