    .kwiin-world,
    .kwiin-world-float,
    .kwiin-world-surface {
      transform: none !important;
      filter: none !important;
    }
  }
</style>

<script>
  import { gsap } from "gsap";

  type PortalElement = HTMLElement & {
    __kwiinPortalCleanup?: () => void;
  };

  function initKwiinPortal() {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const finePointer = window.matchMedia("(hover: hover) and (pointer: fine)").matches;
    const coarsePointer = window.matchMedia("(pointer: coarse)").matches;

    document.querySelectorAll<PortalElement>("[data-portal]").forEach((portal) => {
      portal.__kwiinPortalCleanup?.();

      const controller = new AbortController();
      const signal = controller.signal;
      const worlds = Array.from(
        portal.querySelectorAll<HTMLAnchorElement>("[data-world]")
      );
      const thresholdSeal = portal.querySelector<HTMLElement>(".kwiin-threshold-seal");
      let launching = false;

      gsap.set(worlds, {
        transformPerspective: 1300,
        transformStyle: "preserve-3d",
        force3D: true,
      });

      function activate(active: HTMLAnchorElement) {
        if (launching) return;

        const side = active.dataset.world || "";
        portal.dataset.active = side;

        worlds.forEach((world) => {
          const selected = world === active;
          gsap.to(world, {
            z: selected ? 82 : -34,
            scale: selected ? 1.035 : 0.982,
            duration: selected ? 0.8 : 0.95,
            ease: "power3.out",
            overwrite: "auto",
          });
        });
      }

      function reset() {
        if (launching) return;
        delete portal.dataset.active;

        gsap.to(worlds, {
          rotateX: 0,
          rotateY: 0,
          z: 0,
          scale: 1,
          opacity: 1,
          duration: 1.05,
          ease: "expo.out",
          overwrite: "auto",
        });
      }

      function launch(active: HTMLAnchorElement) {
        if (launching) return;
        launching = true;

        const href = active.href;
        const other = worlds.find((world) => world !== active);
        const gleam = active.querySelector<HTMLElement>("[data-gleam]");

        portal.classList.add("is-launching");
        portal.dataset.active = active.dataset.world || "";

        const timeline = gsap.timeline({
          defaults: { ease: "power3.inOut" },
          onComplete: () => window.location.assign(href),
        });

        timeline
          .to(active, {
            rotateX: 0,
            rotateY: 0,
            z: 170,
            scale: 1.105,
            duration: 0.72,
          }, 0)
          .to(other || [], {
            z: -170,
            scale: 0.88,
            opacity: 0.16,
            duration: 0.68,
          }, 0)
          .to(gleam || [], {
            opacity: 1,
            scale: 1.9,
            duration: 0.72,
          }, 0)
          .to(thresholdSeal || [], {
            scale: 0.36,
            opacity: 0,
            duration: 0.46,
          }, 0.06);
      }

      if (finePointer && !reduce) {
        worlds.forEach((world) => {
          const rotateXTo = gsap.quickTo(world, "rotateX", {
            duration: 0.65,
            ease: "power3.out",
          });
          const rotateYTo = gsap.quickTo(world, "rotateY", {
            duration: 0.65,
            ease: "power3.out",
          });

          world.addEventListener("pointerenter", () => activate(world), { signal });
          world.addEventListener("focus", () => activate(world), { signal });

          world.addEventListener("pointermove", (event) => {
            const rect = world.getBoundingClientRect();
            const x = (event.clientX - rect.left) / rect.width;
            const y = (event.clientY - rect.top) / rect.height;

            rotateXTo((0.5 - y) * 8);
            rotateYTo((x - 0.5) * 10);
            world.style.setProperty("--mx", `${(x * 100).toFixed(1)}%`);
            world.style.setProperty("--my", `${(y * 100).toFixed(1)}%`);
          }, { signal });
        });

        portal.addEventListener("pointerleave", reset, { signal });
        portal.addEventListener("focusout", (event) => {
          if (!portal.contains(event.relatedTarget as Node | null)) reset();
        }, { signal });
      }

      if (coarsePointer && !reduce) {
        worlds.forEach((world) => {
          world.addEventListener("pointerdown", () => {
            activate(world);
            gsap.to(world, {
              z: 105,
              scale: 1.055,
              duration: 0.24,
              ease: "power2.out",
              overwrite: "auto",
            });
          }, { signal });

          world.addEventListener("click", (event) => {
            if (
              event.metaKey ||
              event.ctrlKey ||
              event.shiftKey ||
              event.altKey ||
              event.button !== 0
            ) {
              return;
            }

            event.preventDefault();
            launch(world);
          }, { signal });
        });
      }

      portal.__kwiinPortalCleanup = () => {
        controller.abort();
        gsap.killTweensOf(worlds);
        if (thresholdSeal) gsap.killTweensOf(thresholdSeal);
      };
    });
  }

  initKwiinPortal();
  document.addEventListener("astro:after-swap", initKwiinPortal);
</script>
