---
/**
 * The KWIIN threshold is one continuous, living object with two worlds.
 *
 * Astro remains the page shell; GSAP supplies pointer-driven depth and the
 * touch launch sequence. The portal is deliberately progressive: without
 * JavaScript both halves remain ordinary links, and reduced-motion visitors
 * get the same composition without perpetual or transitional movement.
 */
import { withBase } from "../utils/base";
---

<div class="kwiin-portal" data-portal>
  <div class="kwiin-portal-shell">
    <span class="kwiin-portal-ambient kwiin-portal-ambient--gold" aria-hidden="true"></span>
    <span class="kwiin-portal-ambient kwiin-portal-ambient--violet" aria-hidden="true"></span>

    <a
      href={withBase("/studio")}
      class="kwiin-world kwiin-world--studio"
      data-world="studio"
      aria-label="KWIIN Signature Experience. Preisgekrönte Thai-Massage im Studio in Dübendorf."
    >
      <span class="kwiin-world-surface" aria-hidden="true"></span>
      <span class="kwiin-world-bloom" aria-hidden="true"></span>
      <span class="kwiin-world-gleam" data-gleam aria-hidden="true"></span>
      <span class="kwiin-world-grain" aria-hidden="true"></span>

      <span class="kwiin-particle kwiin-particle--1" aria-hidden="true"></span>
      <span class="kwiin-particle kwiin-particle--2" aria-hidden="true"></span>
      <span class="kwiin-particle kwiin-particle--3" aria-hidden="true"></span>
      <span class="kwiin-particle kwiin-particle--4" aria-hidden="true"></span>

      <span class="kwiin-world-index" aria-hidden="true">
        <span>01</span>
        <i></i>
        <span>Im Studio</span>
      </span>

      <div class="kwiin-world-float">
        <span class="kwiin-world-emblem kwiin-world-emblem--studio" aria-hidden="true">
          <span class="kwiin-emblem-aura"></span>
          <svg viewBox="0 0 160 160" fill="none" class="kwiin-lotus-orbit">
            <defs>
              <radialGradient id="studio-orbit-glow">
                <stop offset="0" stop-color="#fff6dc" stop-opacity=".95"></stop>
                <stop offset="1" stop-color="#c9a35c" stop-opacity=".18"></stop>
              </radialGradient>
            </defs>
            <circle class="kwiin-orbit kwiin-orbit--outer" cx="80" cy="80" r="68" stroke="rgba(236,210,155,.46)" stroke-width=".8" stroke-dasharray="1 8" stroke-linecap="round"></circle>
            <circle class="kwiin-orbit kwiin-orbit--inner" cx="80" cy="80" r="54" stroke="rgba(236,210,155,.22)" stroke-width=".8" stroke-dasharray="2 11" stroke-linecap="round"></circle>
            <circle class="kwiin-orbit-light" cx="80" cy="12" r="3.2" fill="url(#studio-orbit-glow)"></circle>
            <g class="kwiin-lotus" transform="translate(44 56)" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
              <path d="M36 2C29 14 29 28 36 40C43 28 43 14 36 2Z"></path>
              <path d="M36 40C28 35 22 25 21 12C31 18 35 29 36 40Z"></path>
              <path d="M36 40C44 35 50 25 51 12C41 18 37 29 36 40Z"></path>
              <path d="M36 40C25 40 13 34 7 24C20 25 31 32 36 40Z"></path>
              <path d="M36 40C47 40 59 34 65 24C52 25 41 32 36 40Z"></path>
              <path d="M21 47C28 52 44 52 51 47"></path>
            </g>
          </svg>
        </span>

        <span class="kwiin-world-kicker">Studio · Dübendorf</span>
        <h2 class="kwiin-world-title">
          <span>KWIIN</span>
          Signature
          <em>Experience</em>
        </h2>
        <p class="kwiin-world-description">
          <span class="kwiin-copy-compact">Preisgekrönte Thai-Massage im privaten Studio.</span>
          <span class="kwiin-copy-full">Preisgekrönte Thai-Massage in einem ruhigen, privaten Studio. Ankommen, loslassen, neue Kraft schöpfen.</span>
        </p>
        <span class="kwiin-world-enter">
          <span>Eintreten</span>
          <svg viewBox="0 0 28 12" fill="none" aria-hidden="true">
            <path d="M1 6h24M20 1l5 5-5 5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </span>
        <span class="kwiin-world-detail">Dübendorf · ab 85 CHF</span>
      </div>
    </a>

    <a
      href={withBase("/mobile-spa")}
      class="kwiin-world kwiin-world--mobile"
      data-world="mobile"
      aria-label="KWIIN Mobile Spa. Luxus Thai-Massage bei Ihnen zuhause, im Büro oder im Hotel."
    >
      <span class="kwiin-world-surface" aria-hidden="true"></span>
      <span class="kwiin-world-bloom" aria-hidden="true"></span>
      <span class="kwiin-world-gleam" data-gleam aria-hidden="true"></span>
      <span class="kwiin-world-grain" aria-hidden="true"></span>

      <span class="kwiin-particle kwiin-particle--1" aria-hidden="true"></span>
      <span class="kwiin-particle kwiin-particle--2" aria-hidden="true"></span>
      <span class="kwiin-particle kwiin-particle--3" aria-hidden="true"></span>
      <span class="kwiin-particle kwiin-particle--4" aria-hidden="true"></span>

      <span class="kwiin-world-index" aria-hidden="true">
        <span>02</span>
        <i></i>
        <span>Bei Ihnen</span>
      </span>

      <div class="kwiin-world-float">
        <span class="kwiin-world-emblem kwiin-world-emblem--mobile" aria-hidden="true">
          <span class="kwiin-emblem-aura"></span>
          <svg viewBox="0 0 180 150" fill="none" class="kwiin-journey">
            <defs>
              <linearGradient id="journey-line" x1="16" y1="116" x2="158" y2="54" gradientUnits="userSpaceOnUse">
                <stop stop-color="#9474bd" stop-opacity=".18"></stop>
                <stop offset=".5" stop-color="#ecd29b" stop-opacity=".8"></stop>
                <stop offset="1" stop-color="#fff3cf"></stop>
              </linearGradient>
              <radialGradient id="journey-orb">
                <stop stop-color="#fff8e5"></stop>
                <stop offset=".35" stop-color="#ecd29b"></stop>
                <stop offset="1" stop-color="#7c5ea3" stop-opacity="0"></stop>
              </radialGradient>
            </defs>
            <circle class="kwiin-journey-ring kwiin-journey-ring--one" cx="92" cy="77" r="63" stroke="rgba(159,126,201,.25)" stroke-width=".8" stroke-dasharray="1 9" stroke-linecap="round"></circle>
            <circle class="kwiin-journey-ring kwiin-journey-ring--two" cx="92" cy="77" r="49" stroke="rgba(236,210,155,.14)" stroke-width=".8" stroke-dasharray="2 12" stroke-linecap="round"></circle>
            <path class="kwiin-journey-path" d="M15 116C48 92 76 124 109 92C123 79 133 72 146 70" stroke="url(#journey-line)" stroke-width="1.5" stroke-linecap="round"></path>
            <circle class="kwiin-journey-light kwiin-journey-light--halo" cx="15" cy="116" r="10" fill="url(#journey-orb)"></circle>
            <circle class="kwiin-journey-light" cx="15" cy="116" r="2.6" fill="#fff3cf"></circle>
            <g class="kwiin-pavilion" stroke="rgba(255,239,198,.92)" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
              <path d="M128 67l18-16 18 16"></path>
              <path d="M133 66v27h26V66"></path>
              <path d="M143 93V81h7v12"></path>
              <path d="M146 51v-7m-3.5 3.5h7"></path>
            </g>
          </svg>
        </span>

        <span class="kwiin-world-kicker">Bei Ihnen · Region Zürich</span>
        <h2 class="kwiin-world-title">
          <span>KWIIN</span>
          Mobile
          <em>Spa</em>
        </h2>
        <p class="kwiin-world-description">
          <span class="kwiin-copy-compact">Luxusmassage bei Ihnen – zuhause, im Büro oder Hotel.</span>
          <span class="kwiin-copy-full">Dieselbe Qualität, dieselbe Ruhe, direkt bei Ihnen. Zuhause, im Büro oder im Hotel.</span>
        </p>
        <span class="kwiin-world-enter">
          <span>Eintreten</span>
          <svg viewBox="0 0 28 12" fill="none" aria-hidden="true">
            <path d="M1 6h24M20 1l5 5-5 5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </span>
        <span class="kwiin-world-detail">Region Zürich · alles inklusive</span>
      </div>
    </a>

    <div class="kwiin-threshold" aria-hidden="true">
      <span class="kwiin-threshold-veil"></span>
      <svg viewBox="0 0 120 800" preserveAspectRatio="none" class="kwiin-threshold-line">
        <defs>
          <linearGradient id="threshold-gold" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#c9a35c" stop-opacity="0"></stop>
            <stop offset=".18" stop-color="#ecd29b" stop-opacity=".42"></stop>
            <stop offset=".5" stop-color="#fff4d4" stop-opacity=".85"></stop>
            <stop offset=".82" stop-color="#9b78c7" stop-opacity=".38"></stop>
            <stop offset="1" stop-color="#7c5ea3" stop-opacity="0"></stop>
          </linearGradient>
        </defs>
        <path d="M60 0C29 96 91 180 58 278C30 365 91 447 60 538C32 620 87 711 60 800" stroke="url(#threshold-gold)" stroke-width="1.15"></path>
        <path class="kwiin-threshold-pulse" d="M60 0C29 96 91 180 58 278C30 365 91 447 60 538C32 620 87 711 60 800" stroke="rgba(255,244,212,.9)" stroke-width="2"></path>
      </svg>
      <span class="kwiin-threshold-seal">
        <span class="kwiin-seal-halo"></span>
        <svg viewBox="0 0 100 100" class="kwiin-seal-orbit">
          <circle cx="50" cy="50" r="45" fill="none" stroke="rgba(236,210,155,.42)" stroke-width=".8" stroke-dasharray="1 5"></circle>
          <circle cx="50" cy="50" r="36" fill="rgba(11,9,8,.78)" stroke="rgba(236,210,155,.26)" stroke-width=".8"></circle>
        </svg>
        <svg viewBox="0 0 64 44" fill="none" class="kwiin-seal-lotus">
          <g stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
            <path d="M32 3C26.5 12 26.5 24 32 34C37.5 24 37.5 12 32 3Z"></path>
            <path d="M32 34C25 31 20 23 19 13C27 17 31 26 32 34Z"></path>
            <path d="M32 34C39 31 44 23 45 13C37 17 33 26 32 34Z"></path>
            <path d="M32 34C22 34 13 29 8 21C19 22 28 28 32 34Z"></path>
            <path d="M32 34C42 34 51 29 56 21C45 22 36 28 32 34Z"></path>
          </g>
        </svg>
      </span>
    </div>

    <span class="kwiin-portal-frame" aria-hidden="true"></span>
  </div>
</div>

<style>
  .kwiin-portal {
    --portal-radius: 1.8rem;
    position: relative;
    perspective: 1500px;
    perspective-origin: 50% 42%;
    padding-block: 0.35rem 0.85rem;
  }

  .kwiin-portal-shell {
    position: relative;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    min-height: clamp(34rem, 74svh, 40rem);
    border-radius: var(--portal-radius);
    background:
      radial-gradient(70% 54% at 50% 45%, rgba(226, 195, 137, 0.075), transparent 65%),
      #0c0909;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.06) inset,
      0 45px 100px -42px rgba(0, 0, 0, 0.92),
      0 0 90px -64px rgba(201, 163, 92, 0.62);
    isolation: isolate;
    transform-style: preserve-3d;
    transition:
      grid-template-columns 0.9s var(--ease-silk),
      box-shadow 0.9s var(--ease-silk);
    animation: kwiin-shell-levitate 9s ease-in-out infinite;
  }

  .kwiin-portal-frame {
    position: absolute;
    inset: 0;
    z-index: 40;
    border: 1px solid rgba(236, 210, 155, 0.18);
    border-radius: inherit;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.018) inset,
      0 0 0 9px rgba(201, 163, 92, 0.018) inset;
    pointer-events: none;
  }

  .kwiin-portal-frame::before,
  .kwiin-portal-frame::after {
    content: "";
    position: absolute;
    top: 1.1rem;
    bottom: 1.1rem;
    width: 1px;
    opacity: 0.42;
  }

  .kwiin-portal-frame::before {
    left: 1.05rem;
    background: linear-gradient(180deg, transparent, rgba(236, 210, 155, 0.5) 12%, transparent 42%);
  }

  .kwiin-portal-frame::after {
    right: 1.05rem;
    background: linear-gradient(0deg, transparent, rgba(155, 120, 199, 0.5) 12%, transparent 42%);
  }

  .kwiin-portal-ambient {
    position: absolute;
    z-index: -1;
    width: 44%;
    aspect-ratio: 1;
    border-radius: 50%;
    filter: blur(70px);
    opacity: 0.2;
    pointer-events: none;
    animation: kwiin-ambient-drift 13s ease-in-out infinite alternate;
  }

  .kwiin-portal-ambient--gold {
    left: -12%;
    top: 3%;
    background: rgba(201, 163, 92, 0.42);
  }

  .kwiin-portal-ambient--violet {
    right: -12%;
    bottom: 0;
    background: rgba(124, 94, 163, 0.42);
    animation-delay: -6s;
    animation-direction: alternate-reverse;
  }

  .kwiin-world {
    --mx: 50%;
    --my: 38%;
    position: relative;
    z-index: 2;
    display: flex;
    min-width: 0;
    align-items: stretch;
    justify-content: center;
    overflow: hidden;
    padding: 3.8rem 0.65rem 1.45rem;
    color: var(--color-kwiin-ivory);
    text-align: center;
    text-decoration: none;
    transform-style: preserve-3d;
    will-change: transform;
    transition:
      filter 0.8s var(--ease-silk),
      opacity 0.8s var(--ease-silk),
      border-radius 0.8s var(--ease-silk);
  }

  .kwiin-world--studio {
    border-radius: var(--portal-radius) 0 0 var(--portal-radius);
    transform-origin: 100% 50%;
  }

  .kwiin-world--mobile {
    border-radius: 0 var(--portal-radius) var(--portal-radius) 0;
    transform-origin: 0 50%;
  }

  .kwiin-world:focus-visible {
    z-index: 30;
    outline: 1px solid rgba(255, 242, 208, 0.92);
    outline-offset: -0.55rem;
    border-radius: var(--portal-radius);
  }

  .kwiin-world-surface,
  .kwiin-world-bloom,
  .kwiin-world-gleam,
  .kwiin-world-grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .kwiin-world-surface {
    z-index: -4;
    transform: scale(1.035);
    transition: transform 1.2s var(--ease-silk), filter 0.9s var(--ease-silk);
  }

  .kwiin-world--studio .kwiin-world-surface {
    background:
      radial-gradient(90% 55% at 38% 27%, rgba(233, 200, 133, 0.2), transparent 56%),
      radial-gradient(90% 80% at 90% 65%, rgba(138, 90, 38, 0.1), transparent 68%),
      linear-gradient(155deg, #24190f 0%, #120d09 52%, #090708 100%);
  }

  .kwiin-world--mobile .kwiin-world-surface {
    background:
      radial-gradient(86% 60% at 62% 27%, rgba(144, 105, 190, 0.21), transparent 56%),
      radial-gradient(90% 80% at 12% 67%, rgba(91, 56, 130, 0.13), transparent 67%),
      linear-gradient(205deg, #21172d 0%, #120d18 52%, #090708 100%);
  }

  .kwiin-world-bloom {
    z-index: -3;
    inset: 11% 4% 20%;
    border-radius: 50%;
    opacity: 0.58;
    filter: blur(24px);
    transform-origin: 50% 40%;
    animation: kwiin-bloom-breathe 6.8s ease-in-out infinite;
    transition: opacity 0.8s var(--ease-silk);
  }

  .kwiin-world--studio .kwiin-world-bloom {
    background: radial-gradient(circle, rgba(222, 183, 105, 0.3), transparent 68%);
  }

  .kwiin-world--mobile .kwiin-world-bloom {
    background: radial-gradient(circle, rgba(127, 91, 171, 0.33), transparent 68%);
    animation-delay: -3.2s;
    animation-duration: 7.7s;
  }

  .kwiin-world-gleam {
    z-index: 4;
    opacity: 0.14;
    mix-blend-mode: screen;
    background: radial-gradient(
      260px circle at var(--mx) var(--my),
      rgba(255, 247, 226, 0.3),
      rgba(236, 210, 155, 0.05) 30%,
      transparent 68%
    );
    transition: opacity 0.7s var(--ease-silk);
  }

  .kwiin-world-grain {
    z-index: 5;
    opacity: 0.08;
    mix-blend-mode: soft-light;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.62' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.7'/%3E%3C/svg%3E");
  }

  .kwiin-world-index {
    position: absolute;
    top: 1.25rem;
    z-index: 8;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.48rem;
    letter-spacing: 0.17em;
    text-transform: uppercase;
    color: rgba(236, 210, 155, 0.58);
    transform: translateZ(26px);
  }

  .kwiin-world--studio .kwiin-world-index {
    left: 1.25rem;
  }

  .kwiin-world--mobile .kwiin-world-index {
    right: 1.25rem;
    flex-direction: row-reverse;
    color: rgba(202, 175, 232, 0.62);
  }

  .kwiin-world-index i {
    width: 0.9rem;
    height: 1px;
    background: currentColor;
  }

  .kwiin-world-float {
    position: relative;
    z-index: 7;
    display: flex;
    width: 100%;
    min-width: 0;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    transform: translateZ(52px);
    transform-style: preserve-3d;
    animation: kwiin-content-float 7.4s ease-in-out infinite;
    transition: opacity 0.75s var(--ease-silk), filter 0.75s var(--ease-silk);
  }

  .kwiin-world--mobile .kwiin-world-float {
    animation-delay: -3.7s;
    animation-duration: 8.2s;
  }

  .kwiin-world-emblem {
    position: relative;
    display: grid;
    width: clamp(5.6rem, 25vw, 7rem);
    aspect-ratio: 1;
    place-items: center;
    color: var(--color-kwiin-gold-bright);
    transform: translateZ(44px);
    filter: drop-shadow(0 16px 26px rgba(0, 0, 0, 0.42));
  }

  .kwiin-world-emblem--mobile {
    width: clamp(6.3rem, 28vw, 7.6rem);
  }

  .kwiin-world-emblem svg {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .kwiin-emblem-aura {
    position: absolute;
    inset: 18%;
    border-radius: 50%;
    background: rgba(227, 190, 115, 0.3);
    filter: blur(18px);
    animation: kwiin-emblem-breathe 5.2s ease-in-out infinite;
  }

  .kwiin-world-emblem--mobile .kwiin-emblem-aura {
    background: rgba(128, 91, 172, 0.38);
    animation-delay: -2.4s;
  }

  .kwiin-orbit {
    transform-origin: 80px 80px;
    animation: kwiin-orbit 48s linear infinite;
  }

  .kwiin-orbit--inner {
    animation-duration: 67s;
    animation-direction: reverse;
  }

  .kwiin-orbit-light {
    transform-origin: 80px 80px;
    animation: kwiin-orbit 19s linear infinite;
    filter: drop-shadow(0 0 7px rgba(255, 238, 190, 0.9));
  }

  .kwiin-lotus {
    filter: drop-shadow(0 0 10px rgba(236, 210, 155, 0.42));
    animation: kwiin-lotus-breathe 5.4s ease-in-out infinite;
    transform-origin: 36px 31px;
  }

  .kwiin-journey-ring {
    transform-origin: 92px 77px;
    animation: kwiin-orbit 58s linear infinite;
  }

  .kwiin-journey-ring--two {
    animation-duration: 73s;
    animation-direction: reverse;
  }

  .kwiin-journey-path {
    stroke-dasharray: 5 10;
    animation: kwiin-journey-dash 2.8s linear infinite;
  }

  .kwiin-journey-light {
    offset-path: path("M15 116C48 92 76 124 109 92C123 79 133 72 146 70");
    animation: kwiin-travel-home 5.8s var(--ease-silk) infinite;
    filter: drop-shadow(0 0 8px rgba(255, 239, 198, 0.92));
  }

  .kwiin-journey-light--halo {
    opacity: 0.55;
    filter: blur(2px);
  }

  .kwiin-pavilion {
    filter: drop-shadow(0 0 9px rgba(236, 210, 155, 0.34));
    animation: kwiin-pavilion-breathe 5.8s ease-in-out infinite;
    transform-origin: 146px 72px;
  }

  .kwiin-world-kicker {
    margin-top: 0.7rem;
    font-size: clamp(0.46rem, 1.9vw, 0.58rem);
    letter-spacing: clamp(0.15em, 0.85vw, 0.26em);
    line-height: 1.5;
    text-transform: uppercase;
    color: rgba(236, 210, 155, 0.77);
  }

  .kwiin-world--mobile .kwiin-world-kicker {
    color: rgba(221, 196, 241, 0.76);
  }

  .kwiin-world-title {
    margin-top: 0.65rem;
    max-width: 100%;
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 7.1vw, 1.82rem);
    font-weight: 500;
    line-height: 0.92;
    letter-spacing: -0.015em;
    color: var(--color-kwiin-ivory);
    text-wrap: balance;
    transform: translateZ(18px);
  }

  .kwiin-world-title > span {
    display: block;
    margin-bottom: 0.45rem;
    font-family: var(--font-body);
    font-size: 0.28em;
    font-weight: 400;
    letter-spacing: 0.43em;
    line-height: 1;
    text-transform: uppercase;
    color: rgba(236, 210, 155, 0.7);
  }

  .kwiin-world-title em {
    display: block;
    margin-top: 0.12em;
    font-weight: 500;
    color: var(--color-kwiin-gold-bright);
  }

  .kwiin-world--mobile .kwiin-world-title em {
    color: #e0c9f2;
  }

  .kwiin-world-description {
    min-height: 4.65em;
    margin-top: 1rem;
    max-width: 10rem;
    font-size: clamp(0.62rem, 2.65vw, 0.72rem);
    font-weight: 300;
    line-height: 1.55;
    color: rgba(232, 221, 201, 0.72);
    text-wrap: balance;
  }

  .kwiin-copy-full {
    display: none;
  }

  .kwiin-world-enter {
    display: inline-flex;
    min-width: 0;
