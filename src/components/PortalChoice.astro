---
import { withBase } from "../utils/base";
---

<div class="kwiin-portal" data-portal>
  <div class="kwiin-portal-shell">
    <a
      href={withBase("/studio")}
      class="kwiin-world kwiin-world--studio"
      data-world="studio"
      data-i18n-aria-label="portal.studioAria"
      aria-label="KWIIN Signature Experience im Studio in Dübendorf"
    >
      <span class="kwiin-world-surface" aria-hidden="true"></span>
      <span class="kwiin-world-light" aria-hidden="true"></span>
      <span class="kwiin-world-index" aria-hidden="true">
        <span>01</span><i></i><span data-i18n="portal.studioIndex">Im Studio</span>
      </span>

      <span class="kwiin-world-content">
        <span class="kwiin-world-emblem kwiin-world-emblem--studio" aria-hidden="true">
          <svg viewBox="0 0 120 120" fill="none">
            <circle class="kwiin-orbit kwiin-orbit--outer" cx="60" cy="60" r="48"></circle>
            <circle class="kwiin-orbit kwiin-orbit--inner" cx="60" cy="60" r="38"></circle>
            <circle class="kwiin-orbit-star" cx="60" cy="12" r="2.6"></circle>
            <g class="kwiin-emblem-lotus" stroke="currentColor" stroke-width="1.55" stroke-linecap="round" stroke-linejoin="round">
              <path d="M60 38c-6 8-6 18 0 27 6-9 6-19 0-27Z"></path>
              <path d="M60 65c-7-3-12-10-12-19 8 4 11 12 12 19Z"></path>
              <path d="M60 65c7-3 12-10 12-19-8 4-11 12-12 19Z"></path>
              <path d="M60 65c-10 0-18-4-23-12 10 1 19 6 23 12Z"></path>
              <path d="M60 65c10 0 18-4 23-12-10 1-19 6-23 12Z"></path>
              <path d="M45 73c7 5 23 5 30 0"></path>
            </g>
          </svg>
        </span>

        <span class="kwiin-world-kicker" data-i18n="portal.studioKicker">Studio · Dübendorf</span>
        <span class="kwiin-world-title">
          <small>KWIIN</small>
          <span data-i18n="portal.studioTitle">Signature</span>
          <em data-i18n="portal.studioAccent">Experience</em>
        </span>
        <span class="kwiin-world-description" data-i18n="portal.studioCopy">
          Persönliche Thai Massage in einem ruhigen Studio.
        </span>
        <span class="kwiin-world-enter">
          <span data-i18n="portal.enter">Entdecken</span>
          <svg viewBox="0 0 28 12" fill="none" aria-hidden="true">
            <path d="M1 6h24M20 1l5 5-5 5"></path>
          </svg>
        </span>
        <span class="kwiin-world-detail" data-i18n="portal.studioDetail">Dübendorf · ab CHF 85</span>
      </span>
    </a>

    <a
      href={withBase("/mobile-spa")}
      class="kwiin-world kwiin-world--mobile"
      data-world="mobile"
      data-i18n-aria-label="portal.mobileAria"
      aria-label="KWIIN Mobile Spa bei Ihnen in der Region Zürich"
    >
      <span class="kwiin-world-surface" aria-hidden="true"></span>
      <span class="kwiin-world-light" aria-hidden="true"></span>
      <span class="kwiin-world-index" aria-hidden="true">
        <span data-i18n="portal.mobileIndex">Bei Ihnen</span><i></i><span>02</span>
      </span>

      <span class="kwiin-world-content">
        <span class="kwiin-world-emblem kwiin-world-emblem--mobile" aria-hidden="true">
          <svg viewBox="0 0 120 120" fill="none">
            <circle class="kwiin-mobile-ring kwiin-mobile-ring--outer" cx="60" cy="60" r="48"></circle>
            <circle class="kwiin-mobile-ring kwiin-mobile-ring--inner" cx="60" cy="60" r="38"></circle>
            <path class="kwiin-route" d="M24 76c13-16 27 8 41-7 8-9 14-16 24-17"></path>
            <circle class="kwiin-route-signal" cx="24" cy="76" r="3"></circle>
            <g class="kwiin-home" stroke="currentColor" stroke-width="1.55" stroke-linecap="round" stroke-linejoin="round">
              <path d="m77 53 13-11 13 11"></path>
              <path d="M81 52v20h18V52"></path>
              <path d="M88 72v-8h5v8"></path>
            </g>
          </svg>
        </span>

        <span class="kwiin-world-kicker" data-i18n="portal.mobileKicker">Bei Ihnen · Region Zürich</span>
        <span class="kwiin-world-title">
          <small>KWIIN</small>
          <span data-i18n="portal.mobileTitle">Mobile</span>
          <em data-i18n="portal.mobileAccent">Spa</em>
        </span>
        <span class="kwiin-world-description" data-i18n="portal.mobileCopy">
          Ihre Massage zuhause, im Büro oder im Hotel.
        </span>
        <span class="kwiin-world-enter">
          <span data-i18n="portal.enter">Entdecken</span>
          <svg viewBox="0 0 28 12" fill="none" aria-hidden="true">
            <path d="M1 6h24M20 1l5 5-5 5"></path>
          </svg>
        </span>
        <span class="kwiin-world-detail" data-i18n="portal.mobileDetail">Region Zürich · Anfahrt wählbar</span>
      </span>
    </a>

    <span class="kwiin-portal-seam" aria-hidden="true"></span>
    <span class="kwiin-portal-frame" aria-hidden="true"></span>
  </div>
</div>

<style>
  .kwiin-portal {
    --portal-radius: 1.8rem;
    position: relative;
    padding-block: 0.35rem 0.75rem;
  }

  .kwiin-portal-shell {
    position: relative;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    min-height: clamp(32rem, 70svh, 39rem);
    overflow: hidden;
    border-radius: var(--portal-radius);
    background: #eadfe4;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.94) inset,
      0 34px 82px -40px rgba(72, 58, 79, 0.38),
      0 0 58px -46px rgba(185, 133, 47, 0.58);
    isolation: isolate;
    contain: layout paint;
  }

  .kwiin-world {
    position: relative;
    z-index: 2;
    display: flex;
    min-width: 0;
    overflow: hidden;
    align-items: stretch;
    justify-content: center;
    padding: 3rem clamp(0.55rem, 2.4vw, 1.35rem) 1.3rem;
    color: var(--color-kwiin-ivory);
    text-align: center;
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
    contain: layout paint style;
  }

  .kwiin-world:focus-visible {
    z-index: 5;
    outline: 2px solid rgba(116, 82, 29, 0.82);
    outline-offset: -0.5rem;
  }

  .kwiin-world-surface,
  .kwiin-world-light {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .kwiin-world-surface {
    z-index: -2;
    transform: scale(1.02);
    transition: transform 0.8s var(--ease-silk), filter 0.8s var(--ease-silk);
  }

  .kwiin-world--studio .kwiin-world-surface {
    background:
      radial-gradient(110% 58% at 28% 16%, rgba(244, 216, 141, 0.42), transparent 58%),
      radial-gradient(82% 70% at 8% 88%, rgba(198, 139, 131, 0.3), transparent 68%),
      linear-gradient(154deg, #f3e5df 0%, #e8d7d8 52%, #d8ced4 100%);
  }

  .kwiin-world--mobile .kwiin-world-surface {
    background:
      radial-gradient(110% 58% at 72% 16%, rgba(169, 216, 213, 0.54), transparent 58%),
      radial-gradient(82% 72% at 92% 88%, rgba(183, 180, 208, 0.38), transparent 68%),
      linear-gradient(206deg, #d8eeee 0%, #d7dce8 52%, #ddd5e2 100%);
  }

  .kwiin-world-light {
    z-index: -1;
    inset: 14% 6% 26%;
    border-radius: 50%;
    opacity: 0.55;
    transform: scale(0.9);
    animation: kwiin-world-breathe 7.5s ease-in-out infinite;
  }

  .kwiin-world--studio .kwiin-world-light {
    background: radial-gradient(circle, rgba(255, 255, 255, 0.64), rgba(244, 216, 141, 0.12) 42%, transparent 70%);
  }

  .kwiin-world--mobile .kwiin-world-light {
    background: radial-gradient(circle, rgba(255, 255, 255, 0.6), rgba(71, 163, 171, 0.1) 42%, transparent 70%);
    animation-delay: -3.75s;
  }

  .kwiin-world-index {
    position: absolute;
    top: 1.15rem;
    z-index: 3;
    display: flex;
    min-width: 0;
    align-items: center;
    gap: 0.42rem;
    color: rgba(116, 82, 29, 0.72);
    font-size: 0.48rem;
    letter-spacing: 0.15em;
    line-height: 1;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .kwiin-world--studio .kwiin-world-index { left: 1rem; }
  .kwiin-world--mobile .kwiin-world-index {
    right: 1rem;
    color: rgba(76, 91, 119, 0.72);
  }

  .kwiin-world-index i {
    width: clamp(0.65rem, 3vw, 1.35rem);
    height: 1px;
    flex: none;
    background: currentColor;
  }

  .kwiin-world-content {
    position: relative;
    z-index: 2;
    display: flex;
    width: 100%;
    min-width: 0;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    transition: transform 0.65s var(--ease-silk), opacity 0.65s var(--ease-silk);
  }

  .kwiin-world-emblem {
    position: relative;
    display: block;
    width: clamp(5rem, 22vw, 7.5rem);
    max-width: 70%;
    aspect-ratio: 1;
    color: var(--color-kwiin-gold-bright);
  }

  .kwiin-world-emblem--mobile { color: #73516f; }

  .kwiin-world-emblem svg {
    display: block;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .kwiin-orbit,
  .kwiin-mobile-ring {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    transform-origin: 60px 60px;
  }

  .kwiin-orbit--outer,
  .kwiin-mobile-ring--outer {
    opacity: 0.33;
    stroke-width: 0.75;
    stroke-dasharray: 1 7;
    animation: kwiin-orbit 46s linear infinite;
  }

  .kwiin-orbit--inner,
  .kwiin-mobile-ring--inner {
    opacity: 0.16;
    stroke-width: 0.7;
    stroke-dasharray: 2 10;
    animation: kwiin-orbit 64s linear infinite reverse;
  }

  .kwiin-orbit-star {
    fill: #8b641f;
    transform-origin: 60px 60px;
    animation: kwiin-orbit 17s linear infinite;
  }

  .kwiin-emblem-lotus,
  .kwiin-home {
    filter: drop-shadow(0 0 8px rgba(236, 210, 155, 0.32));
  }

  .kwiin-route {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.25;
    stroke-linecap: round;
    stroke-dasharray: 4 7;
    opacity: 0.65;
    animation: kwiin-route-flow 3.6s linear infinite;
  }

  .kwiin-route-signal {
    fill: #8b641f;
    offset-path: path("M24 76c13-16 27 8 41-7 8-9 14-16 24-17");
    animation: kwiin-route-signal 5.8s ease-in-out infinite;
  }

  .kwiin-world-kicker {
    max-width: 100%;
    margin-top: 0.5rem;
    color: rgba(116, 82, 29, 0.78);
    font-size: clamp(0.45rem, 1.8vw, 0.58rem);
    letter-spacing: clamp(0.11em, 0.65vw, 0.22em);
    line-height: 1.45;
    text-transform: uppercase;
  }

  .kwiin-world--mobile .kwiin-world-kicker { color: rgba(98, 70, 96, 0.8); }

  .kwiin-world-title {
    display: flex;
    min-width: 0;
    margin-top: 0.7rem;
    flex-direction: column;
    align-items: center;
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 6vw, 2.35rem);
    font-weight: 400;
    line-height: 0.9;
  }

  .kwiin-world-title small {
    margin-bottom: 0.35rem;
    color: rgba(116, 82, 29, 0.68);
    font-family: var(--font-body);
    font-size: 0.46rem;
    font-style: normal;
    letter-spacing: 0.31em;
    line-height: 1;
  }

  .kwiin-world-title em {
    color: var(--color-kwiin-gold-bright);
    font-style: italic;
  }

  .kwiin-world--mobile .kwiin-world-title em { color: #73516f; }

  .kwiin-world-description {
    display: block;
    width: min(100%, 16rem);
    margin-top: 1.15rem;
    color: rgba(53, 45, 64, 0.72);
    font-size: clamp(0.68rem, 2.4vw, 0.82rem);
    font-weight: 300;
    line-height: 1.55;
  }

  .kwiin-world-enter {
    display: inline-flex;
    min-width: 0;
    margin-top: 1.35rem;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    padding: 0.68rem clamp(0.75rem, 3vw, 1.2rem);
    border: 1px solid rgba(116, 82, 29, 0.54);
    border-radius: 999px;
    color: rgba(70, 49, 22, 0.9);
    font-size: clamp(0.5rem, 1.8vw, 0.62rem);
    letter-spacing: clamp(0.1em, 0.6vw, 0.19em);
    line-height: 1;
    text-transform: uppercase;
    white-space: nowrap;
    transition: background 0.45s var(--ease-silk), border-color 0.45s var(--ease-silk);
  }

  .kwiin-world--mobile .kwiin-world-enter {
    border-color: rgba(98, 70, 96, 0.52);
    color: rgba(73, 50, 72, 0.92);
  }

  .kwiin-world-enter svg {
    width: clamp(1rem, 4vw, 1.45rem);
    flex: none;
  }

  .kwiin-world-enter path {
    stroke: currentColor;
    stroke-width: 1.2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .kwiin-world-detail {
    margin-top: 1.05rem;
    color: rgba(53, 45, 64, 0.72);
    font-size: clamp(0.43rem, 1.55vw, 0.54rem);
    letter-spacing: 0.1em;
    line-height: 1.4;
    text-transform: uppercase;
  }

  .kwiin-portal-seam {
    position: absolute;
    inset-block: 1.15rem;
    left: 50%;
    z-index: 8;
    width: 1px;
    background: linear-gradient(180deg, transparent, rgba(116, 82, 29, 0.34) 18%, rgba(98, 70, 96, 0.34) 82%, transparent);
    pointer-events: none;
  }

  .kwiin-portal-frame {
    position: absolute;
    inset: 0;
    z-index: 9;
    border: 1px solid rgba(116, 82, 29, 0.28);
    border-radius: inherit;
    box-shadow: 0 0 0 8px rgba(201, 163, 92, 0.018) inset;
    pointer-events: none;
  }

  .kwiin-portal.is-dormant * { animation-play-state: paused !important; }

  @media (hover: hover) and (pointer: fine) {
    .kwiin-portal-shell:has(.kwiin-world:hover) .kwiin-world:not(:hover) .kwiin-world-content {
      opacity: 0.66;
      transform: scale(0.985);
    }

    .kwiin-world:hover .kwiin-world-content {
      transform: translateY(-0.45rem) scale(1.018);
    }

    .kwiin-world:hover .kwiin-world-surface { transform: scale(1.055); }
    .kwiin-world:hover .kwiin-world-enter {
      border-color: rgba(116, 82, 29, 0.76);
      background: rgba(255, 255, 255, 0.26);
    }
  }

  .kwiin-world:active .kwiin-world-content {
    transform: scale(0.985);
    transition-duration: 0.1s;
  }

  @media (max-width: 30rem) {
    .kwiin-portal { --portal-radius: 1.45rem; }

    .kwiin-portal-shell {
      min-height: min(35rem, 72svh);
      max-height: 35rem;
    }

    .kwiin-world { padding-inline: 0.58rem; }
    .kwiin-world-index { letter-spacing: 0.1em; }
    .kwiin-world--studio .kwiin-world-index { left: 0.7rem; }
    .kwiin-world--mobile .kwiin-world-index { right: 0.7rem; }
    .kwiin-world-description { min-height: 3.2em; }
  }

  @media (hover: none), (pointer: coarse) {
    .kwiin-world {
      contain: layout paint;
      will-change: auto;
    }

    .kwiin-world-surface { transition: none; }
    .kwiin-world-light { animation-duration: 10s; }
    .kwiin-emblem-lotus,
    .kwiin-home { filter: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .kwiin-portal *,
    .kwiin-portal *::before,
    .kwiin-portal *::after {
      animation: none !important;
      transition-duration: 0.01ms !important;
    }
  }

  @keyframes kwiin-world-breathe {
    0%, 100% { opacity: 0.42; transform: scale(0.88); }
    50% { opacity: 0.68; transform: scale(1.05); }
  }

  @keyframes kwiin-orbit { to { transform: rotate(1turn); } }

  @keyframes kwiin-route-flow { to { stroke-dashoffset: -22; } }

  @keyframes kwiin-route-signal {
    0% { opacity: 0; offset-distance: 0%; }
    15% { opacity: 1; }
    75% { opacity: 1; }
    100% { opacity: 0; offset-distance: 100%; }
  }
</style>

<script>
  type PortalWindow = Window & { __kwiinPortalObserver?: IntersectionObserver };

  function initPortal() {
    const portal = document.querySelector<HTMLElement>("[data-portal]");
    if (!portal || portal.dataset.portalBound === "true") return;
    portal.dataset.portalBound = "true";

    const appWindow = window as PortalWindow;
    appWindow.__kwiinPortalObserver?.disconnect();

    if (!("IntersectionObserver" in window)) return;
    const observer = new IntersectionObserver(
      ([entry]) => portal.classList.toggle("is-dormant", !entry.isIntersecting),
      { rootMargin: "160px 0px" }
    );
    observer.observe(portal);
    appWindow.__kwiinPortalObserver = observer;
  }

  initPortal();
  document.addEventListener("astro:after-swap", initPortal);
</script>
