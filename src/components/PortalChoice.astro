  @media (prefers-reduced-motion: reduce) {
    .kwiin-portal-shell,
    .kwiin-portal-ambient,
    .kwiin-world-float,
    .kwiin-world-bloom,
    .kwiin-emblem-aura,
    .kwiin-orbit,
    .kwiin-orbit-light,
    .kwiin-lotus,
    .kwiin-journey-ring,
    .kwiin-journey-path,
    .kwiin-journey-light,
    .kwiin-pavilion,
    .kwiin-particle,
    .kwiin-threshold-veil,
    .kwiin-threshold-pulse,
    .kwiin-seal-halo,
    .kwiin-seal-orbit {
      animation: none !important;
