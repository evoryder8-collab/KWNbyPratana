        0 1px 0 rgba(255, 255, 255, 0.075) inset,
        0 58px 118px -44px rgba(0, 0, 0, 0.96),
        0 0 105px -58px rgba(201, 163, 92, 0.72);
    }
  }

  @keyframes kwiin-ambient-drift {
    0% { transform: translate3d(-4%, -3%, 0) scale(0.92); opacity: 0.14; }
    100% { transform: translate3d(9%, 7%, 0) scale(1.13); opacity: 0.28; }
