---
/**
 * A whisper of gold dust: tiny luminous particles drifting upward inside
 * whichever section hosts this component (the host must be positioned).
 * Canvas-based but deliberately frugal: ~36 particles, paused while
 * offscreen, skipped entirely under reduced motion or without JS.
 */
export interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<canvas data-gold-dust class={`pointer-events-none absolute inset-0 h-full w-full ${className}`} aria-hidden="true"
></canvas>

<script>
  interface Mote {
    x: number;
    y: number;
    r: number;
    vy: number;
    drift: number;
    phase: number;
    tw: number;
  }

  function setupGoldDust(canvas: HTMLCanvasElement) {
    if (canvas.dataset.dustBound === "true") return;
    canvas.dataset.dustBound = "true";

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce) return;

    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const DPR = Math.min(window.devicePixelRatio || 1, 2);
    let width = 0;
    let height = 0;
    let motes: Mote[] = [];
    let raf = 0;
    let running = false;
    let t = 0;

    function seed() {
      const count = Math.round(Math.min(44, Math.max(22, width / 34)));
      motes = Array.from({ length: count }, () => ({
        x: Math.random() * width,
        y: Math.random() * height,
        r: 0.6 + Math.random() * 1.3,
        vy: 0.08 + Math.random() * 0.18,
        drift: 0.1 + Math.random() * 0.25,
        phase: Math.random() * Math.PI * 2,
        tw: 0.4 + Math.random() * 0.6,
      }));
    }

    function resize() {
      const rect = canvas.getBoundingClientRect();
      width = rect.width;
      height = rect.height;
      canvas.width = Math.round(width * DPR);
      canvas.height = Math.round(height * DPR);
      ctx!.setTransform(DPR, 0, 0, DPR, 0, 0);
      if (!motes.length) seed();
    }

    function frame() {
      if (!running) return;
      t += 0.016;
      ctx!.clearRect(0, 0, width, height);

      for (const m of motes) {
        m.y -= m.vy;
        m.x += Math.sin(t * m.drift + m.phase) * 0.14;
        if (m.y < -4) {
          m.y = height + 4;
          m.x = Math.random() * width;
        }
        const alpha = (0.25 + 0.55 * Math.abs(Math.sin(t * m.tw + m.phase))) * 0.8;
        ctx!.beginPath();
        ctx!.arc(m.x, m.y, m.r, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(236, 210, 155, ${alpha.toFixed(3)})`;
        ctx!.shadowColor = "rgba(236, 210, 155, 0.6)";
        ctx!.shadowBlur = 6;
        ctx!.fill();
        ctx!.shadowBlur = 0;
      }
      raf = requestAnimationFrame(frame);
    }

    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting && !running) {
            running = true;
            raf = requestAnimationFrame(frame);
          } else if (!entry.isIntersecting && running) {
            running = false;
            cancelAnimationFrame(raf);
          }
        }
      },
      { threshold: 0.02 }
    );

    resize();
    io.observe(canvas);
    new ResizeObserver(resize).observe(canvas);
  }

  function initGoldDust() {
    document
      .querySelectorAll<HTMLCanvasElement>("canvas[data-gold-dust]")
      .forEach(setupGoldDust);
  }

  initGoldDust();
  document.addEventListener("astro:after-swap", initGoldDust);
</script>
