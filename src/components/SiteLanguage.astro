<script>
  import {
    LANGUAGE_CODES,
    translations,
    translate,
    type LanguageCode,
    type TranslationKey,
  } from "../i18n/translations";

  type LanguageWindow = Window & {
    __kwiinLanguage?: LanguageCode;
    __kwiinSetLanguage?: (language: LanguageCode, animate?: boolean) => void;
    __kwiinT?: (
      key: TranslationKey,
      params?: Record<string, string | number>
    ) => string;
  };

  const STORAGE_KEY = "kwiin-language";
  const LEGACY_STORAGE_KEY = "kwiin-hero-language";
  const textKeys = new WeakMap<Text, TranslationKey>();
  const sourceToKey = new Map<string, TranslationKey>();

  Object.entries(translations.de).forEach(([key, value]) => {
    const normalized = normalizeText(value);
    if (normalized && !sourceToKey.has(normalized)) {
      sourceToKey.set(normalized, key as TranslationKey);
    }
  });

  function normalizeText(value: string) {
    return value.replace(/\s+/g, " ").trim();
  }

  function isLanguageCode(value: string | null): value is LanguageCode {
    return Boolean(value && LANGUAGE_CODES.includes(value as LanguageCode));
  }

  function storedLanguage(): LanguageCode {
    try {
      const current = localStorage.getItem(STORAGE_KEY);
      if (isLanguageCode(current)) return current;
      const legacy = localStorage.getItem(LEGACY_STORAGE_KEY);
      if (isLanguageCode(legacy)) return legacy;
    } catch {
      return "de";
    }
    return "de";
  }

  function applyExplicitTranslations(language: LanguageCode) {
    document.querySelectorAll<HTMLElement>("[data-i18n]").forEach((element) => {
      const key = element.dataset.i18n as TranslationKey;
      if (translations.de[key] !== undefined) element.textContent = translations[language][key];
      element.lang = language;
    });

    const attributeMap = [
      ["data-i18n-aria-label", "aria-label"],
      ["data-i18n-alt", "alt"],
      ["data-i18n-title", "title"],
      ["data-i18n-placeholder", "placeholder"],
    ] as const;

    attributeMap.forEach(([selector, attribute]) => {
      document.querySelectorAll<HTMLElement>(`[${selector}]`).forEach((element) => {
        const key = element.getAttribute(selector) as TranslationKey;
        if (translations.de[key] !== undefined) {
          element.setAttribute(attribute, translations[language][key]);
        }
      });
    });

    document.querySelectorAll<HTMLAnchorElement>("[data-i18n-whatsapp]").forEach((link) => {
      const key = link.dataset.i18nWhatsapp as TranslationKey;
      if (translations.de[key] === undefined) return;
      try {
        const url = new URL(link.href);
        url.searchParams.set("text", translations[language][key]);
        link.href = url.toString();
      } catch {
        // The visible interface still translates if a malformed URL is supplied.
      }
    });
  }

  function applyAutomaticText(language: LanguageCode) {
    const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, {
      acceptNode(node) {
        const parent = node.parentElement;
        if (!parent || parent.closest("script, style, noscript, svg")) {
          return NodeFilter.FILTER_REJECT;
        }
        return normalizeText(node.nodeValue || "")
          ? NodeFilter.FILTER_ACCEPT
          : NodeFilter.FILTER_REJECT;
      },
    });

    let node = walker.nextNode() as Text | null;
    while (node) {
      let key = textKeys.get(node);
      if (!key) {
        key = sourceToKey.get(normalizeText(node.nodeValue || ""));
        if (key) textKeys.set(node, key);
      }

      if (key) {
        const raw = node.nodeValue || "";
        const leading = raw.match(/^\s*/)?.[0] ?? "";
        const trailing = raw.match(/\s*$/)?.[0] ?? "";
        node.nodeValue = `${leading}${translations[language][key]}${trailing}`;
      }
      node = walker.nextNode() as Text | null;
    }
  }

  function applyMetadata(language: LanguageCode) {
    const page = document.body.dataset.page || "home";
    const titleKey = `meta.${page}.title` as TranslationKey;
    const descriptionKey = `meta.${page}.description` as TranslationKey;
    const title = translations[language][titleKey];
    const description = translations[language][descriptionKey];

    if (title) {
      document.title = title;
      document.querySelector('meta[property="og:title"]')?.setAttribute("content", title);
      document.querySelector('meta[name="twitter:title"]')?.setAttribute("content", title);
    }
    if (description) {
      document.querySelector('meta[name="description"]')?.setAttribute("content", description);
      document.querySelector('meta[property="og:description"]')?.setAttribute("content", description);
      document.querySelector('meta[name="twitter:description"]')?.setAttribute("content", description);
    }
  }

  function applyLanguage(language: LanguageCode, persist: boolean) {
    const appWindow = window as LanguageWindow;
    appWindow.__kwiinLanguage = language;
    document.documentElement.lang = language;
    document.body.dataset.language = language;

    applyExplicitTranslations(language);
    applyAutomaticText(language);
    applyMetadata(language);

    if (persist) {
      try {
        localStorage.setItem(STORAGE_KEY, language);
        localStorage.removeItem(LEGACY_STORAGE_KEY);
      } catch {
        // Language selection still works for the current visit.
      }
    }

    window.dispatchEvent(
      new CustomEvent("kwiin:language-change", { detail: { language } })
    );
  }

  function initSiteLanguage() {
    const appWindow = window as LanguageWindow;
    const active = appWindow.__kwiinLanguage ?? storedLanguage();

    appWindow.__kwiinT = (key, params = {}) => translate(
      appWindow.__kwiinLanguage ?? "de",
      key,
      params
    );
    appWindow.__kwiinSetLanguage = (language, animate = true) => {
      if (!isLanguageCode(language)) return;
      const reduceMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (animate && !reduceMotion) {
        document.body.classList.add("is-language-switching");
        window.setTimeout(() => {
          applyLanguage(language, true);
          requestAnimationFrame(() => document.body.classList.remove("is-language-switching"));
        }, 150);
      } else {
        applyLanguage(language, true);
      }
    };

    applyLanguage(active, false);
  }

  initSiteLanguage();
  document.addEventListener("astro:after-swap", initSiteLanguage);
</script>
