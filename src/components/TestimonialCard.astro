---
import type { Testimonial } from "../data/testimonials";

export interface Props {
  testimonial: Testimonial;
}
const { testimonial } = Astro.props;
const quoteKey = testimonial.name === "Rudi"
  ? "home.testimonialOne"
  : testimonial.name === "Eliza"
    ? "home.testimonialTwo"
    : "home.testimonialThree";
---

<figure
  class="reveal-up kwiin-tilt kwiin-panel relative flex h-full flex-col justify-between gap-6 rounded-3xl p-8"
>
  <span class="kwiin-tilt-sheen" aria-hidden="true"></span>
  <span class="relative z-10 font-display text-6xl leading-none text-kwiin-gold/50" aria-hidden="true">
    &ldquo;
  </span>
  <blockquote class="relative z-10 -mt-8 font-display text-xl leading-relaxed text-kwiin-ivory text-balance" data-i18n={quoteKey}>
    {testimonial.quote}
  </blockquote>
  <figcaption class="relative z-10 flex items-center gap-3 text-xs uppercase tracking-[0.2em] text-kwiin-gold-bright/80">
    <span class="h-px w-8 bg-kwiin-gold/50" aria-hidden="true"></span>
    {testimonial.name}
  </figcaption>
</figure>
