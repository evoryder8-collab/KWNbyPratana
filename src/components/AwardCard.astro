---
import type { Award } from "../data/awards";

export interface Props {
  award: Award;
}
const { award } = Astro.props;

const medalColor: Record<Award["medal"], string> = {
  Gold: "from-kwiin-gold-dim via-kwiin-gold to-kwiin-gold-bright text-kwiin-black",
  Silver: "from-[#9a9a9a] via-[#cfcfcf] to-[#eaeaea] text-kwiin-black",
  Bronze: "from-[#7a4a2c] via-[#a9683c] to-[#c98a55] text-kwiin-black",
};
---

<div
  class="reveal-up kwiin-card flex flex-col items-center gap-3 rounded-2xl px-5 py-8 text-center"
>
  <span
    class={`flex h-14 w-14 items-center justify-center rounded-full bg-gradient-to-br ${medalColor[award.medal]} text-xs font-semibold uppercase tracking-wide shadow-lg`}
    aria-hidden="true"
  >
    {award.medal[0]}
  </span>
  <p class="text-sm uppercase tracking-[0.12em] text-kwiin-gold-bright">{award.medal}</p>
  <p class="font-display text-lg text-kwiin-ivory">{award.category}</p>
</div>
