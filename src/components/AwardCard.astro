---
import type { Award } from "../data/awards";
import { medalLabels } from "../data/awards";

export interface Props {
  award: Award;
}
const { award } = Astro.props;

const medalColor: Record<Award["medal"], string> = {
  Gold: "from-kwiin-gold-dim via-kwiin-gold to-kwiin-gold-bright text-kwiin-black",
  Silver: "from-[#9a9a9a] via-[#cfcfcf] to-[#eaeaea] text-kwiin-black",
  Bronze: "from-[#7a4a2c] via-[#a9683c] to-[#c98a55] text-kwiin-black",
};
---

<div
  class="reveal-up kwiin-tilt kwiin-panel relative flex flex-col items-center gap-3 rounded-3xl px-5 py-8 text-center"
>
  <span class="kwiin-tilt-sheen" aria-hidden="true"></span>
  <span class="relative z-10 flex h-16 w-16 items-center justify-center" aria-hidden="true">
    <span class="absolute inset-0 rounded-full border border-kwiin-gold/25"></span>
    <span
      class={`flex h-12 w-12 items-center justify-center rounded-full bg-gradient-to-br ${medalColor[award.medal]} font-display text-lg shadow-lg`}
    >
      {medalLabels[award.medal][0]}
    </span>
  </span>
  <p class="relative z-10 text-xs uppercase tracking-[0.2em] text-kwiin-gold-bright">
    {medalLabels[award.medal]}
  </p>
  <p class="relative z-10 font-display text-lg text-kwiin-ivory">{award.category}</p>
</div>
