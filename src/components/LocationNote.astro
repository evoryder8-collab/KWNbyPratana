---
/**
 * Subtle partner/location disclosure. Use the "full" variant once per page
 * at most, lower on the page (never in a hero). Keep visually secondary,
 * small text, muted color.
 */
export interface Props {
  variant?: "subtle" | "full" | "official";
  class?: string;
}
import { subtleLocationLine, fullLocationLine, officialPartnerLine } from "../data/partners";

const { variant = "subtle", class: className = "" } = Astro.props;

const text =
  variant === "full"
    ? fullLocationLine
    : variant === "official"
      ? officialPartnerLine
      : subtleLocationLine;
const translationKey =
  variant === "full"
    ? "common.locationFull"
    : variant === "official"
      ? "common.locationOfficial"
      : "common.locationSubtle";
---

<p class={`text-xs leading-relaxed text-kwiin-soft-grey/70 max-w-md ${className}`} data-i18n={translationKey}>
  {text}
</p>
