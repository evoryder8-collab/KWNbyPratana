---
import { contact, brandLine } from "../data/contact";
import { footerPartnerNote } from "../data/partners";
import { navItems } from "../data/navigation";
import { WHATSAPP_MESSAGES, whatsappUrl } from "../utils/whatsapp";
import { withBase } from "../utils/base";

const whatsappHref = whatsappUrl(WHATSAPP_MESSAGES.studioGeneric);
const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 bg-kwiin-charcoal/40">
  <div class="mx-auto grid max-w-7xl gap-10 px-5 py-16 lg:grid-cols-4 lg:px-8">
    <div class="lg:col-span-2">
      <a href={withBase("/")} class="flex items-center gap-2 font-display text-xl text-kwiin-ivory">
        <img src={withBase("/assets/kwiin-logo.png")} alt="KWIIN by Pratana Halstrick" class="h-10 w-auto" />
        KWIIN <span class="text-kwiin-gold-bright">by Pratana</span>
      </a>
      <p class="mt-4 max-w-sm text-sm leading-relaxed text-kwiin-soft-grey">{brandLine}</p>
      <a
        href={whatsappHref}
        target="_blank"
        rel="noopener noreferrer"
        class="kwiin-magnetic mt-6 inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-kwiin-gold to-kwiin-gold-bright px-6 py-3 text-sm font-semibold uppercase tracking-[0.08em] text-kwiin-black"
      >
        Book via WhatsApp
      </a>
    </div>

    <div>
      <h2 class="text-xs uppercase tracking-[0.14em] text-kwiin-gold-bright/80">Explore</h2>
      <ul class="mt-4 flex flex-col gap-3 text-sm text-kwiin-soft-grey">
        {
          navItems.map((item) => (
            <li>
              <a href={withBase(item.href)} class="transition-colors hover:text-kwiin-ivory">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h2 class="text-xs uppercase tracking-[0.14em] text-kwiin-gold-bright/80">Connect</h2>
      <ul class="mt-4 flex flex-col gap-3 text-sm text-kwiin-soft-grey">
        <li>{contact.hours}</li>
        <li>{contact.languages.join(" · ")}</li>
        <li>
          <a href={contact.instagramUrl} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-kwiin-ivory">
            {contact.instagramHandle}
          </a>
        </li>
        <li>General contact: {contact.generalContactNumber}</li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/5 px-5 py-6 lg:px-8">
    <p class="mx-auto max-w-3xl text-center text-[11px] leading-relaxed text-kwiin-soft-grey/50">
      {footerPartnerNote}
    </p>
    <p class="mt-3 text-center text-[11px] text-kwiin-soft-grey/40">
      &copy; {year} KWIIN by Pratana Halstrick. All rights reserved.
    </p>
  </div>
</footer>
