---
import { contact, tagline, closingLines } from "../data/contact";
import { footerPartnerNote } from "../data/partners";
import { navItems } from "../data/navigation";
import { WHATSAPP_MESSAGES, whatsappUrl } from "../utils/whatsapp";
import { withBase } from "../utils/base";
import LotusMark from "./LotusMark.astro";
import OrnamentDivider from "./OrnamentDivider.astro";

const whatsappHref = whatsappUrl(WHATSAPP_MESSAGES.studioGeneric);
const year = new Date().getFullYear();
const values = [
  { label: "Eleganz", key: "values.elegance" },
  { label: "Qualität", key: "values.quality" },
  { label: "Achtsamkeit", key: "values.mindfulness" },
  { label: "Respekt", key: "values.respect" },
  { label: "Authentizität", key: "values.authenticity" },
] as const;
const navKeys = {
  "/studio": "nav.signature",
  "/mobile-spa": "nav.mobile",
  "/services": "nav.services",
  "/about": "nav.about",
  "/contact": "nav.contact",
} as const;
---

<footer class="relative z-10 overflow-hidden border-t border-white/5 bg-kwiin-espresso/60">
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-64 bg-[radial-gradient(60%_100%_at_50%_0%,rgba(201,163,92,0.08),transparent)]"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto max-w-7xl px-5 pb-14 pt-20 lg:px-8">
    <div class="text-center">
      <LotusMark class="mx-auto h-8 w-auto text-kwiin-gold" />
      <p class="mt-6 font-display text-3xl leading-snug text-kwiin-ivory text-balance sm:text-4xl">
        <span data-i18n="common.closingOne">{closingLines[0]}</span><br />
        <span class="kwiin-accent" data-i18n="common.closingTwo">{closingLines[1]}</span>
      </p>
      <a
        href={whatsappHref}
        target="_blank"
        rel="noopener noreferrer"
        class="kwiin-magnetic mt-8 inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-kwiin-gold to-kwiin-gold-bright px-8 py-3.5 text-sm font-semibold uppercase tracking-[0.08em] text-kwiin-black shadow-[0_0_40px_-10px_rgba(201,163,92,0.5)]"
        data-i18n-whatsapp="common.studioWhatsApp"
        data-i18n-aria-label="common.whatsappAppointment"
      >
        <span data-i18n="common.whatsappAppointment">Termin via WhatsApp</span>
      </a>
    </div>

    <OrnamentDivider class="my-14" />

    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <div class="lg:col-span-2">
        <a href={withBase("/")} class="flex items-center gap-3 font-display text-xl text-kwiin-ivory">
          <img src={withBase("/assets/kwiin-logo.png")} alt="KWIIN by Pratana Halstrick" class="h-10 w-auto" />
          KWIIN <span class="text-sm italic text-kwiin-gold-bright">by Pratana</span>
        </a>
        <p class="mt-4 max-w-sm font-display text-lg italic text-kwiin-gold-bright/90" data-i18n="common.tagline">{tagline}</p>
        <p class="mt-3 max-w-sm text-sm leading-relaxed text-kwiin-soft-grey" data-i18n="footer.description">
          Traditionelle thailändische Heilkunst, verbunden mit modernem Luxus und höchster
          Qualität. In Dübendorf und bei Ihnen, in der ganzen Region Zürich.
        </p>
      </div>

      <div>
        <h2 class="text-xs uppercase tracking-[0.2em] text-kwiin-gold-bright/80" data-i18n="footer.explore">Entdecken</h2>
        <ul class="mt-4 flex flex-col gap-3 text-sm text-kwiin-soft-grey">
          {
            navItems.map((item) => (
              <li>
                <a href={withBase(item.href)} class="transition-colors hover:text-kwiin-gold-bright">
                  <span data-i18n={navKeys[item.href as keyof typeof navKeys]}>{item.label}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h2 class="text-xs uppercase tracking-[0.2em] text-kwiin-gold-bright/80" data-i18n="footer.contact">Kontakt</h2>
        <ul class="mt-4 flex flex-col gap-3 text-sm text-kwiin-soft-grey">
          <li data-i18n="common.hours">{contact.hours}</li>
          <li data-i18n="common.languages">{contact.languages.join(" · ")}</li>
          <li>
            <a href={contact.instagramUrl} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-kwiin-gold-bright">
              {contact.instagramHandle}
            </a>
          </li>
          <li><span data-i18n="footer.general">Allgemeiner Kontakt:</span> {contact.generalContactNumber}</li>
        </ul>
      </div>
    </div>

    <p class="mt-12 flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-[0.62rem] uppercase tracking-[0.28em] text-kwiin-soft-grey/50">
      {
        values.map((value, i) => (
          <>
            {i > 0 && <span class="text-kwiin-gold/40" aria-hidden="true">·</span>}
            <span data-i18n={value.key}>{value.label}</span>
          </>
        ))
      }
    </p>
  </div>

  <div class="relative border-t border-white/5 px-5 py-6 lg:px-8">
    <p class="mx-auto max-w-3xl text-center text-[11px] leading-relaxed text-kwiin-soft-grey/50" data-i18n="common.partnerFooter">
      {footerPartnerNote}
    </p>
    <p class="mt-3 text-center text-[11px] text-kwiin-soft-grey/40">
      &copy; {year} Barbu Media Switzerland. <span data-i18n="common.rights">Alle Rechte vorbehalten.</span>
    </p>
  </div>
</footer>
