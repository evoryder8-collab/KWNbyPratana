---
/**
 * The KWIIN lotus, drawn as fine line art. Replaces the emoji used in
 * earlier iterations everywhere a brand mark is needed (nav, dividers,
 * footer, emblems). Inherits `currentColor`, so tint it via text color.
 */
export interface Props {
  class?: string;
  strokeWidth?: number;
}
const { class: className = "h-6 w-auto", strokeWidth = 1.6 } = Astro.props;
---

<svg
  viewBox="0 0 64 44"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  <path d="M32 4 C26.5 13 26.5 24 32 34 C37.5 24 37.5 13 32 4 Z"></path>
  <path d="M32 34 C26 30.5 21 23 19.5 12.5 C27.5 17 31.5 25 32 34 Z"></path>
  <path d="M32 34 C38 30.5 43 23 44.5 12.5 C36.5 17 32.5 25 32 34 Z"></path>
  <path d="M32 34 C23 33 13 28 8.5 19.5 C18 20.5 28 26.5 32 34 Z"></path>
  <path d="M32 34 C41 33 51 28 55.5 19.5 C46 20.5 36 26.5 32 34 Z"></path>
  <path d="M20 38.5 C25 42 39 42 44 38.5"></path>
</svg>
