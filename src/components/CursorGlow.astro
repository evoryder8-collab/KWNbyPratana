---
/**
 * Custom gold cursor: a crisp dot that tracks the pointer directly plus a
 * silk ring that follows with a soft lerp and blooms over interactive
 * elements. Fine-pointer devices only, disabled for reduced motion, and the
 * native cursor is only hidden once the replacement is actually live.
 * The wrapper is persisted across view transitions so the loop never dies.
 */
---

<div id="kwiin-cursor" transition:persist="kwiin-cursor" aria-hidden="true">
  <div class="kwiin-cursor-ring" id="kwiin-cursor-ring"></div>
  <div class="kwiin-cursor-dot" id="kwiin-cursor-dot"></div>
</div>

<script>
  function initKwiinCursor() {
    const w = window as any;
    if (w.__kwiinCursorInit) return;

    const fine = window.matchMedia("(hover: hover) and (pointer: fine)").matches;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!fine || reduce) return;

    const dot = document.getElementById("kwiin-cursor-dot");
    const ring = document.getElementById("kwiin-cursor-ring");
    if (!dot || !ring) return;

    w.__kwiinCursorInit = true;
    document.body.classList.add("kwiin-cursor-on");

    let x = -100,
      y = -100,
      rx = -100,
      ry = -100,
      visible = false;

    function render() {
      rx += (x - rx) * 0.16;
      ry += (y - ry) * 0.16;
      dot!.style.transform = `translate(${x - 2.5}px, ${y - 2.5}px)`;
      const half = ring!.offsetWidth / 2;
      ring!.style.transform = `translate(${rx - half}px, ${ry - half}px)`;
      requestAnimationFrame(render);
    }

    document.addEventListener("pointermove", (e) => {
      x = e.clientX;
      y = e.clientY;
      if (!visible) {
        visible = true;
        dot!.style.opacity = "1";
        ring!.style.opacity = "1";
        rx = x;
        ry = y;
      }
      const target = e.target as HTMLElement | null;
      const interactive = target?.closest(
        "a, button, [role='button'], input, select, textarea, [data-cursor-hover]"
      );
      document.body.classList.toggle("kwiin-cursor-hover", Boolean(interactive));
    });

    document.documentElement.addEventListener("pointerleave", () => {
      dot!.style.opacity = "0";
      ring!.style.opacity = "0";
      visible = false;
    });

    // body classes come from the incoming document on view transitions,
    // so re-mark the cursor as active after every swap.
    document.addEventListener("astro:after-swap", () => {
      document.body.classList.add("kwiin-cursor-on");
    });

    requestAnimationFrame(render);
  }

  initKwiinCursor();
</script>
