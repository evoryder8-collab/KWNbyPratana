---
/**
 * Wraps any block of content and reveals it with a soft upward fade as it
 * scrolls into view, driven by GSAP + ScrollTrigger (see
 * src/utils/animations.ts, initialized once globally in BaseLayout). Falls
 * back to a static, fully-visible render when the user prefers reduced
 * motion, so content is never hidden from anyone.
 */
export interface Props {
  class?: string;
  /** stagger children with [data-reveal-child] instead of revealing the whole block at once */
  stagger?: boolean;
}
const { class: className = "", stagger = false } = Astro.props;
---

<div class={className} data-section-reveal data-stagger={stagger ? "true" : "false"}>
  <slot />
</div>
