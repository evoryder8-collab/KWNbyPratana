---
import type { Service } from "../data/services";
import PriceList from "./PriceList.astro";
import ServiceAvailabilityBadge from "./ServiceAvailabilityBadge.astro";
import WhatsAppButton from "./WhatsAppButton.astro";
import LotusMark from "./LotusMark.astro";
import {
  DEFAULT_MOBILE_SPA_TRAVEL_ZONE,
} from "../data/services";
import { whatsappUrl } from "../utils/whatsapp";

export interface Props {
  service: Service;
  context?: "studio" | "mobile" | "all";
}
const { service, context = "all" } = Astro.props;

const initialMode = context === "mobile" ? "mobile" : "studio";
const studioMessage = `${service.whatsappText} Ich wünsche einen Termin im Studio in Dübendorf.`;
const mobileMessage = `${service.whatsappText} Ich wünsche einen Mobile-Spa-Termin bei mir.`;
const studioWhatsapp = whatsappUrl(studioMessage);
const mobileWhatsapp15 = whatsappUrl(
  `${mobileMessage} Anfahrtszone: bis 15 km.`
);
const mobileWhatsapp30 = whatsappUrl(
  `${mobileMessage} Anfahrtszone: bis 30 km.`
);
const initialMessage = initialMode === "mobile" ? mobileMessage : studioMessage;
const ctaLabel = initialMode === "mobile"
  ? "Mobil via WhatsApp anfragen"
  : "Im Studio via WhatsApp buchen";
const serviceKey = {
  "kwiin-massage": "kwiin",
  "booster-muscles-sport": "booster",
  "flow-essence-lymph": "flow",
  "back-serenity": "back",
  "crown-serenity-head": "crown",
  "bata-flow-foot": "bata",
}[service.id] ?? "kwiin";
---

<article
  class="reveal-up kwiin-tilt kwiin-panel group relative flex h-full flex-col gap-5 rounded-3xl p-8"
  data-service-card
  data-service-id={service.id}
  data-initial-price-mode={initialMode}
  data-studio-whatsapp={studioWhatsapp}
  data-mobile-whatsapp-15={mobileWhatsapp15}
  data-mobile-whatsapp-30={mobileWhatsapp30}
>
  {
    service.knownFor && (
      <span
        class="absolute -top-3 left-8 z-10 rounded-full bg-gradient-to-r from-kwiin-gold to-kwiin-gold-bright px-3.5 py-1 text-[10px] font-semibold uppercase tracking-[0.14em] text-kwiin-black shadow-md"
      >
        <span data-i18n="pricing.signature">Signature</span>
      </span>
    )
  }

  <span class="kwiin-tilt-sheen" aria-hidden="true"></span>
  <LotusMark
    class="pointer-events-none absolute right-6 top-6 h-6 w-auto text-kwiin-gold/25 transition-colors duration-500 group-hover:text-kwiin-gold/60"
    strokeWidth={2}
  />

  <div class="relative z-10">
    <p class="text-[0.65rem] uppercase tracking-[0.22em] text-kwiin-gold-bright/75">
      <span data-i18n={`service.${serviceKey}.category`}>{service.category}</span>
    </p>
    <h3 class="mt-2 font-display text-[1.7rem] leading-tight text-kwiin-ivory">
      {service.title}
      {service.subtitle && <span class="italic text-kwiin-soft-grey"> · {service.subtitle}</span>}
    </h3>
  </div>

  <p class="relative z-10 font-display text-base italic text-kwiin-gold-bright/90" data-i18n={`service.${serviceKey}.tagline`}>{service.tagline}</p>

  <p class="relative z-10 flex-1 text-sm leading-relaxed text-kwiin-soft-grey" data-i18n={`service.${serviceKey}.description`}>{service.description}</p>

  <div class="relative z-10">
    <ServiceAvailabilityBadge
      serviceId={service.id}
      studioAvailable={service.studioAvailable}
      mobileAvailable={service.mobileAvailable}
      initialMode={initialMode}
    />
  </div>

  <div class="relative z-10">
    <PriceList
      durations={service.durations}
      initialMode={initialMode}
      initialTravelFeeChf={DEFAULT_MOBILE_SPA_TRAVEL_ZONE.feeChf}
      initialDistanceKm={DEFAULT_MOBILE_SPA_TRAVEL_ZONE.maxDistanceKm}
    />
  </div>

  <div class="relative z-10 mt-2" data-service-cta>
    <WhatsAppButton message={initialMessage} label={ctaLabel} variant="secondary" class="w-full justify-center" />
  </div>
</article>

<script>
  import type { TranslationKey } from "../i18n/translations";

  type PriceMode = "studio" | "mobile";
  type DistanceKm = "15" | "30";
  type PricingWindow = Window & {
    __kwiinT?: (key: TranslationKey, params?: Record<string, string | number>) => string;
    __kwiinPricingLanguageBound?: boolean;
  };

  const priceAnimations = new WeakMap<HTMLElement, number>();

  function localText(
    key: TranslationKey,
    params: Record<string, string | number> = {}
  ) {
    return (window as PricingWindow).__kwiinT?.(key, params) ?? key;
  }

  function animatePrice(
    element: HTMLElement,
    from: number,
    to: number,
    shouldAnimate: boolean
  ) {
    const previousAnimation = priceAnimations.get(element);
    if (previousAnimation) cancelAnimationFrame(previousAnimation);

    if (!shouldAnimate || from === to) {
      element.textContent = String(to);
      return;
    }

    const total = element.closest<HTMLElement>("[data-price-total]");
    const startedAt = performance.now();
    const duration = 440;
    total?.classList.remove("is-updating");
    void total?.offsetWidth;
    total?.classList.add("is-updating");

    function frame(now: number) {
      const progress = Math.min(1, (now - startedAt) / duration);
      const eased = 1 - Math.pow(1 - progress, 3);
      element.textContent = String(Math.round(from + (to - from) * eased));

      if (progress < 1) {
        priceAnimations.set(element, requestAnimationFrame(frame));
      } else {
        priceAnimations.delete(element);
        window.setTimeout(() => total?.classList.remove("is-updating"), 520);
      }
    }

    priceAnimations.set(element, requestAnimationFrame(frame));
  }

  function updateCardPriceMode(
    card: HTMLElement,
    mode: PriceMode,
    distanceKm: DistanceKm,
    shouldAnimate: boolean
  ) {
    card.dataset.priceMode = mode;
    card.dataset.mobileDistance = distanceKm;

    const selector = card.querySelector<HTMLElement>("[data-price-selector]");
    if (selector) selector.dataset.mode = mode;

    card
      .querySelectorAll<HTMLInputElement>("[data-price-mode-input]")
      .forEach((input) => {
        input.checked = input.value === mode;
      });

    const distancePanel = card.querySelector<HTMLElement>(
      "[data-mobile-distance-panel]"
    );
    distancePanel?.setAttribute(
      "aria-hidden",
      mode === "mobile" ? "false" : "true"
    );

    const distanceSelect = card.querySelector<HTMLSelectElement>(
      "[data-mobile-distance-select]"
    );
    if (distanceSelect) distanceSelect.value = distanceKm;

    const selectedDistanceOption = distanceSelect?.selectedOptions[0];
    const travelFee = Number(
      selectedDistanceOption?.dataset.travelFee ||
      (distanceKm === "30" ? 100 : 45)
    );

    card.querySelectorAll<HTMLElement>("[data-price-list]").forEach((list) => {
      list.dataset.mode = mode;
    });

    card.querySelectorAll<HTMLElement>("[data-price-row]").forEach((row) => {
      const studioPrice = Number(row.dataset.studioPrice || 0);
      const nextPrice = mode === "mobile" ? studioPrice + travelFee : studioPrice;
      const priceValue = row.querySelector<HTMLElement>("[data-price-value]");
      const currentPrice = Number(priceValue?.textContent || studioPrice);
      const breakdown = row.querySelector<HTMLElement>("[data-travel-breakdown]");
      const minutes = row.dataset.minutes || "";
      const duration = row.querySelector<HTMLElement>("[data-price-duration]");

      if (duration) {
        duration.textContent = localText("pricing.duration", { minutes });
      }

      if (priceValue) {
        animatePrice(priceValue, currentPrice, nextPrice, shouldAnimate);
      }

      if (breakdown) {
        breakdown.textContent = localText("pricing.breakdown", {
          fee: travelFee,
          distance: distanceKm,
        });
        breakdown.dataset.visible = mode === "mobile" ? "true" : "false";
        breakdown.setAttribute("aria-hidden", mode === "mobile" ? "false" : "true");
      }

      row.setAttribute(
        "aria-label",
        mode === "mobile"
          ? localText("pricing.rowMobile", {
              minutes,
              price: nextPrice,
              fee: travelFee,
              distance: distanceKm,
            })
          : localText("pricing.rowStudio", { minutes, price: nextPrice })
      );
    });

    const cta = card.querySelector<HTMLAnchorElement>("[data-service-cta] a");
    const ctaLabel = cta?.querySelector<HTMLElement>("span");
    if (cta) {
      const href = mode === "mobile"
        ? distanceKm === "30"
          ? card.getAttribute("data-mobile-whatsapp-30")
          : card.getAttribute("data-mobile-whatsapp-15")
        : card.dataset.studioWhatsapp;
      const label = mode === "mobile"
        ? localText("pricing.ctaMobile", { distance: distanceKm })
        : localText("pricing.ctaStudio");

      if (href) {
        try {
          const localizedUrl = new URL(href);
          localizedUrl.searchParams.set("text", label);
          cta.href = localizedUrl.toString();
        } catch {
          cta.href = href;
        }
      }
      cta.setAttribute("aria-label", label);
      if (ctaLabel) ctaLabel.textContent = label;
    }
  }

  function initServicePricing() {
    const cards = Array.from(
      document.querySelectorAll<HTMLElement>("[data-service-card]")
    );
    if (!cards.length) return;

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const initialMode = (cards[0].dataset.initialPriceMode || "studio") as PriceMode;
    let activeDistance: DistanceKm = "15";

    function updateAllCards(
      mode: PriceMode,
      distanceKm: DistanceKm,
      shouldAnimate: boolean
    ) {
      activeDistance = distanceKm;
      cards.forEach((card) =>
        updateCardPriceMode(
          card,
          mode,
          distanceKm,
          shouldAnimate && !reduceMotion
        )
      );
    }

    cards.forEach((card) => {
      if (card.dataset.pricingBound === "true") return;
      card.dataset.pricingBound = "true";

      card.addEventListener("change", (event) => {
        const input = (event.target as HTMLElement).closest<HTMLInputElement>(
          "[data-price-mode-input]"
        );
        if (input) {
          updateAllCards(input.value as PriceMode, activeDistance, true);
          return;
        }

        const distanceSelect = (event.target as HTMLElement).closest<HTMLSelectElement>(
          "[data-mobile-distance-select]"
        );
        if (distanceSelect) {
          updateAllCards("mobile", distanceSelect.value as DistanceKm, true);
        }
      });
    });

    updateAllCards(initialMode, activeDistance, false);
  }

  initServicePricing();
  document.addEventListener("astro:after-swap", initServicePricing);

  const pricingWindow = window as PricingWindow;
  if (!pricingWindow.__kwiinPricingLanguageBound) {
    pricingWindow.__kwiinPricingLanguageBound = true;
    window.addEventListener("kwiin:language-change", () => {
      document.querySelectorAll<HTMLElement>("[data-service-card]").forEach((card) => {
        const mode = (card.dataset.priceMode || card.dataset.initialPriceMode || "studio") as PriceMode;
        const distance = (card.dataset.mobileDistance || "15") as DistanceKm;
        updateCardPriceMode(card, mode, distance, false);
      });
    });
  }
</script>
