---
import type { Service } from "../data/services";
import PriceList from "./PriceList.astro";
import ServiceAvailabilityBadge from "./ServiceAvailabilityBadge.astro";
import WhatsAppButton from "./WhatsAppButton.astro";
import LotusMark from "./LotusMark.astro";

export interface Props {
  service: Service;
  context?: "studio" | "mobile" | "all";
}
const { service, context = "all" } = Astro.props;

const ctaLabel = context === "mobile" ? "Via WhatsApp anfragen" : "Via WhatsApp buchen";
---

<article
  class="reveal-up kwiin-tilt kwiin-panel group relative flex h-full flex-col gap-5 rounded-3xl p-8"
  data-service-card
>
  {
    service.knownFor && (
      <span
        class="absolute -top-3 left-8 z-10 rounded-full bg-gradient-to-r from-kwiin-gold to-kwiin-gold-bright px-3.5 py-1 text-[10px] font-semibold uppercase tracking-[0.14em] text-kwiin-black shadow-md"
      >
        Signature
      </span>
    )
  }

  <span class="kwiin-tilt-sheen" aria-hidden="true"></span>
  <LotusMark
    class="pointer-events-none absolute right-6 top-6 h-6 w-auto text-kwiin-gold/25 transition-colors duration-500 group-hover:text-kwiin-gold/60"
    strokeWidth={2}
  />

  <div class="relative z-10">
    <p class="text-[0.65rem] uppercase tracking-[0.22em] text-kwiin-gold-bright/75">
      {service.category}
    </p>
    <h3 class="mt-2 font-display text-[1.7rem] leading-tight text-kwiin-ivory">
      {service.title}
      {service.subtitle && <span class="italic text-kwiin-soft-grey"> · {service.subtitle}</span>}
    </h3>
  </div>

  <p class="relative z-10 font-display text-base italic text-kwiin-gold-bright/90">{service.tagline}</p>

  <p class="relative z-10 flex-1 text-sm leading-relaxed text-kwiin-soft-grey">{service.description}</p>

  <div class="relative z-10">
    <ServiceAvailabilityBadge
      studioAvailable={service.studioAvailable}
      mobileAvailable={service.mobileAvailable}
    />
  </div>

  <div class="relative z-10">
    <PriceList durations={service.durations} />
  </div>

  <WhatsAppButton message={service.whatsappText} label={ctaLabel} variant="secondary" class="relative z-10 mt-2 w-full justify-center" />
</article>
