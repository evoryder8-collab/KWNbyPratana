---
/**
 * Editorial section divider: two fading gold hairlines meeting a small
 * lotus mark. Purely decorative.
 */
import LotusMark from "./LotusMark.astro";

export interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<div class={`flex items-center justify-center gap-5 ${className}`} aria-hidden="true">
  <span class="h-px w-20 bg-gradient-to-r from-transparent to-kwiin-gold/60 sm:w-28"></span>
  <LotusMark class="h-5 w-auto text-kwiin-gold" strokeWidth={2} />
  <span class="h-px w-20 bg-gradient-to-l from-transparent to-kwiin-gold/60 sm:w-28"></span>
</div>
