---
import { MOBILE_SPA_TRAVEL_ZONES } from "../data/services";

export interface Props {
  serviceId: string;
  studioAvailable: boolean;
  mobileAvailable: boolean;
  initialMode?: "studio" | "mobile";
}

const {
  serviceId,
  studioAvailable,
  mobileAvailable,
  initialMode = mobileAvailable && !studioAvailable ? "mobile" : "studio",
} = Astro.props;

const inputName = `price-mode-${serviceId}`;
const hintId = `price-mode-hint-${serviceId}`;
---

<fieldset
  class="kwiin-price-selector"
  data-price-selector={serviceId}
  data-mode={initialMode}
  aria-describedby={hintId}
>
  <legend class="sr-only" data-i18n="pricing.legend">Preis nach Behandlungsort auswählen</legend>

  <div class="kwiin-price-selector__intro">
    <span data-i18n="pricing.intro">Preis anzeigen für</span>
    <span class="kwiin-price-selector__action">
      <span data-i18n="pricing.tap">Antippen zum Wechseln</span>
      <svg viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M5.2 9h7.6M9.8 6l3 3-3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </span>
  </div>

  <div class="kwiin-price-selector__track">
    <span class="kwiin-price-selector__indicator" aria-hidden="true"></span>

    {
      studioAvailable && (
        <label class="kwiin-price-selector__option" data-price-mode-option="studio">
          <input
            class="sr-only"
            type="radio"
            name={inputName}
            value="studio"
            data-price-mode-input="studio"
            checked={initialMode === "studio"}
          />
          <svg class="kwiin-price-selector__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M4.5 20h15M6.5 20V8.5L12 4l5.5 4.5V20M9.2 20v-6h5.6v6" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
          <span class="kwiin-price-selector__copy">
            <strong data-i18n="pricing.studio">Im Studio</strong>
            <small data-i18n="pricing.studioPlace">Dübendorf</small>
          </span>
          <span class="kwiin-price-selector__check" aria-hidden="true">
            <svg viewBox="0 0 16 16" fill="none">
              <path d="m4 8.3 2.4 2.4L12.2 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </span>
        </label>
      )
    }

    {
      mobileAvailable && (
        <label class="kwiin-price-selector__option" data-price-mode-option="mobile">
          <input
            class="sr-only"
            type="radio"
            name={inputName}
            value="mobile"
            data-price-mode-input="mobile"
            checked={initialMode === "mobile"}
          />
          <svg class="kwiin-price-selector__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="m3.5 11 6.3-5.3 6.3 5.3v9H3.5v-9Z" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"></path>
            <path d="M7 20v-5.2h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path>
            <path d="M21 15.5h-7.4M16.7 12.4l-3.1 3.1 3.1 3.1" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
          <span class="kwiin-price-selector__copy">
            <strong data-i18n="pricing.mobile">Mobil</strong>
            <small data-i18n="pricing.mobilePlace">bei Ihnen · Anfahrt inklusive</small>
          </span>
          <span class="kwiin-price-selector__check" aria-hidden="true">
            <svg viewBox="0 0 16 16" fill="none">
              <path d="m4 8.3 2.4 2.4L12.2 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </span>
        </label>
      )
    }
  </div>

  <div
    class="kwiin-distance-panel"
    data-mobile-distance-panel
    aria-hidden={initialMode === "mobile" ? "false" : "true"}
  >
    <div class="kwiin-distance-panel__heading">
      <span class="kwiin-distance-panel__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M12 21s6-5.1 6-11a6 6 0 1 0-12 0c0 5.9 6 11 6 11Z" stroke="currentColor" stroke-width="1.35" stroke-linejoin="round"></path>
          <circle cx="12" cy="10" r="2.1" stroke="currentColor" stroke-width="1.35"></circle>
        </svg>
      </span>
      <span>
        <strong data-i18n="pricing.zoneTitle">Anfahrtszone wählen</strong>
        <small data-i18n="pricing.zoneCopy">Die Anfahrt ist direkt im Gesamtpreis enthalten</small>
      </span>
    </div>

    <label class="kwiin-distance-panel__select-wrap">
      <span class="sr-only" data-i18n="pricing.zoneHidden">Maximale Entfernung für Mobile Spa</span>
      <select data-mobile-distance-select aria-label="Anfahrtszone für Mobile Spa" data-i18n-aria-label="pricing.zoneAria">
        {
          MOBILE_SPA_TRAVEL_ZONES.map((zone) => (
            <option
              value={zone.maxDistanceKm}
              data-travel-fee={zone.feeChf}
              data-i18n={zone.maxDistanceKm === 15 ? "pricing.zone15" : "pricing.zone30"}
            >
              Bis {zone.maxDistanceKm} km · plus CHF {zone.feeChf}
            </option>
          ))
        }
      </select>
      <svg viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="m5 7 4 4 4-4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </label>
  </div>

  <p id={hintId} class="kwiin-price-selector__hint" data-i18n="pricing.hint">
    Die Auswahl gilt für alle Behandlungen auf dieser Seite.
  </p>
</fieldset>

<style>
  .kwiin-price-selector {
    min-width: 0;
    border: 0;
    padding: 0;
  }

  .kwiin-price-selector__intro {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.55rem;
    color: rgba(92, 62, 21, 0.92);
    font-size: 0.58rem;
    letter-spacing: 0.16em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .kwiin-price-selector__action {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    color: rgba(53, 45, 64, 0.78);
    letter-spacing: 0.08em;
    text-align: right;
  }

  .kwiin-price-selector__action svg {
    width: 0.85rem;
    flex: none;
    animation: kwiin-selector-nudge 2.4s ease-in-out infinite;
  }

  .kwiin-price-selector__track {
    position: relative;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
    padding: 4px;
    overflow: hidden;
    border: 1px solid rgba(116, 82, 29, 0.34);
    border-radius: 1.15rem;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.92), transparent 45%),
      rgba(230, 221, 226, 0.9);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.9) inset,
      0 12px 28px -16px rgba(72, 58, 79, 0.46);
    backdrop-filter: blur(12px);
  }

  .kwiin-price-selector__indicator {
    position: absolute;
    inset-block: 4px;
    left: 4px;
    width: calc(50% - 4px);
    border: 1px solid rgba(116, 82, 29, 0.36);
    border-radius: 0.9rem;
    background:
      radial-gradient(circle at 22% 20%, rgba(255, 255, 255, 0.56), transparent 45%),
      linear-gradient(135deg, rgba(244, 216, 141, 0.42), rgba(185, 133, 47, 0.14));
    box-shadow:
      0 0 24px -10px rgba(185, 133, 47, 0.48),
      0 1px 0 rgba(255, 255, 255, 0.76) inset;
    transform: translateX(0);
    transition:
      transform 0.58s var(--ease-silk),
      border-color 0.58s var(--ease-silk),
      background 0.58s var(--ease-silk),
      box-shadow 0.58s var(--ease-silk);
  }

  .kwiin-price-selector[data-mode="mobile"] .kwiin-price-selector__indicator {
    border-color: rgba(98, 70, 96, 0.38);
    background:
      radial-gradient(circle at 78% 20%, rgba(255, 255, 255, 0.52), transparent 45%),
      linear-gradient(135deg, rgba(183, 180, 208, 0.52), rgba(71, 163, 171, 0.16));
    box-shadow:
      0 0 25px -10px rgba(98, 70, 96, 0.38),
      0 1px 0 rgba(255, 255, 255, 0.76) inset;
    transform: translateX(100%);
  }

  .kwiin-price-selector__option {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    min-width: 0;
    min-height: 3.65rem;
    align-items: center;
    gap: 0.52rem;
    border-radius: 0.9rem;
    padding: 0.55rem 0.62rem;
    color: rgba(53, 45, 64, 0.74);
    cursor: pointer;
    user-select: none;
    transition:
      color 0.45s var(--ease-silk),
      transform 0.25s var(--ease-silk);
    -webkit-tap-highlight-color: transparent;
  }

  .kwiin-price-selector__option:active {
    transform: scale(0.975);
  }

  .kwiin-price-selector__option:has(input:focus-visible) {
    outline: 1px solid var(--color-kwiin-gold-bright);
    outline-offset: -2px;
  }

  .kwiin-price-selector[data-mode="studio"] [data-price-mode-option="studio"],
  .kwiin-price-selector[data-mode="mobile"] [data-price-mode-option="mobile"] {
    color: var(--color-kwiin-ivory);
  }

  .kwiin-price-selector__icon {
    width: 1.12rem;
    flex: none;
    color: currentColor;
    opacity: 0.75;
    transition: opacity 0.45s var(--ease-silk), filter 0.45s var(--ease-silk);
  }

  [data-price-mode-option="mobile"] .kwiin-price-selector__icon {
    width: 1.26rem;
  }

  .kwiin-price-selector[data-mode="studio"] [data-price-mode-option="studio"] .kwiin-price-selector__icon {
    color: var(--color-kwiin-gold-bright);
    opacity: 1;
    filter: drop-shadow(0 0 6px rgba(236, 210, 155, 0.45));
  }

  .kwiin-price-selector[data-mode="mobile"] [data-price-mode-option="mobile"] .kwiin-price-selector__icon {
    color: #73516f;
    opacity: 1;
    filter: drop-shadow(0 0 6px rgba(178, 135, 218, 0.5));
  }

  .kwiin-price-selector__copy {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 0.16rem;
    text-align: left;
  }

  .kwiin-price-selector__copy strong {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.055em;
    line-height: 1.18;
    overflow-wrap: normal;
    text-transform: uppercase;
    white-space: normal;
    word-break: normal;
  }

  .kwiin-price-selector__copy small {
    font-size: 0.54rem;
    font-weight: 400;
    letter-spacing: 0.025em;
    line-height: 1.28;
    opacity: 0.82;
    overflow-wrap: normal;
    white-space: normal;
    word-break: normal;
  }

  .kwiin-price-selector__check {
    display: grid;
    width: 1rem;
    aspect-ratio: 1;
    place-items: center;
    border: 1px solid currentColor;
    border-radius: 50%;
    opacity: 0;
    transform: scale(0.6);
    transition: opacity 0.4s var(--ease-silk), transform 0.4s var(--ease-silk);
  }

  .kwiin-price-selector__check svg {
    width: 0.7rem;
  }

  .kwiin-price-selector[data-mode="studio"] [data-price-mode-option="studio"] .kwiin-price-selector__check,
  .kwiin-price-selector[data-mode="mobile"] [data-price-mode-option="mobile"] .kwiin-price-selector__check {
    opacity: 0.72;
    transform: scale(1);
  }

  .kwiin-price-selector__hint {
    margin-top: 0.48rem;
    text-align: center;
    color: rgba(53, 45, 64, 0.72);
    font-size: 0.52rem;
    letter-spacing: 0.06em;
    line-height: 1.4;
  }

  .kwiin-distance-panel {
    display: block;
    max-height: 0;
    margin-top: 0;
    overflow: hidden;
    border: 1px solid transparent;
    border-radius: 1rem;
    background: rgba(247, 241, 243, 0);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-0.45rem) scale(0.985);
    transition:
      max-height 0.58s var(--ease-silk),
      margin-top 0.58s var(--ease-silk),
      padding 0.58s var(--ease-silk),
      border-color 0.58s var(--ease-silk),
      background 0.58s var(--ease-silk),
      opacity 0.45s var(--ease-silk),
      transform 0.58s var(--ease-silk);
  }

  .kwiin-price-selector[data-mode="mobile"] .kwiin-distance-panel {
    max-height: 9rem;
    margin-top: 0.65rem;
    padding: 0.72rem;
    border-color: rgba(98, 70, 96, 0.38);
    background:
      radial-gradient(circle at 0 0, rgba(183, 180, 208, 0.36), transparent 55%),
      rgba(250, 247, 248, 0.92);
    box-shadow: 0 14px 30px -18px rgba(98, 70, 96, 0.46);
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  .kwiin-distance-panel__heading {
    display: flex;
    min-height: 0;
    align-items: center;
    gap: 0.55rem;
    overflow: hidden;
  }

  .kwiin-distance-panel__heading > span:last-child {
    display: flex;
    min-width: 0;
    flex: 1;
    flex-direction: column;
    gap: 0.13rem;
  }

  .kwiin-distance-panel__heading strong {
    color: rgba(53, 45, 64, 0.96);
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .kwiin-distance-panel__heading small {
    color: rgba(53, 45, 64, 0.74);
    font-size: 0.5rem;
    line-height: 1.35;
  }

  .kwiin-distance-panel__icon {
    display: grid;
    width: 1.8rem;
    aspect-ratio: 1;
    flex: none;
    place-items: center;
    border: 1px solid rgba(98, 70, 96, 0.34);
    border-radius: 50%;
    color: #73516f;
    background: rgba(183, 180, 208, 0.24);
  }

  .kwiin-distance-panel__icon svg {
    width: 0.9rem;
  }

  .kwiin-distance-panel__select-wrap {
    position: relative;
    display: flex;
    align-items: center;
    margin-top: 0.62rem;
    overflow: hidden;
    border: 1px solid rgba(98, 70, 96, 0.44);
    border-radius: 0.75rem;
    background:
      linear-gradient(135deg, rgba(183, 180, 208, 0.34), rgba(244, 216, 141, 0.16)),
      rgba(255, 255, 255, 0.9);
    color: var(--color-kwiin-ivory);
    transition: border-color 0.35s var(--ease-silk), box-shadow 0.35s var(--ease-silk);
  }

  .kwiin-distance-panel__select-wrap:focus-within {
    border-color: rgba(224, 199, 244, 0.58);
    box-shadow: 0 0 0 3px rgba(124, 94, 163, 0.12);
  }

  .kwiin-distance-panel__select-wrap select {
    width: 100%;
    appearance: none;
    border: 0;
    outline: 0;
    padding: 0.68rem 2.2rem 0.68rem 0.78rem;
    color: inherit;
    background: transparent;
    font: inherit;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    cursor: pointer;
  }

  .kwiin-distance-panel__select-wrap > svg {
    position: absolute;
    right: 0.68rem;
    width: 0.9rem;
    color: #73516f;
    pointer-events: none;
  }

  @keyframes kwiin-selector-nudge {
    0%, 100% { transform: translateX(0); opacity: 0.46; }
    50% { transform: translateX(0.18rem); opacity: 0.9; }
  }

  @media (max-width: 40rem) {
    .kwiin-price-selector__intro {
      align-items: flex-start;
      gap: 0.55rem;
    }

    .kwiin-price-selector__action {
      max-width: 48%;
      justify-content: flex-end;
      line-height: 1.35;
    }

    .kwiin-price-selector__option {
      grid-template-columns: 1.2rem minmax(0, 1fr);
      min-height: 4.65rem;
      align-items: center;
      gap: 0.45rem;
      padding: 0.62rem 0.55rem;
    }

    .kwiin-price-selector__copy {
      padding-right: 0.85rem;
    }

    .kwiin-price-selector__check {
      position: absolute;
      right: 0.48rem;
      top: 0.48rem;
    }

    .kwiin-price-selector__copy strong {
      font-size: 0.62rem;
    }

    .kwiin-price-selector__copy small {
      font-size: 0.52rem;
    }
  }

  @media (max-width: 23rem) {
    .kwiin-price-selector__action {
      font-size: 0.5rem;
    }

    .kwiin-price-selector__option {
      grid-template-columns: 1.05rem minmax(0, 1fr);
      gap: 0.25rem;
      padding-inline: 0.32rem;
    }

    .kwiin-price-selector__copy {
      padding-right: 0.5rem;
    }

    .kwiin-price-selector__check {
      right: 0.3rem;
      top: 0.38rem;
      width: 0.88rem;
    }

    .kwiin-price-selector__copy strong {
      font-size: 0.56rem;
    }

    .kwiin-price-selector__copy small {
      font-size: 0.47rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .kwiin-price-selector__action svg {
      animation: none;
    }

    .kwiin-price-selector__indicator,
    .kwiin-price-selector__option,
    .kwiin-price-selector__check,
    .kwiin-distance-panel {
      transition: none;
    }
  }
</style>
