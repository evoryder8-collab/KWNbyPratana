---
import { whatsappUrl } from "../utils/whatsapp";
import type { TranslationKey } from "../i18n/translations";

export interface Props {
  message: string;
  label?: string;
  variant?: "primary" | "secondary" | "ghost";
  size?: "md" | "lg";
  ariaLabel?: string;
  class?: string;
  labelKey?: TranslationKey;
  messageKey?: TranslationKey;
}

const {
  message,
  label = "Book via WhatsApp",
  variant = "primary",
  size = "md",
  ariaLabel,
  class: className = "",
  labelKey,
  messageKey,
} = Astro.props;

const href = whatsappUrl(message);

const base =
  "kwiin-magnetic inline-flex items-center justify-center gap-2 rounded-full font-medium tracking-wide transition-all duration-300 ease-[var(--ease-silk)] focus-visible:outline-2 focus-visible:outline-offset-3";

const variants: Record<string, string> = {
  primary:
    "bg-gradient-to-r from-kwiin-gold-dim via-kwiin-gold to-kwiin-gold-bright text-kwiin-black shadow-[0_0_0_1px_rgba(201,168,106,0.4)] hover:shadow-[0_0_24px_rgba(201,168,106,0.45)] hover:-translate-y-0.5",
  secondary:
    "border border-kwiin-gold/50 text-kwiin-ivory hover:border-kwiin-gold hover:bg-kwiin-gold/10",
  ghost: "text-kwiin-ivory/80 hover:text-kwiin-gold-bright underline-offset-4 hover:underline",
};

const sizes: Record<string, string> = {
  md: "px-6 py-3 text-sm",
  lg: "px-8 py-4 text-base",
};
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class={`${base} ${variants[variant]} ${sizes[size]} ${className}`}
  aria-label={ariaLabel ?? label}
  data-i18n-aria-label={labelKey}
  data-i18n-whatsapp={messageKey}
>
  <svg
    aria-hidden="true"
    viewBox="0 0 24 24"
    width="18"
    height="18"
    fill="currentColor"
    class="shrink-0"
  >
    <path
      d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.87.52 3.62 1.4 5.12L2 22l5.13-1.5a9.86 9.86 0 0 0 4.91 1.3h.01c5.46 0 9.91-4.45 9.91-9.91C21.96 6.45 17.5 2 12.04 2Zm5.8 14.06c-.24.68-1.42 1.3-1.96 1.38-.5.08-1.13.11-1.83-.12-.42-.13-.96-.31-1.65-.61-2.9-1.25-4.79-4.16-4.94-4.36-.14-.2-1.18-1.57-1.18-2.99 0-1.42.74-2.12 1-2.41.26-.29.57-.36.76-.36.19 0 .38 0 .55.01.18.01.41-.07.64.49.24.58.81 2 .88 2.15.07.15.12.33.02.53-.1.2-.15.32-.3.49-.15.17-.31.38-.45.51-.15.14-.3.29-.13.58.18.3.81 1.33 1.74 2.16 1.2 1.07 2.21 1.4 2.51 1.56.3.15.48.13.65-.05.18-.18.75-.87.95-1.17.2-.3.4-.25.66-.15.27.1 1.7.8 1.99.95.29.14.49.21.56.33.07.13.07.74-.17 1.42Z"
    ></path>
  </svg>
  <span data-i18n={labelKey}>{label}</span>
</a>
