---
import { languages } from "../i18n/translations";
---

<div class="kwiin-language" data-language-selector data-language="de">
  <h1 class="kwiin-language__title" lang="de">
    <span data-i18n="hero.titleLead">Zurück zu </span><span
      class="kwiin-language__accent text-gold-gradient"
      data-i18n="hero.titleAccent">sich</span><span data-i18n="hero.titleEnd">.</span>
  </h1>

  <div class="kwiin-language__bridge">
    <span class="kwiin-language__prompt-wrap" aria-hidden="true">
      <i></i>
      <span class="kwiin-language__prompt" data-language-prompt lang="de">
        Wählen Sie Ihre Sprache
      </span>
    </span>

    <details class="kwiin-language__menu" data-language-menu>
      <summary data-i18n-aria-label="language.selectAria" aria-label="Sprache auswählen">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="8.4"></circle>
          <path d="M3.8 12h16.4M12 3.6c2.2 2.3 3.3 5.1 3.3 8.4S14.2 18.1 12 20.4M12 3.6C9.8 5.9 8.7 8.7 8.7 12s1.1 6.1 3.3 8.4"></path>
        </svg>
        <span data-selected-language>Deutsch</span>
        <small data-selected-code>DE</small>
        <i aria-hidden="true"></i>
      </summary>

      <div
        class="kwiin-language__panel"
        role="menu"
        data-i18n-aria-label="language.available"
        aria-label="Verfügbare Sprachen"
      >
        <span class="kwiin-language__eyebrow" data-i18n="language.yourLanguage">Ihre Sprache</span>
        <div class="kwiin-language__grid">
          {
            languages.map((language) => (
              <button
                type="button"
                role="menuitemradio"
                aria-checked={language.code === "de" ? "true" : "false"}
                data-language-option={language.code}
                data-language-name={language.name}
                data-language-short={language.short}
                lang={language.code}
              >
                <small>{language.short}</small>
                <span>{language.name}</span>
                <i aria-hidden="true"></i>
              </button>
            ))
          }
        </div>
      </div>
    </details>
  </div>
</div>

<style>
  .kwiin-language { position: relative; z-index: 30; }

  .kwiin-language__title {
    max-width: 64rem;
    margin: 1.45rem auto 0;
    color: var(--color-kwiin-ivory);
    font-family: var(--font-display);
    font-size: clamp(3.05rem, 7vw, 5.35rem);
    font-weight: 500;
    letter-spacing: 0.005em;
    line-height: 0.98;
    text-wrap: balance;
  }

  .kwiin-language__accent { font-style: italic; }

  .kwiin-language[data-language="th"] .kwiin-language__title,
  .kwiin-language[data-language="th"] .kwiin-language__prompt {
    font-family: "Noto Serif Thai", serif;
  }

  .kwiin-language[data-language="th"] .kwiin-language__title {
    font-size: clamp(2.55rem, 6vw, 4.6rem);
    line-height: 1.2;
  }

  .kwiin-language[data-language="th"] .kwiin-language__accent { font-style: normal; }

  .kwiin-language__bridge {
    display: flex;
    width: min(100%, 29rem);
    min-height: 2.7rem;
    margin: 1.15rem auto 0;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
  }

  .kwiin-language__prompt-wrap {
    display: flex;
    min-width: 0;
    flex: 1;
    align-items: center;
    justify-content: flex-end;
    gap: 0.7rem;
  }

  .kwiin-language__prompt-wrap > i {
    width: clamp(1rem, 4vw, 2.4rem);
    height: 1px;
    flex: none;
    background: linear-gradient(90deg, transparent, rgba(236, 210, 155, 0.48));
  }

  .kwiin-language__prompt {
    color: rgba(232, 221, 201, 0.66);
    font-size: 0.57rem;
    font-weight: 400;
    letter-spacing: 0.14em;
    line-height: 1.35;
    text-align: right;
    text-transform: uppercase;
    transition: opacity 0.3s var(--ease-silk), filter 0.3s var(--ease-silk), transform 0.3s var(--ease-silk);
  }

  .kwiin-language__prompt.is-changing {
    opacity: 0;
    filter: blur(4px);
    transform: translateY(-0.25rem);
  }

  .kwiin-language__menu { position: relative; flex: none; }

  .kwiin-language__menu summary {
    display: flex;
    min-width: 8.9rem;
    height: 2.7rem;
    align-items: center;
    gap: 0.48rem;
    padding: 0 0.72rem;
    border: 1px solid rgba(236, 210, 155, 0.28);
    border-radius: 999px;
    background: radial-gradient(circle at 20% 0%, rgba(236, 210, 155, 0.1), transparent 52%), rgba(13, 10, 9, 0.82);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.05) inset, 0 12px 30px -18px rgba(0, 0, 0, 0.94);
    color: var(--color-kwiin-ivory-dim);
    cursor: pointer;
    list-style: none;
    backdrop-filter: blur(12px);
    transition: border-color 0.35s var(--ease-silk), box-shadow 0.35s var(--ease-silk);
  }

  .kwiin-language__menu summary::-webkit-details-marker { display: none; }
  .kwiin-language__menu summary:hover,
  .kwiin-language__menu summary:focus-visible,
  .kwiin-language__menu[open] summary {
    border-color: rgba(236, 210, 155, 0.58);
    box-shadow: 0 0 30px -17px rgba(201, 163, 92, 0.75);
  }

  .kwiin-language__menu summary > svg {
    width: 1rem;
    flex: none;
    color: var(--color-kwiin-gold-bright);
    stroke: currentColor;
    stroke-width: 1.1;
  }

  .kwiin-language__menu summary > span {
    overflow: hidden;
    max-width: 4.6rem;
    font-family: var(--font-display);
    font-size: 0.8rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .kwiin-language__menu summary > small {
    color: rgba(186, 177, 164, 0.62);
    font-size: 0.48rem;
    letter-spacing: 0.14em;
  }

  .kwiin-language__menu summary > i {
    width: 0.35rem;
    height: 0.35rem;
    margin-left: auto;
    border-bottom: 1px solid currentColor;
    border-right: 1px solid currentColor;
    transform: translateY(-0.08rem) rotate(45deg);
    transition: transform 0.35s var(--ease-silk);
  }

  .kwiin-language__menu[open] summary > i { transform: translateY(0.08rem) rotate(225deg); }

  .kwiin-language__panel {
    position: absolute;
    top: calc(100% + 0.7rem);
    right: 0;
    width: min(22rem, calc(100vw - 2.5rem));
    padding: 1rem;
    border: 1px solid rgba(236, 210, 155, 0.22);
    border-radius: 1.15rem;
    background: radial-gradient(circle at 100% 0%, rgba(124, 94, 163, 0.14), transparent 46%), rgba(12, 9, 9, 0.98);
    box-shadow: 0 30px 70px -24px rgba(0, 0, 0, 0.96);
    text-align: left;
    transform-origin: 82% 0;
    animation: kwiin-language-arrive 0.4s var(--ease-silk) both;
    backdrop-filter: blur(18px);
  }

  .kwiin-language__eyebrow {
    display: block;
    margin: 0 0 0.72rem 0.25rem;
    color: rgba(236, 210, 155, 0.62);
    font-size: 0.5rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .kwiin-language__grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.42rem; }

  .kwiin-language__grid button {
    display: grid;
    min-width: 0;
    grid-template-columns: 1.9rem 1fr 0.5rem;
    align-items: center;
    gap: 0.45rem;
    padding: 0.68rem 0.65rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 0.75rem;
    background: rgba(255, 255, 255, 0.02);
    color: rgba(232, 221, 201, 0.76);
    text-align: left;
    cursor: pointer;
    transition: color 0.3s, border-color 0.3s, background 0.3s, transform 0.3s;
  }

  .kwiin-language__grid button:hover,
  .kwiin-language__grid button:focus-visible {
    border-color: rgba(236, 210, 155, 0.26);
    color: var(--color-kwiin-ivory);
    transform: translateY(-1px);
  }

  .kwiin-language__grid button[aria-checked="true"] {
    border-color: rgba(236, 210, 155, 0.4);
    background: linear-gradient(110deg, rgba(201, 163, 92, 0.13), rgba(124, 94, 163, 0.09));
  }

  .kwiin-language__grid button > small { color: rgba(236, 210, 155, 0.62); font-size: 0.48rem; letter-spacing: 0.13em; }
  .kwiin-language__grid button > span { overflow: hidden; font-family: var(--font-display); font-size: 0.86rem; text-overflow: ellipsis; white-space: nowrap; }
  .kwiin-language__grid button > i { width: 0.38rem; height: 0.38rem; border: 1px solid rgba(236, 210, 155, 0.3); border-radius: 50%; }
  .kwiin-language__grid button[aria-checked="true"] > i { background: var(--color-kwiin-gold-bright); box-shadow: 0 0 10px rgba(236, 210, 155, 0.72); }

  @keyframes kwiin-language-arrive {
    from { opacity: 0; transform: translateY(-0.4rem) scale(0.97); }
    to { opacity: 1; transform: none; }
  }

  @media (max-width: 23rem) {
    .kwiin-language__title { font-size: 2.75rem; }
    .kwiin-language__bridge { gap: 0.5rem; }
    .kwiin-language__prompt-wrap > i { display: none; }
    .kwiin-language__prompt { font-size: 0.49rem; letter-spacing: 0.09em; }
    .kwiin-language__menu summary { min-width: 8.1rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .kwiin-language__prompt { transition: none; }
    .kwiin-language__panel { animation: none; }
  }
</style>

<script>
  import {
    LANGUAGE_CODES,
    languages,
    translations,
    type LanguageCode,
  } from "../i18n/translations";

  type SelectorWindow = Window & {
    __kwiinLanguage?: LanguageCode;
    __kwiinSetLanguage?: (language: LanguageCode, animate?: boolean) => void;
    __kwiinLanguageSelectorCleanup?: () => void;
  };

  function initLanguageSelector() {
    const root = document.querySelector<HTMLElement>("[data-language-selector]");
    if (!root) return;

    const appWindow = window as SelectorWindow;
    appWindow.__kwiinLanguageSelectorCleanup?.();
    const controller = new AbortController();
    const signal = controller.signal;
    const menu = root.querySelector<HTMLDetailsElement>("[data-language-menu]");
    const prompt = root.querySelector<HTMLElement>("[data-language-prompt]");
    const selectedName = root.querySelector<HTMLElement>("[data-selected-language]");
    const selectedCode = root.querySelector<HTMLElement>("[data-selected-code]");
    const options = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-language-option]"));
    if (!menu || !prompt || !selectedName || !selectedCode) return;

    const selectorRoot = root;
    const languageMenu = menu;
    const languagePrompt = prompt;
    const selectedLanguageName = selectedName;
    const selectedLanguageCode = selectedCode;

    const reduceMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;
    let active = appWindow.__kwiinLanguage ?? "de";
    let promptIndex = LANGUAGE_CODES.indexOf(active);
    let cycleTimer = 0;
    let fadeTimer = 0;
    let inView = true;

    function updateSelection(language: LanguageCode) {
      active = language;
      selectorRoot.dataset.language = language;
      selectorRoot.querySelector("h1")?.setAttribute("lang", language);
      const meta = languages.find((item) => item.code === language)!;
      selectedLanguageName.textContent = meta.name;
      selectedLanguageName.lang = language;
      selectedLanguageCode.textContent = meta.short;
      options.forEach((option) => option.setAttribute(
        "aria-checked",
        option.dataset.languageOption === language ? "true" : "false"
      ));
      languageMenu.open = false;
    }

    function stopCycle() {
      clearTimeout(cycleTimer);
      clearTimeout(fadeTimer);
    }

    function queueCycle() {
      stopCycle();
      if (reduceMotion || document.hidden || !inView || languageMenu.open) return;
      cycleTimer = window.setTimeout(() => {
        languagePrompt.classList.add("is-changing");
        fadeTimer = window.setTimeout(() => {
          promptIndex = (promptIndex + 1) % LANGUAGE_CODES.length;
          const next = LANGUAGE_CODES[promptIndex];
          languagePrompt.textContent = translations[next]["language.prompt"];
          languagePrompt.lang = next;
          languagePrompt.classList.remove("is-changing");
          queueCycle();
        }, 300);
      }, 2300);
    }

    options.forEach((option) => option.addEventListener("click", () => {
      const language = option.dataset.languageOption as LanguageCode;
      if (!LANGUAGE_CODES.includes(language)) return;
      const changed = language !== active;
      updateSelection(language);
      appWindow.__kwiinSetLanguage?.(language, changed);
      promptIndex = LANGUAGE_CODES.indexOf(language);
      languagePrompt.textContent = translations[language]["language.prompt"];
      languagePrompt.lang = language;
      queueCycle();
    }, { signal }));

    window.addEventListener("kwiin:language-change", (event) => {
      const language = (event as CustomEvent<{ language: LanguageCode }>).detail.language;
      updateSelection(language);
      promptIndex = LANGUAGE_CODES.indexOf(language);
      languagePrompt.textContent = translations[language]["language.prompt"];
      languagePrompt.lang = language;
      queueCycle();
    }, { signal });

    languageMenu.addEventListener("toggle", queueCycle, { signal });
    document.addEventListener("pointerdown", (event) => {
      if (languageMenu.open && !languageMenu.contains(event.target as Node)) languageMenu.open = false;
    }, { signal });
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") languageMenu.open = false;
    }, { signal });
    document.addEventListener("visibilitychange", queueCycle, { signal });

    const observer = new IntersectionObserver(([entry]) => {
      inView = Boolean(entry?.isIntersecting);
      queueCycle();
    }, { threshold: 0.05 });
    observer.observe(selectorRoot);

    updateSelection(active);
    languagePrompt.textContent = translations[active]["language.prompt"];
    languagePrompt.lang = active;
    queueCycle();

    appWindow.__kwiinLanguageSelectorCleanup = () => {
      controller.abort();
      observer.disconnect();
      stopCycle();
    };
  }

  initLanguageSelector();
  document.addEventListener("astro:after-swap", initLanguageSelector);
</script>
