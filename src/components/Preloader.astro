---
/**
 * Cinematic first-load overlay. The KWIIN lotus draws itself in gold line
 * art, the wordmark rises with expanding letterspacing, the English
 * signature line fades in, and a thin gold hairline sweeps before the whole
 * curtain dissolves.
 *
 * Robustness:
 * - Shown once per browser session (sessionStorage), so internal navigation
 *   never re-triggers it.
 * - The fade-out is a pure CSS animation with `forwards` fill, so even with
 *   JavaScript disabled the overlay always clears itself.
 * - prefers-reduced-motion collapses every animation to ~instant via the
 *   global reduced-motion rule, so it never lingers for those users.
 */
---

<div id="kwiin-preloader" class="kwiin-preloader" role="presentation" aria-hidden="true">
  <div class="kwiin-preloader-inner">
    <svg
      viewBox="0 0 64 44"
      fill="none"
      stroke="currentColor"
      stroke-width="1.4"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="kwiin-pl-lotus"
    >
      <path d="M32 4 C26.5 13 26.5 24 32 34 C37.5 24 37.5 13 32 4 Z"></path>
      <path d="M32 34 C26 30.5 21 23 19.5 12.5 C27.5 17 31.5 25 32 34 Z"></path>
      <path d="M32 34 C38 30.5 43 23 44.5 12.5 C36.5 17 32.5 25 32 34 Z"></path>
      <path d="M32 34 C23 33 13 28 8.5 19.5 C18 20.5 28 26.5 32 34 Z"></path>
      <path d="M32 34 C41 33 51 28 55.5 19.5 C46 20.5 36 26.5 32 34 Z"></path>
      <path d="M20 38.5 C25 42 39 42 44 38.5"></path>
    </svg>
    <span class="kwiin-pl-word text-gold-gradient">KWIIN</span>
    <span class="kwiin-pl-by">Where Luxury meets Healing.</span>
    <span class="kwiin-pl-line" aria-hidden="true"></span>
  </div>
</div>

<style>
  .kwiin-preloader {
    position: fixed;
    inset: 0;
    z-index: 100000;
    display: grid;
    place-items: center;
    background: radial-gradient(circle at 50% 42%, #16110d, #0b0908 70%);
    animation: kwiin-pl-out 0.9s var(--ease-silk) 2.3s forwards;
  }

  .kwiin-preloader-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.65rem;
  }

  .kwiin-pl-lotus {
    height: 3.4rem;
    width: auto;
    color: var(--color-kwiin-gold);
    filter: drop-shadow(0 0 14px rgba(201, 163, 92, 0.45));
  }
  .kwiin-pl-lotus path {
    stroke-dasharray: 130;
    stroke-dashoffset: 130;
    animation: kwiin-pl-draw 1.4s var(--ease-silk) forwards;
  }
  .kwiin-pl-lotus path:nth-child(1) { animation-delay: 0.1s; }
  .kwiin-pl-lotus path:nth-child(2) { animation-delay: 0.26s; }
  .kwiin-pl-lotus path:nth-child(3) { animation-delay: 0.26s; }
  .kwiin-pl-lotus path:nth-child(4) { animation-delay: 0.44s; }
  .kwiin-pl-lotus path:nth-child(5) { animation-delay: 0.44s; }
  .kwiin-pl-lotus path:nth-child(6) { animation-delay: 0.62s; }

  .kwiin-pl-word {
    font-family: var(--font-display);
    font-size: 2.6rem;
    letter-spacing: 0.5em;
    padding-left: 0.5em;
    opacity: 0;
    transform: translateY(10px);
    animation: kwiin-pl-rise 0.9s var(--ease-silk) 0.5s forwards;
  }

  .kwiin-pl-by {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-kwiin-gold-bright);
    opacity: 0;
    animation: kwiin-pl-fade 0.9s var(--ease-silk) 0.85s forwards;
  }

  .kwiin-pl-line {
    margin-top: 0.4rem;
    height: 1px;
    width: 0;
    background: linear-gradient(90deg, transparent, var(--color-kwiin-gold-bright), transparent);
    animation: kwiin-pl-line 1.1s var(--ease-silk) 0.7s forwards;
  }

  @keyframes kwiin-pl-draw { to { stroke-dashoffset: 0; } }
  @keyframes kwiin-pl-rise { to { opacity: 1; transform: translateY(0); } }
  @keyframes kwiin-pl-fade { to { opacity: 0.9; } }
  @keyframes kwiin-pl-line { to { width: 220px; } }
  @keyframes kwiin-pl-out { to { opacity: 0; visibility: hidden; } }
</style>

<script>
  function kwiinPreloader() {
    const pre = document.getElementById("kwiin-preloader");
    if (!pre) return;

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let done = false;
    const remove = () => {
      if (done) return;
      done = true;
      pre.remove();
      try { sessionStorage.setItem("kwiin-pre", "1"); } catch (e) {}
    };

    try {
      if (sessionStorage.getItem("kwiin-pre") === "1") {
        pre.remove();
        return;
      }
    } catch (e) {}

    if (reduce) {
      remove();
      return;
    }

    window.setTimeout(remove, 3300);
  }

  kwiinPreloader();
</script>
