---
export interface Props {
  language: string;
  translationKey?: string;
}
const { language, translationKey } = Astro.props;
---

<span
  class="inline-flex items-center rounded-full border border-kwiin-soft-grey/30 px-3 py-1 text-xs uppercase tracking-[0.12em] text-kwiin-soft-grey"
  data-i18n={translationKey}
>
  {language}
</span>
