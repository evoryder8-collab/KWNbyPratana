---
import { navItems, navCtaLabel } from "../data/navigation";
import { WHATSAPP_MESSAGES } from "../utils/whatsapp";
import { withBase } from "../utils/base";
import WhatsAppButton from "./WhatsAppButton.astro";
import MobileMenu from "./MobileMenu.astro";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-white/5 bg-kwiin-black/70 backdrop-blur-md">
  <nav class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-4 lg:px-8" aria-label="Main navigation">
    <a href={withBase("/")} class="flex items-center gap-2 font-display text-lg tracking-wide text-kwiin-ivory">
      <img src={withBase("/assets/kwiin-logo.png")} alt="KWIIN by Pratana Halstrick" class="h-9 w-auto" />
      <span class="hidden sm:inline">KWIIN <span class="text-kwiin-gold-bright">by Pratana</span></span>
    </a>

    <ul class="hidden items-center gap-8 lg:flex">
      {
        navItems.map((item) => {
          const active = currentPath === withBase(item.href).replace(/\/$/, "");
          return (
            <li>
              <a
                href={withBase(item.href)}
                aria-current={active ? "page" : undefined}
                class={`text-sm uppercase tracking-[0.1em] transition-colors hover:text-kwiin-gold-bright ${
                  active ? "text-kwiin-gold-bright" : "text-kwiin-ivory/80"
                }`}
              >
                {item.label}
              </a>
            </li>
          );
        })
      }
    </ul>

    <div class="hidden lg:block">
      <WhatsAppButton message={WHATSAPP_MESSAGES.studioGeneric} label={navCtaLabel} size="md" />
    </div>

    <button
      id="kwiin-menu-toggle"
      type="button"
      class="flex h-10 w-10 items-center justify-center rounded-full border border-white/10 text-kwiin-ivory lg:hidden"
      aria-expanded="false"
      aria-controls="kwiin-mobile-menu"
      aria-label="Open menu"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-5 w-5">
        <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"></path>
      </svg>
    </button>
  </nav>

  <MobileMenu />
</header>
