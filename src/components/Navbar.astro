---
import { navItems, navCtaLabel } from "../data/navigation";
import { WHATSAPP_MESSAGES } from "../utils/whatsapp";
import { withBase } from "../utils/base";
import WhatsAppButton from "./WhatsAppButton.astro";
import MobileMenu from "./MobileMenu.astro";
import LotusMark from "./LotusMark.astro";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const navKeys = {
  "/studio": "nav.signature",
  "/mobile-spa": "nav.mobile",
  "/services": "nav.services",
  "/about": "nav.about",
  "/contact": "nav.contact",
} as const;
---

{/*
  The fullscreen mobile menu is intentionally rendered as a SIBLING of the
  header, not inside it: the header's backdrop-filter makes it the containing
  block for fixed-position descendants, which would clamp the menu to the
  navbar strip and let page content bleed through underneath it.
*/}
<header
  id="kwiin-nav"
  data-scrolled="false"
  class="fixed inset-x-0 top-0 z-50 border-b border-white/5 bg-kwiin-black/60 backdrop-blur-md transition-[background-color,backdrop-filter,border-color] duration-500"
>
  <div
    id="kwiin-scroll-progress"
    class="kwiin-scroll-progress pointer-events-none absolute inset-x-0 top-0 h-px"
    aria-hidden="true"
  >
  </div>

  <nav
    class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-4 transition-[padding] duration-500 lg:px-8"
    aria-label="Hauptnavigation"
    data-i18n-aria-label="nav.aria"
  >
    <a
      href={withBase("/")}
      class="group flex items-center gap-3 font-display text-lg tracking-wide text-kwiin-ivory"
    >
      <LotusMark class="h-7 w-auto text-kwiin-gold transition-transform duration-700 group-hover:scale-110" />
      <span class="flex items-baseline gap-1.5">
        <span class="tracking-[0.18em]">KWIIN</span>
        <span class="hidden font-display text-sm italic text-kwiin-gold-bright sm:inline">by Pratana</span>
      </span>
    </a>

    <ul class="hidden items-center gap-9 lg:flex">
      {
        navItems.map((item) => {
          const active = currentPath === withBase(item.href).replace(/\/$/, "");
          return (
            <li>
              <a
                href={withBase(item.href)}
                aria-current={active ? "page" : undefined}
                class={`kwiin-navlink text-[0.78rem] uppercase tracking-[0.16em] transition-colors hover:text-kwiin-gold-bright ${
                  active ? "text-kwiin-gold-bright" : "text-kwiin-ivory/80"
                }`}
              >
                <span data-i18n={navKeys[item.href as keyof typeof navKeys]}>{item.label}</span>
              </a>
            </li>
          );
        })
      }
    </ul>

    <div class="hidden lg:block">
      <WhatsAppButton
        message={WHATSAPP_MESSAGES.studioGeneric}
        label={navCtaLabel}
        labelKey="nav.book"
        messageKey="common.studioWhatsApp"
        size="md"
      />
    </div>

    <button
      id="kwiin-menu-toggle"
      type="button"
      class="flex h-10 w-10 items-center justify-center rounded-full border border-white/10 text-kwiin-ivory transition-colors hover:border-kwiin-gold/40 lg:hidden"
      aria-expanded="false"
      aria-controls="kwiin-mobile-menu"
      aria-label="Menü öffnen"
      data-i18n-aria-label="nav.menuOpen"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-5 w-5">
        <path d="M4 8h16M8 12h12M4 16h16" stroke-linecap="round"></path>
      </svg>
    </button>
  </nav>
</header>

<MobileMenu />

<style>
  #kwiin-nav[data-scrolled="true"] {
    background-color: rgba(8, 20, 29, 0.88);
    border-color: rgba(201, 163, 92, 0.16);
    box-shadow: 0 10px 40px -24px rgba(0, 0, 0, 0.9);
  }
  #kwiin-nav[data-scrolled="true"] nav {
    padding-top: 0.7rem;
    padding-bottom: 0.7rem;
  }
</style>

<script>
  // Scroll-aware navbar: condenses on scroll and drives the progress hairline.
  function initNavScroll() {
    const nav = document.getElementById("kwiin-nav");
    const bar = document.getElementById("kwiin-scroll-progress");
    if (!nav) return;
    if (nav.dataset.scrollBound === "true") return;
    nav.dataset.scrollBound = "true";

    let ticking = false;

    function update() {
      const y = window.scrollY || document.documentElement.scrollTop;
      nav!.setAttribute("data-scrolled", y > 8 ? "true" : "false");

      if (bar) {
        const doc = document.documentElement;
        const max = doc.scrollHeight - doc.clientHeight;
        const pct = max > 0 ? y / max : 0;
        bar.style.transform = `scaleX(${pct.toFixed(4)})`;
      }
      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    }

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
    update();
  }

  initNavScroll();
  document.addEventListener("astro:after-swap", () => {
    const nav = document.getElementById("kwiin-nav");
    if (nav) nav.dataset.scrollBound = "";
    initNavScroll();
  });
</script>
