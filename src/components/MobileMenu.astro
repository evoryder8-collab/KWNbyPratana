---
import { navItems, navCtaLabel } from "../data/navigation";
import { WHATSAPP_MESSAGES, whatsappUrl } from "../utils/whatsapp";

const whatsappHref = whatsappUrl(WHATSAPP_MESSAGES.studioGeneric);
---

<div
  id="kwiin-mobile-menu"
  class="fixed inset-0 z-40 hidden flex-col bg-kwiin-black/98 px-6 pt-24 pb-10 backdrop-blur-xl lg:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Mobile navigation"
>
  <button
    id="kwiin-menu-close"
    type="button"
    class="absolute right-5 top-5 flex h-10 w-10 items-center justify-center rounded-full border border-white/10 text-kwiin-ivory"
    aria-label="Close menu"
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-5 w-5">
      <path d="M6 6l12 12M18 6 6 18" stroke-linecap="round"></path>
    </svg>
  </button>

  <ul class="flex flex-1 flex-col items-center justify-center gap-6">
    {
      navItems.map((item) => (
        <li class="kwiin-menu-item opacity-0">
          <a
            href={item.href}
            class="font-display text-3xl text-kwiin-ivory transition-colors hover:text-kwiin-gold-bright"
          >
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>

  <a
    href={whatsappHref}
    target="_blank"
    rel="noopener noreferrer"
    class="kwiin-menu-item mx-auto inline-flex items-center justify-center gap-2 rounded-full bg-gradient-to-r from-kwiin-gold to-kwiin-gold-bright px-7 py-3 text-sm font-semibold uppercase tracking-[0.08em] text-kwiin-black opacity-0"
  >
    {navCtaLabel}
  </a>
</div>

<script>
  import { animate } from "motion";

  function setup() {
    const toggle = document.getElementById("kwiin-menu-toggle");
    const closeBtn = document.getElementById("kwiin-menu-close");
    const menu = document.getElementById("kwiin-mobile-menu");
    if (!toggle || !menu || !closeBtn) return;

    const items = menu.querySelectorAll(".kwiin-menu-item");
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function openMenu() {
      menu!.classList.remove("hidden");
      menu!.classList.add("flex");
      toggle!.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";

      if (reduceMotion) {
        items.forEach((el) => ((el as HTMLElement).style.opacity = "1"));
        return;
      }

      animate(menu!, { opacity: [0, 1] }, { duration: 0.35 });
      animate(
        items,
        { opacity: [0, 1], y: [16, 0] },
        { duration: 0.45, delay: (i: number) => 0.08 + i * 0.06 }
      );
    }

    function closeMenu() {
      const finish = () => {
        menu!.classList.add("hidden");
        menu!.classList.remove("flex");
        toggle!.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
      };
      if (reduceMotion) {
        finish();
        return;
      }
      animate(menu!, { opacity: [1, 0] }, { duration: 0.25 }).finished.then(finish);
    }

    toggle!.addEventListener("click", () => {
      const expanded = toggle!.getAttribute("aria-expanded") === "true";
      if (expanded) closeMenu();
      else openMenu();
    });
    closeBtn!.addEventListener("click", closeMenu);
    menu!.querySelectorAll("a").forEach((a) => a.addEventListener("click", closeMenu));
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && toggle!.getAttribute("aria-expanded") === "true") closeMenu();
    });
  }

  setup();
  document.addEventListener("astro:after-swap", setup);
</script>
