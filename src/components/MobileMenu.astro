---
import { navItems, navCtaLabel } from "../data/navigation";
import { WHATSAPP_MESSAGES, whatsappUrl } from "../utils/whatsapp";
import { withBase } from "../utils/base";
import { brandLine, contact } from "../data/contact";

const whatsappHref = whatsappUrl(WHATSAPP_MESSAGES.studioGeneric);
---

<div
  id="kwiin-mobile-menu"
  class="fixed inset-0 z-40 hidden flex-col bg-kwiin-black px-7 pt-24 pb-10 backdrop-blur-xl lg:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Mobile navigation"
>
  <button
    id="kwiin-menu-close"
    type="button"
    class="absolute right-5 top-5 flex h-10 w-10 items-center justify-center rounded-full border border-white/10 text-kwiin-ivory transition-colors hover:border-kwiin-gold/40"
    aria-label="Close menu"
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-5 w-5">
      <path d="M6 6l12 12M18 6 6 18" stroke-linecap="round"></path>
    </svg>
  </button>

  <p class="kwiin-menu-item mb-8 text-[0.65rem] uppercase tracking-[0.32em] text-kwiin-gold-bright/70 opacity-0">
    KWIIN <span aria-hidden="true">🪷</span> by Pratana Halstrick
  </p>

  <ul class="flex flex-1 flex-col justify-center gap-5">
    {
      navItems.map((item, i) => (
        <li class="kwiin-menu-item opacity-0">
          <a
            href={withBase(item.href)}
            class="group flex items-baseline gap-4 text-kwiin-ivory transition-colors hover:text-kwiin-gold-bright"
          >
            <span class="font-body text-xs tracking-[0.2em] text-kwiin-gold/50 tabular-nums">
              {String(i + 1).padStart(2, "0")}
            </span>
            <span class="font-display text-4xl leading-none">{item.label}</span>
          </a>
        </li>
      ))
    }
  </ul>

  <div class="kwiin-menu-item mt-8 opacity-0">
    <p class="font-display text-xl italic text-kwiin-gold-bright text-balance">
      &ldquo;{brandLine}&rdquo;
    </p>
    <a
      href={contact.instagramUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-3 inline-block text-xs uppercase tracking-[0.18em] text-kwiin-soft-grey transition-colors hover:text-kwiin-gold-bright"
    >
      {contact.instagramHandle}
    </a>
  </div>

  <a
    href={whatsappHref}
    target="_blank"
    rel="noopener noreferrer"
    class="kwiin-menu-item mt-7 inline-flex items-center justify-center gap-2 rounded-full bg-gradient-to-r from-kwiin-gold to-kwiin-gold-bright px-7 py-3.5 text-sm font-semibold uppercase tracking-[0.08em] text-kwiin-black opacity-0"
  >
    {navCtaLabel}
  </a>
</div>

<style>
  /* Guaranteed-opaque background so page content never shows through the
     open menu, regardless of which opacity utilities Tailwind emits. */
  #kwiin-mobile-menu {
    background-color: var(--color-kwiin-black, #0a0908);
  }
</style>

<script>
  import { animate } from "motion";

  function setup() {
    const toggle = document.getElementById("kwiin-menu-toggle");
    const closeBtn = document.getElementById("kwiin-menu-close");
    const menu = document.getElementById("kwiin-mobile-menu");
    if (!toggle || !menu || !closeBtn) return;

    const items = menu.querySelectorAll(".kwiin-menu-item");
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function openMenu() {
      menu!.classList.remove("hidden");
      menu!.classList.add("flex");
      toggle!.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";

      if (reduceMotion) {
        items.forEach((el) => ((el as HTMLElement).style.opacity = "1"));
        return;
      }

      animate(menu!, { opacity: [0, 1] }, { duration: 0.35 });
      animate(
        items,
        { opacity: [0, 1], y: [18, 0] },
        { duration: 0.5, delay: (i: number) => 0.08 + i * 0.07 }
      );
    }

    function closeMenu() {
      const finish = () => {
        menu!.classList.add("hidden");
        menu!.classList.remove("flex");
        toggle!.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
      };
      if (reduceMotion) {
        finish();
        return;
      }
      animate(menu!, { opacity: [1, 0] }, { duration: 0.25 }).finished.then(finish);
    }

    toggle!.addEventListener("click", () => {
      const expanded = toggle!.getAttribute("aria-expanded") === "true";
      if (expanded) closeMenu();
      else openMenu();
    });
    closeBtn!.addEventListener("click", closeMenu);
    menu!.querySelectorAll("a").forEach((a) => a.addEventListener("click", closeMenu));
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && toggle!.getAttribute("aria-expanded") === "true") closeMenu();
    });
  }

  setup();
  document.addEventListener("astro:after-swap", setup);
</script>
