---
import { ClientRouter } from "astro:transitions";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Preloader from "../components/Preloader.astro";
import AmbientBackdrop from "../components/AmbientBackdrop.astro";
import CursorGlow from "../components/CursorGlow.astro";
import { withBase } from "../utils/base";
import "../styles/global.css";

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const {
  title,
  description,
  ogImage = withBase("/assets/kwiin-logo.png"),
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href={withBase("/assets/kwiin-logo.png")} />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="de_CH" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <meta name="theme-color" content="#0b0908" />

    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Inter:wght@300;400;500;600&family=Noto+Serif+Thai:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />
  </head>
  <body class="bg-kwiin-black text-kwiin-ivory min-h-screen flex flex-col">
    <Preloader />
    <AmbientBackdrop />
    <CursorGlow />

    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:bg-kwiin-gold focus:text-kwiin-black focus:px-4 focus:py-2 focus:rounded"
    >
      Zum Inhalt springen
    </a>

    <Navbar />

    <main id="main-content" class="relative z-10 flex-1">
      <slot />
    </main>

    <Footer />

    <script>
      // Lenis smooth scroll is a desktop enhancement. iOS and other
      // coarse-pointer devices keep native momentum scrolling so there is no
      // permanent requestAnimationFrame loop competing with touch input.
      import Lenis from "lenis";
      import { initKwiinAnimations, resetKwiinAnimations, refreshScrollTriggers } from "../utils/animations";

      function initLenis() {
        const w = window as any;

        // tear down the previous instance so view transitions never stack
        // multiple smooth-scroll loops
        if (w.__kwiinLenisRaf) cancelAnimationFrame(w.__kwiinLenisRaf);
        if (w.__kwiinLenis?.destroy) w.__kwiinLenis.destroy();
        w.__kwiinLenisRaf = 0;
        w.__kwiinLenis = undefined;

        const prefersReducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)"
        ).matches;
        const prefersNativeTouchScroll = window.matchMedia(
          "(hover: none), (pointer: coarse)"
        ).matches;

        if (prefersReducedMotion || prefersNativeTouchScroll) return;

        const lenis = new Lenis({
          duration: 1.1,
          smoothWheel: true,
          easing: (t: number) => 1 - Math.pow(1 - t, 3),
        });

        function raf(time: number) {
          lenis.raf(time);
          w.__kwiinLenisRaf = requestAnimationFrame(raf);
        }
        w.__kwiinLenisRaf = requestAnimationFrame(raf);

        // expose so GSAP ScrollTrigger can sync with it on each page
        w.__kwiinLenis = lenis;
        window.dispatchEvent(new CustomEvent("kwiin:lenis-ready"));
      }

      initLenis();
      initKwiinAnimations();
      window.addEventListener("kwiin:lenis-ready", refreshScrollTriggers);

      document.addEventListener("astro:after-swap", () => {
        resetKwiinAnimations();
        initLenis();
        initKwiinAnimations();
      });
    </script>
  </body>
</html>
