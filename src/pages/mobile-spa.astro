---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageTransition from "../components/PageTransition.astro";
import SectionReveal from "../components/SectionReveal.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import MobileSpaFeature from "../components/MobileSpaFeature.astro";
import ServiceCard from "../components/ServiceCard.astro";
import OrnamentDivider from "../components/OrnamentDivider.astro";
import { services, MOBILE_SPA_TRAVEL_FEE_NOTE } from "../data/services";
import { WHATSAPP_MESSAGES } from "../utils/whatsapp";

const title = "KWIIN Mobile Spa | Luxus Thai-Massage bei Ihnen, Region Zürich";
const description =
  "KWIIN Mobile Spa bringt Pratana Halstricks preisgekrönte Thai-Massage zu Ihnen: nach Hause, ins Büro oder ins Hotel, in der ganzen Region Zürich. Anfragen via WhatsApp.";

const mobileServices = services.filter((s) => s.mobileAvailable);
---

<BaseLayout title={title} description={description}>
  <PageTransition variant="glide">
    <section class="relative overflow-hidden pb-20 pt-40">
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(124,94,163,0.16),transparent_55%)]"
        aria-hidden="true"
      >
      </div>
      <div class="relative mx-auto max-w-4xl px-5 text-center lg:px-8">
        <p class="kwiin-eyebrow">KWIIN Mobile Spa</p>
        <h1 class="mt-6 font-display text-4xl leading-tight text-kwiin-ivory text-balance sm:text-5xl lg:text-6xl">
          Ihr Zuhause wird zum
          <span class="kwiin-accent text-gold-gradient">Spa.</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-kwiin-soft-grey">
          Pratana bringt die KWIIN Erfahrung direkt zu Ihnen: nach Hause, ins Büro oder ins
          Hotel. Mit hochwertigen Ölen, edlen Materialien und einer Atmosphäre, die
          Entschleunigung spürbar macht.
        </p>
        <div class="mt-9 flex justify-center">
          <WhatsAppButton
            message={WHATSAPP_MESSAGES.mobileGeneric}
            label="Mobile Spa via WhatsApp anfragen"
            size="lg"
          />
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-5 pb-20 lg:px-8">
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        <MobileSpaFeature
          icon="home"
          title="Zuhause"
          description="Eine ruhige, komfortable Massage in Ihren eigenen vier Wänden. Ideal für einen stillen Abend oder ein Wochenende der Erholung."
        />
        <MobileSpaFeature
          icon="office"
          title="Büro & Executive Recovery"
          description="Sessions vor Ort, die Verspannungen aus langen Arbeitstagen lösen. Für Teams und Führungskräfte, die neue Energie brauchen."
        />
        <MobileSpaFeature
          icon="hotel"
          title="Hotel & private Suiten"
          description="Auf Reisen in Zürich? Pratana bringt die KWIIN Erfahrung in Ihr Hotelzimmer oder Ihre private Suite."
        />
        <MobileSpaFeature
          icon="prepare"
          title="Was Sie vorbereiten"
          description="Nichts. Pratana bringt Massageliege, Öle und frische Tücher mit. Ein ruhiger Raum und eine angenehme Temperatur genügen."
        />
        <MobileSpaFeature
          icon="travel"
          title="Reichweite"
          description="Mobile Spa ist in der ganzen Region Zürich verfügbar. Weitere Distanzen gerne auf Anfrage via WhatsApp."
        />
      </div>

      <p class="mt-8 text-center text-xs uppercase tracking-[0.12em] text-kwiin-soft-grey/60">
        {MOBILE_SPA_TRAVEL_FEE_NOTE}
      </p>
    </section>

    <section class="mx-auto max-w-7xl px-5 pb-20 lg:px-8">
      <SectionReveal class="mb-12 text-center">
        <p class="kwiin-eyebrow">Mobile Behandlungen</p>
        <h2 class="mt-5 font-display text-4xl text-kwiin-ivory text-balance sm:text-5xl">
          Derselbe KWIIN Standard, <span class="kwiin-accent">wo immer Sie sind</span>
        </h2>
      </SectionReveal>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {mobileServices.map((service) => <ServiceCard service={service} context="mobile" />)}
      </div>
    </section>

    <SectionReveal class="mx-auto max-w-3xl px-5 pb-24 text-center lg:px-8">
      <OrnamentDivider class="mb-10" />
      <p class="mb-8 font-display text-2xl italic text-kwiin-gold-bright text-balance">
        Dieselbe Qualität, dieselbe Ruhe, dieselbe Aufmerksamkeit. In jedem Raum.
      </p>
      <WhatsAppButton
        message={WHATSAPP_MESSAGES.mobileGeneric}
        label="Mobile Spa via WhatsApp anfragen"
        size="lg"
      />
    </SectionReveal>
  </PageTransition>
</BaseLayout>
