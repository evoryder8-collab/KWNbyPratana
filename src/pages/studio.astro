---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageTransition from "../components/PageTransition.astro";
import SectionReveal from "../components/SectionReveal.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import ServiceCard from "../components/ServiceCard.astro";
import LocationNote from "../components/LocationNote.astro";
import PartnerStrip from "../components/PartnerStrip.astro";
import GoldDust from "../components/GoldDust.astro";
import OrnamentDivider from "../components/OrnamentDivider.astro";
import { services, featuredService } from "../data/services";
import { WHATSAPP_MESSAGES } from "../utils/whatsapp";
import { brandLine } from "../data/contact";

const title = "KWIIN Signature Experience | Thai-Massage Studio in Dübendorf";
const description =
  "Preisgekrönte Thai-Massage mit luxuriöser Heilkunst in einem ruhigen Studio in Dübendorf. Buchen Sie Ihre KWIIN Signature Experience via WhatsApp.";

const studioServices = services.filter((s) => s.studioAvailable);

const ritual = [
  {
    step: "01",
    title: "Ankommen", titleKey: "studio.ritualOneTitle",
    copy: "Wir starten mit einem kurzen Gespräch. Sie sagen, was Ihr Körper heute braucht.", copyKey: "studio.ritualOneCopy",
  },
  {
    step: "02",
    title: "Behandlung", titleKey: "studio.ritualTwoTitle",
    copy: "Druck, Dehnung und ruhige Bewegungen werden passend für Sie kombiniert.", copyKey: "studio.ritualTwoCopy",
  },
  {
    step: "03",
    title: "Nachruhen", titleKey: "studio.ritualThreeTitle",
    copy: "Nach der Massage haben Sie kurz Zeit, in Ruhe wieder anzukommen.", copyKey: "studio.ritualThreeCopy",
  },
];
---

<BaseLayout title={title} description={description} page="studio">
  <PageTransition>
    <section class="relative overflow-hidden pb-24 pt-40">
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(201,163,92,0.14),transparent_55%)]"
        aria-hidden="true"
      >
      </div>
      <GoldDust />
      <div class="relative mx-auto max-w-4xl px-5 text-center lg:px-8">
        <p class="kwiin-eyebrow">KWIIN Signature Experience</p>
        <h1 class="mt-6 font-display text-4xl leading-tight text-kwiin-ivory text-balance sm:text-5xl lg:text-6xl">
          <span data-i18n="studio.heroTitleLead">Massage, die </span><span class="kwiin-accent text-gold-gradient" data-i18n="studio.heroTitleAccent">wirklich zu Ihnen passt.</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-kwiin-soft-grey" data-i18n="studio.heroCopy">
          Pratana verbindet traditionelle Thai Massage mit gezielter Körperarbeit. Jede Behandlung wird auf Sie und Ihren Tag abgestimmt.
        </p>
        <div class="mt-9 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <WhatsAppButton message={WHATSAPP_MESSAGES.studioGeneric} label="Termin via WhatsApp" labelKey="common.whatsappAppointment" messageKey="common.studioWhatsApp" size="lg" />
          <a
            href="#treatments"
            class="text-sm uppercase tracking-[0.12em] text-kwiin-ivory/80 underline-offset-4 transition-colors hover:text-kwiin-gold-bright hover:underline"
          >
            <span data-i18n="studio.discoverTreatments">Behandlungen ansehen</span>
          </a>
        </div>
        <div class="mt-10 flex justify-center">
          <LocationNote variant="subtle" class="text-center" />
        </div>
      </div>
    </section>

    {/* ── Die Seele Thailands ──────────────────────────────────────── */}
    <section class="relative border-y border-kwiin-gold/10 py-24">
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(80%_70%_at_50%_100%,rgba(201,163,92,0.07),transparent_60%)]"
        aria-hidden="true"
      >
      </div>
      <div class="relative mx-auto grid max-w-6xl gap-12 px-5 lg:grid-cols-[3fr_2fr] lg:items-center lg:px-8">
        <SectionReveal>
          <p class="kwiin-eyebrow kwiin-eyebrow--bare" data-i18n="studio.thaiEyebrow">Die Wurzeln in Thailand</p>
          <h2 class="mt-5 font-display text-4xl leading-tight text-kwiin-ivory sm:text-5xl">
            Nuad <span class="kwiin-accent">Thai</span>
          </h2>
          <p class="mt-6 max-w-xl text-base leading-relaxed text-kwiin-soft-grey" data-i18n="studio.thaiCopyOne">
            Nuad Thai ist eine traditionelle Massageform mit mehr als 2'500 Jahren Geschichte. Sie verbindet Druckpunkte, Dehnung und ruhige Bewegung.
          </p>
          <p class="mt-4 max-w-xl text-base leading-relaxed text-kwiin-soft-grey" data-i18n="studio.thaiCopyTwo">
            Für Pratana ist diese Arbeit kein Trend. Sie ist Teil ihrer Kultur und wird mit Respekt weitergegeben.
          </p>
        </SectionReveal>

        <SectionReveal class="kwiin-panel relative overflow-hidden rounded-3xl p-10 text-center">
          <p class="font-display text-7xl leading-none text-kwiin-gold-bright">2019</p>
          <p class="mt-4 text-xs uppercase tracking-[0.24em] text-kwiin-gold-bright/80">
            UNESCO
          </p>
          <p class="mt-2 font-display text-xl leading-snug text-kwiin-ivory text-balance" data-i18n="studio.unesco">
            Anerkannt als Immaterielles Kulturerbe der Menschheit
          </p>
          <OrnamentDivider class="mt-6" />
        </SectionReveal>
      </div>
    </section>

    {/* ── Das Ritual ───────────────────────────────────────────────── */}
    <section class="mx-auto max-w-6xl px-5 py-24 lg:px-8">
      <SectionReveal class="mb-12 text-center">
        <p class="kwiin-eyebrow" data-i18n="studio.ritualEyebrow">So läuft Ihr Termin ab</p>
        <h2 class="mt-5 font-display text-4xl text-kwiin-ivory sm:text-5xl">
          <span data-i18n="studio.ritualTitleLead">Drei ruhige </span><span class="kwiin-accent" data-i18n="studio.ritualTitleAccent">Schritte</span>
        </h2>
      </SectionReveal>

      <SectionReveal stagger={true} class="grid gap-6 md:grid-cols-3">
        {
          ritual.map((act) => (
            <div data-reveal-child class="kwiin-panel relative flex flex-col rounded-3xl p-8">
              <span class="font-display text-5xl italic text-kwiin-gold/40">{act.step}</span>
              <h3 class="mt-4 font-display text-2xl text-kwiin-ivory" data-i18n={act.titleKey}>{act.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-kwiin-soft-grey" data-i18n={act.copyKey}>{act.copy}</p>
            </div>
          ))
        }
      </SectionReveal>
    </section>

    {/* ── Signature treatment ──────────────────────────────────────── */}
    <SectionReveal class="mx-auto max-w-6xl px-5 pb-8 lg:px-8">
      <div class="kwiin-panel relative overflow-hidden rounded-[2rem] p-10 sm:p-14">
        <div
          class="pointer-events-none absolute inset-0 bg-[radial-gradient(60%_100%_at_100%_0%,rgba(201,163,92,0.12),transparent_60%)]"
          aria-hidden="true"
        >
        </div>
        <div class="relative max-w-2xl">
          <p class="text-[0.65rem] uppercase tracking-[0.24em] text-kwiin-gold-bright/80">
            <span data-i18n="studio.signatureLabel">Die Signature Behandlung</span>
          </p>
          <h2 class="mt-3 font-display text-4xl text-kwiin-ivory sm:text-5xl">{featuredService.title}</h2>
          <p class="mt-3 font-display text-xl italic text-kwiin-gold-bright/90" data-i18n="service.kwiin.tagline">
            {featuredService.tagline}
          </p>
          <p class="mt-5 text-base leading-relaxed text-kwiin-soft-grey" data-i18n="service.kwiin.description">
            {featuredService.description}
          </p>
          <div class="mt-8">
            <WhatsAppButton message={featuredService.whatsappText} label="Via WhatsApp buchen" labelKey="common.bookWhatsApp" messageKey="common.studioWhatsApp" />
          </div>
        </div>
      </div>
    </SectionReveal>

    {/* ── Treatments ───────────────────────────────────────────────── */}
    <section id="treatments" class="mx-auto max-w-7xl scroll-mt-28 px-5 py-20 lg:px-8">
      <SectionReveal class="mb-12 text-center">
        <p class="kwiin-eyebrow" data-i18n="studio.treatmentsEyebrow">Behandlungen</p>
        <h2 class="mt-5 font-display text-4xl text-kwiin-ivory sm:text-5xl">
          <span data-i18n="studio.treatmentsTitleLead">Die KWIIN </span><span class="kwiin-accent" data-i18n="studio.treatmentsTitleAccent">Lotus Flow Methode</span>
        </h2>
        <p class="mx-auto mt-5 max-w-2xl text-sm leading-relaxed text-kwiin-soft-grey" data-i18n="studio.treatmentsCopy">
          Traditionelle Thai Körperarbeit, fliessende Dehnungen und gezielter Druck werden passend zu Ihren Bedürfnissen kombiniert.
        </p>
      </SectionReveal>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {studioServices.map((service) => <ServiceCard service={service} context="studio" />)}
      </div>
    </section>

    <SectionReveal class="mx-auto max-w-3xl px-5 pb-24 text-center lg:px-8">
      <OrnamentDivider class="mb-10" />
      <p class="font-display text-2xl italic text-kwiin-gold-bright text-balance">
        “<span data-i18n="common.brandLine">{brandLine}</span>”
      </p>
    </SectionReveal>

    <PartnerStrip />
  </PageTransition>
</BaseLayout>
