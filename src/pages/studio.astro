---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageTransition from "../components/PageTransition.astro";
import SectionReveal from "../components/SectionReveal.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import ServiceCard from "../components/ServiceCard.astro";
import LocationNote from "../components/LocationNote.astro";
import PartnerStrip from "../components/PartnerStrip.astro";
import GoldDust from "../components/GoldDust.astro";
import OrnamentDivider from "../components/OrnamentDivider.astro";
import { services, featuredService } from "../data/services";
import { WHATSAPP_MESSAGES } from "../utils/whatsapp";
import { brandLine } from "../data/contact";

const title = "KWIIN Signature Experience | Thai-Massage Studio in Dübendorf";
const description =
  "Preisgekrönte Thai-Massage mit luxuriöser Heilkunst in einem ruhigen Studio in Dübendorf. Buchen Sie Ihre KWIIN Signature Experience via WhatsApp.";

const studioServices = services.filter((s) => s.studioAvailable);

const ritual = [
  {
    step: "01",
    title: "Ankommen",
    copy: "Ruhe, ein kurzes Gespräch, bewusstes Loslassen. Jede Behandlung beginnt mit dem Zuhören und wird auf Ihren Körper und Ihren Tag abgestimmt.",
  },
  {
    step: "02",
    title: "Die Behandlung",
    copy: "Akupressur, achtsame Dehnung und Energiearbeit fliessen ineinander. Kraftvoll, präzise und immer im Dialog mit Ihrem Körper.",
  },
  {
    step: "03",
    title: "Nachklang",
    copy: "Zeit zum Zurückkommen. Ihr Körper darf das Erlebte setzen lassen, bevor Sie zurück in den Tag gehen. Leichter, ruhiger, ganz bei sich.",
  },
];
---

<BaseLayout title={title} description={description}>
  <PageTransition>
    <section class="relative overflow-hidden pb-24 pt-40">
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(201,163,92,0.14),transparent_55%)]"
        aria-hidden="true"
      >
      </div>
      <GoldDust />
      <div class="relative mx-auto max-w-4xl px-5 text-center lg:px-8">
        <p class="kwiin-eyebrow">KWIIN Signature Experience</p>
        <h1 class="mt-6 font-display text-4xl leading-tight text-kwiin-ivory text-balance sm:text-5xl lg:text-6xl">
          Die Kunst der Berührung,
          <span class="kwiin-accent text-gold-gradient">in ihrer edelsten Form.</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-kwiin-soft-grey">
          Preisgekrönte Thai-Massage von Pratana Halstrick: geboren in Bangkok, geprägt zwischen
          Thailand, Deutschland und der Schweiz, und ganz der Aufgabe gewidmet, Körper und Geist
          neue Kraft zu schenken.
        </p>
        <div class="mt-9 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <WhatsAppButton message={WHATSAPP_MESSAGES.studioGeneric} label="Termin via WhatsApp" size="lg" />
          <a
            href="#treatments"
            class="text-sm uppercase tracking-[0.12em] text-kwiin-ivory/80 underline-offset-4 transition-colors hover:text-kwiin-gold-bright hover:underline"
          >
            Behandlungen entdecken
          </a>
        </div>
        <div class="mt-10 flex justify-center">
          <LocationNote variant="subtle" class="text-center" />
        </div>
      </div>
    </section>

    {/* ── Die Seele Thailands ──────────────────────────────────────── */}
    <section class="relative border-y border-kwiin-gold/10 py-24">
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(80%_70%_at_50%_100%,rgba(201,163,92,0.07),transparent_60%)]"
        aria-hidden="true"
      >
      </div>
      <div class="relative mx-auto grid max-w-6xl gap-12 px-5 lg:grid-cols-[3fr_2fr] lg:items-center lg:px-8">
        <SectionReveal>
          <p class="kwiin-eyebrow kwiin-eyebrow--bare">Die Seele Thailands</p>
          <h2 class="mt-5 font-display text-4xl leading-tight text-kwiin-ivory sm:text-5xl">
            Nuad <span class="kwiin-accent">Thai</span>
          </h2>
          <p class="mt-6 max-w-xl text-base leading-relaxed text-kwiin-soft-grey">
            Im Mittelpunkt unserer Arbeit steht die traditionelle Nuad Thai Massage, eine
            Heilkunst mit einer über 2'500-jährigen Geschichte. Sie verbindet Akupressur,
            Meditation, achtsame Dehnung und Energiearbeit zu einer ganzheitlichen Behandlung.
          </p>
          <p class="mt-4 max-w-xl text-base leading-relaxed text-kwiin-soft-grey">
            Für uns ist Nuad Thai kein Trend. Es ist ein kulturelles Erbe. Eine Tradition, die
            wir mit tiefem Respekt bewahren und mit Stolz weitergeben.
          </p>
        </SectionReveal>

        <SectionReveal class="kwiin-panel relative overflow-hidden rounded-3xl p-10 text-center">
          <p class="font-display text-7xl leading-none text-kwiin-gold-bright">2019</p>
          <p class="mt-4 text-xs uppercase tracking-[0.24em] text-kwiin-gold-bright/80">
            UNESCO
          </p>
          <p class="mt-2 font-display text-xl leading-snug text-kwiin-ivory text-balance">
            Anerkannt als Immaterielles Kulturerbe der Menschheit
          </p>
          <OrnamentDivider class="mt-6" />
        </SectionReveal>
      </div>
    </section>

    {/* ── Das Ritual ───────────────────────────────────────────────── */}
    <section class="mx-auto max-w-6xl px-5 py-24 lg:px-8">
      <SectionReveal class="mb-12 text-center">
        <p class="kwiin-eyebrow">Das Ritual</p>
        <h2 class="mt-5 font-display text-4xl text-kwiin-ivory sm:text-5xl">
          Drei Akte der <span class="kwiin-accent">Entschleunigung</span>
        </h2>
      </SectionReveal>

      <SectionReveal stagger={true} class="grid gap-6 md:grid-cols-3">
        {
          ritual.map((act) => (
            <div data-reveal-child class="kwiin-panel relative flex flex-col rounded-3xl p-8">
              <span class="font-display text-5xl italic text-kwiin-gold/40">{act.step}</span>
              <h3 class="mt-4 font-display text-2xl text-kwiin-ivory">{act.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-kwiin-soft-grey">{act.copy}</p>
            </div>
          ))
        }
      </SectionReveal>
    </section>

    {/* ── Signature treatment ──────────────────────────────────────── */}
    <SectionReveal class="mx-auto max-w-6xl px-5 pb-8 lg:px-8">
      <div class="kwiin-panel relative overflow-hidden rounded-[2rem] p-10 sm:p-14">
        <div
          class="pointer-events-none absolute inset-0 bg-[radial-gradient(60%_100%_at_100%_0%,rgba(201,163,92,0.12),transparent_60%)]"
          aria-hidden="true"
        >
        </div>
        <div class="relative max-w-2xl">
          <p class="text-[0.65rem] uppercase tracking-[0.24em] text-kwiin-gold-bright/80">
            Die Signature-Behandlung
          </p>
          <h2 class="mt-3 font-display text-4xl text-kwiin-ivory sm:text-5xl">{featuredService.title}</h2>
          <p class="mt-3 font-display text-xl italic text-kwiin-gold-bright/90">
            {featuredService.tagline}
          </p>
          <p class="mt-5 text-base leading-relaxed text-kwiin-soft-grey">
            {featuredService.description}
          </p>
          <div class="mt-8">
            <WhatsAppButton message={featuredService.whatsappText} label="Via WhatsApp buchen" />
          </div>
        </div>
      </div>
    </SectionReveal>

    {/* ── Treatments ───────────────────────────────────────────────── */}
    <section id="treatments" class="mx-auto max-w-7xl scroll-mt-28 px-5 py-20 lg:px-8">
      <SectionReveal class="mb-12 text-center">
        <p class="kwiin-eyebrow">Behandlungen</p>
        <h2 class="mt-5 font-display text-4xl text-kwiin-ivory sm:text-5xl">
          Die KWIIN <span class="kwiin-accent">Lotus Flow</span> Methode
        </h2>
        <p class="mx-auto mt-5 max-w-2xl text-sm leading-relaxed text-kwiin-soft-grey">
          Ein Signature-Ansatz, der traditionelle Thai-Körperarbeit mit fliessenden Dehnungen
          und gezielten Druckpunkttechniken verbindet. Verspannungen lösen sich, Beweglichkeit
          kehrt zurück, das Nervensystem darf weich werden.
        </p>
      </SectionReveal>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {studioServices.map((service) => <ServiceCard service={service} context="studio" />)}
      </div>
    </section>

    <SectionReveal class="mx-auto max-w-3xl px-5 pb-24 text-center lg:px-8">
      <OrnamentDivider class="mb-10" />
      <p class="font-display text-2xl italic text-kwiin-gold-bright text-balance">
        “{brandLine}”
      </p>
    </SectionReveal>

    <PartnerStrip />
  </PageTransition>
</BaseLayout>
