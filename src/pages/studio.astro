---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageTransition from "../components/PageTransition.astro";
import SectionReveal from "../components/SectionReveal.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import ServiceCard from "../components/ServiceCard.astro";
import LocationNote from "../components/LocationNote.astro";
import PartnerStrip from "../components/PartnerStrip.astro";
import { services, featuredService } from "../data/services";
import { WHATSAPP_MESSAGES } from "../utils/whatsapp";
import { brandLine } from "../data/contact";

const title = "KWIIN Signature Experience | Thai Massage Studio in Dübendorf";
const description =
  "Champion-level Thai massage with a luxury healing touch, in a calm studio setting in Dübendorf. Book your KWIIN Signature Experience via WhatsApp.";

const studioServices = services.filter((s) => s.studioAvailable);
---

<BaseLayout title={title} description={description}>
  <PageTransition>
    <section class="relative overflow-hidden pt-36 pb-24">
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(201,168,106,0.12),transparent_55%)]"
        aria-hidden="true"
      ></div>
      <div class="relative mx-auto max-w-4xl px-5 text-center lg:px-8">
        <p class="text-xs uppercase tracking-[0.2em] text-kwiin-gold-bright/80">
          KWIIN Signature Experience
        </p>
        <h1 class="mt-4 font-display text-4xl leading-tight text-kwiin-ivory text-balance sm:text-5xl lg:text-6xl">
          Champion-level Thai massage with a luxury healing touch.
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-kwiin-soft-grey">
          By Pratana Halstrick, born in Bangkok, shaped between Thailand, Germany, and
          Switzerland, and devoted to helping people feel renewed in body and spirit.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <WhatsAppButton message={WHATSAPP_MESSAGES.studioGeneric} label="Book via WhatsApp" size="lg" />
          <a
            href="#treatments"
            class="text-sm uppercase tracking-[0.1em] text-kwiin-ivory/80 underline-offset-4 hover:text-kwiin-gold-bright hover:underline"
          >
            Explore Treatments
          </a>
        </div>
        <div class="mt-10 flex justify-center">
          <LocationNote variant="subtle" />
        </div>
      </div>
    </section>

    <SectionReveal class="mx-auto max-w-7xl px-5 pb-20 lg:px-8">
      <div class="grid gap-8 md:grid-cols-2">
        <div class="kwiin-card rounded-3xl p-8">
          <p class="text-xs uppercase tracking-[0.14em] text-kwiin-gold-bright/80">
            The Signature Treatment
          </p>
          <h2 class="mt-3 font-display text-3xl text-kwiin-ivory">{featuredService.title}</h2>
          <p class="mt-2 font-display text-lg italic text-kwiin-gold-bright/90">
            {featuredService.tagline}
          </p>
          <p class="mt-4 text-sm leading-relaxed text-kwiin-soft-grey">
            {featuredService.description}
          </p>
        </div>
        <div class="kwiin-card flex flex-col justify-center rounded-3xl border-2 border-dashed border-white/10 p-8 text-center text-sm text-kwiin-soft-grey/70">
          {/* Placeholder: replace with original studio / treatment-room photography */}
          Studio &amp; treatment photography coming soon
        </div>
      </div>
    </SectionReveal>

    <section id="treatments" class="mx-auto max-w-7xl px-5 pb-20 lg:px-8">
      <SectionReveal class="mb-10 text-center">
        <p class="text-xs uppercase tracking-[0.2em] text-kwiin-gold-bright/80">Treatments</p>
        <h2 class="mt-3 font-display text-3xl text-kwiin-ivory sm:text-4xl">
          The KWIIN Lotus Flow Method
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-sm leading-relaxed text-kwiin-soft-grey">
          A signature approach that blends traditional Thai bodywork with flowing stretches and
          focused pressure-point techniques, designed to help release tension, support mobility,
          and invite the nervous system to soften.
        </p>
      </SectionReveal>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {studioServices.map((service) => <ServiceCard service={service} context="studio" />)}
      </div>
    </section>

    <SectionReveal class="mx-auto max-w-3xl px-5 pb-24 text-center lg:px-8">
      <p class="font-display text-2xl italic text-kwiin-gold-bright text-balance">
        “{brandLine}”
      </p>
    </SectionReveal>

    <PartnerStrip />
  </PageTransition>
</BaseLayout>
