---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageTransition from "../components/PageTransition.astro";
import PortalChoice from "../components/PortalChoice.astro";
import PartnerStrip from "../components/PartnerStrip.astro";
import HeroAura from "../components/HeroAura";

const title = "KWIIN by Pratana Halstrick — Luxury Thai Massage in Switzerland";
const description =
  "KWIIN by Pratana Halstrick offers champion-level Thai massage in Dübendorf and Mobile Spa appointments across the Zürich region. Book via WhatsApp.";
---

<BaseLayout title={title} description={description}>
  <PageTransition>
    <section class="relative flex min-h-screen items-center overflow-hidden pt-28">
      <HeroAura client:visible />

      <div class="relative z-10 mx-auto w-full max-w-7xl px-5 lg:px-8">
        <div class="mb-12 text-center">
          <p class="text-[0.7rem] uppercase tracking-[0.32em] text-kwiin-gold-bright/80">
            Champion-level Thai massage · Switzerland
          </p>
          <h1 class="text-gold-gradient mx-auto mt-5 max-w-3xl font-display text-5xl leading-[1.05] text-balance sm:text-6xl lg:text-7xl">
            Choose your KWIIN journey
          </h1>
          <p class="mx-auto mt-5 font-display text-lg italic text-kwiin-gold-bright/90 sm:text-xl">
            Gratitude in the name of your health.
          </p>
        </div>

        <PortalChoice />

        <p class="mx-auto mt-10 max-w-xl text-center text-sm leading-relaxed text-kwiin-soft-grey">
          Two ways to experience KWIIN — a dedicated studio setting in Dübendorf, or Pratana's
          luxury Thai massage brought directly to your space.
        </p>
      </div>
    </section>

    <PartnerStrip />
  </PageTransition>
</BaseLayout>
