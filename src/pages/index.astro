---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageTransition from "../components/PageTransition.astro";
import PortalChoice from "../components/PortalChoice.astro";
import PartnerStrip from "../components/PartnerStrip.astro";
import SectionReveal from "../components/SectionReveal.astro";
import OrnamentDivider from "../components/OrnamentDivider.astro";
import ValuesMarquee from "../components/ValuesMarquee.astro";
import GoldDust from "../components/GoldDust.astro";
import TestimonialCard from "../components/TestimonialCard.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import HeroAura from "../components/HeroAura.astro";
import GlobalLanguageSelector from "../components/GlobalLanguageSelector.astro";
import { testimonials } from "../data/testimonials";
import { WHATSAPP_MESSAGES } from "../utils/whatsapp";
import { withBase } from "../utils/base";

const title = "KWIIN by Pratana Halstrick | Zurück zu sich";
const description =
  "KWIIN verbindet traditionelle thailändische Heilkunst mit modernem Luxus: preisgekrönte Thai-Massage im Studio in Dübendorf und als Mobile Spa in der ganzen Region Zürich.";
const touchLines = [
  { text: "Berührung kann beruhigen.", key: "home.touchLineOne" },
  { text: "Sie kann Schmerzen lindern.", key: "home.touchLineTwo" },
  { text: "Sie kann Vertrauen geben.", key: "home.touchLineThree" },
  { text: "Sie kann neue Energie bringen.", key: "home.touchLineFour" },
] as const;
---

<BaseLayout title={title} description={description} page="home">
  <PageTransition>
    {/* ── I. Hero: the arrival ─────────────────────────────────────── */}
    <section class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden pb-14 pt-28">
      <HeroAura />

      <div class="relative z-10 mx-auto w-full max-w-7xl px-5 lg:px-8">
        <div class="text-center">
          <p class="kwiin-eyebrow" data-i18n="hero.eyebrow">Willkommen bei KWIIN</p>
          <GlobalLanguageSelector />
        </div>

        <div class="kwiin-portrait-stage relative mx-auto mt-6 flex w-full max-w-md justify-center sm:max-w-lg">
          <span class="kwiin-aura" aria-hidden="true"></span>
          <span class="kwiin-aura-ground" aria-hidden="true"></span>
          <picture class="relative z-10 flex justify-center">
            <source
              srcset={withBase("/assets/Pratana%20Portrait%20transparent%20optimised.webp")}
              type="image/webp"
            />
            <img
              src={withBase("/assets/pratana-portrait.png")}
              alt="Pratana Halstrick, Gründerin von KWIIN"
              data-i18n-alt="hero.portraitAlt"
              class="kwiin-portrait w-auto"
              decoding="async"
              fetchpriority="high"
            />
          </picture>
        </div>

        <p
          class="mx-auto mt-2 max-w-2xl text-center font-display text-lg leading-relaxed text-kwiin-ivory-dim sm:text-xl"
          data-i18n="hero.intro"
        >
          KWIIN ist ein ruhiger Ort für gute Massage, echte Erholung und Zeit für sich.
        </p>

        <div class="mt-12 flex flex-col items-center gap-3" aria-hidden="true">
          <span class="text-[0.62rem] uppercase tracking-[0.3em] text-kwiin-soft-grey/85" data-i18n="hero.cue">
            Wählen Sie Ihren Weg
          </span>
          <span class="kwiin-scroll-cue"></span>
        </div>
      </div>
    </section>

    {/* ── II. The portal: two worlds ───────────────────────────────── */}
    <section class="relative mx-auto max-w-7xl px-4 pb-24 pt-4 sm:px-5 lg:px-8">
      <PortalChoice />
      <SectionReveal class="mx-auto mt-10 max-w-2xl text-center">
        <p class="font-display text-lg leading-relaxed text-kwiin-ivory-dim sm:text-xl" data-i18n="home.portalFollow">
          Im Studio oder bei Ihnen zuhause: Sie erhalten dieselbe persönliche Betreuung und dieselbe Qualität.
        </p>
      </SectionReveal>
    </section>

    {/* ── III. Manifesto: true luxury is time ──────────────────────── */}
    <section class="relative overflow-hidden py-28 sm:py-36">
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(70%_60%_at_50%_50%,rgba(201,163,92,0.07),transparent_70%)]"
        aria-hidden="true"
      >
      </div>
      <div class="relative mx-auto max-w-4xl px-5 text-center lg:px-8">
        <p class="kwiin-eyebrow" data-i18n="home.beliefEyebrow">Was uns wichtig ist</p>
        <p class="mt-10 font-display text-2xl text-kwiin-soft-grey sm:text-3xl" data-words data-i18n="home.beliefIntro">
          Luxus muss nicht laut sein.
        </p>
        <p
          class="mt-6 font-display text-5xl italic leading-[1.1] text-kwiin-gold-bright text-balance sm:text-6xl lg:text-7xl"
          data-words data-i18n="home.beliefMain"
        >
          Luxus ist Zeit für sich.
        </p>

        <SectionReveal stagger={true} class="mt-14 flex flex-col items-center gap-4">
          <p data-reveal-child class="font-display text-xl text-kwiin-ivory-dim sm:text-2xl">
            <span data-i18n="home.timeOne">Zeit zum Abschalten.</span>
          </p>
          <p data-reveal-child class="font-display text-xl text-kwiin-ivory-dim sm:text-2xl">
            <span data-i18n="home.timeTwo">Zeit zum Durchatmen.</span>
          </p>
          <p data-reveal-child class="font-display text-xl text-kwiin-ivory-dim sm:text-2xl">
            <span data-i18n="home.timeThree">Zeit, sich wieder gut zu fühlen.</span>
          </p>
        </SectionReveal>

        <OrnamentDivider class="mt-16" />
      </div>
    </section>

    {/* ── IV. Values in motion ─────────────────────────────────────── */}
    <ValuesMarquee />

    {/* ── V. Die Kunst der Berührung ───────────────────────────────── */}
    <section class="mx-auto max-w-7xl px-5 py-28 lg:px-8">
      <div class="grid gap-14 lg:grid-cols-[2fr_3fr] lg:gap-20">
        <SectionReveal class="lg:sticky lg:top-32 lg:self-start">
          <p class="kwiin-eyebrow kwiin-eyebrow--bare" data-i18n="home.touchChapter">Kapitel I</p>
          <h2 class="mt-5 font-display text-4xl leading-tight text-kwiin-ivory sm:text-5xl">
            <span data-i18n="home.touchTitleLead">Die Kraft der </span><span class="kwiin-accent" data-i18n="home.touchTitleAccent">Berührung</span>
          </h2>
          <p class="mt-6 max-w-md text-base leading-relaxed text-kwiin-soft-grey" data-i18n="home.touchCopy">
            Massage ist eine direkte Form von Fürsorge. Eine gute Behandlung hört auf den Körper und gibt ihm, was er gerade braucht.
          </p>
        </SectionReveal>

        <SectionReveal stagger={true} class="flex flex-col">
          {
            touchLines.map((line) => (
              <p
                data-reveal-child
                class="border-b border-kwiin-purple/10 py-7 font-display text-2xl text-kwiin-ivory-dim transition-colors hover:text-kwiin-ivory sm:text-3xl"
              >
                <span data-i18n={line.key}>{line.text}</span>
              </p>
            ))
          }
          <p data-reveal-child class="pt-10 font-display text-2xl italic leading-snug text-kwiin-gold-bright sm:text-3xl">
            <span data-i18n="home.touchFinalOne">Wir behandeln nicht nur Muskeln.</span><br /><span data-i18n="home.touchFinalTwo">Wir behandeln Menschen.</span>
          </p>
        </SectionReveal>
      </div>
    </section>

    {/* ── VI. Die Seele Thailands ──────────────────────────────────── */}
    <section class="relative overflow-hidden border-y border-kwiin-gold/10 py-28">
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(90%_70%_at_50%_0%,rgba(201,163,92,0.1),transparent_60%)]"
        aria-hidden="true"
      >
      </div>
      <GoldDust />

      <div class="relative mx-auto max-w-5xl px-5 text-center lg:px-8">
        <SectionReveal>
          <p class="kwiin-eyebrow" data-i18n="home.thaiEyebrow">Die Wurzeln in Thailand</p>
          <h2 class="mx-auto mt-6 max-w-3xl font-display text-4xl leading-tight text-kwiin-ivory text-balance sm:text-5xl">
            <span data-i18n="home.thaiTitleLead">Nuad Thai hat über </span><span class="kwiin-accent" data-i18n="home.thaiTitleAccent">2'500 Jahre</span><span data-i18n="home.thaiTitleEnd"> Geschichte.</span>
          </h2>
          <p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-kwiin-soft-grey" data-i18n="home.thaiCopy">
            Nuad Thai verbindet Druck, Dehnung und ruhige Bewegungen. 2019 wurde sie von der UNESCO als Kulturerbe anerkannt. Pratana führt diese Tradition mit Respekt und viel Erfahrung weiter.
          </p>
        </SectionReveal>

        <SectionReveal stagger={true} class="mx-auto mt-16 grid max-w-3xl gap-10 sm:grid-cols-3">
          <div data-reveal-child>
            <p class="font-display text-5xl text-kwiin-gold-bright">
              <span data-counter="2500" data-counter-suffix="+">2'500+</span>
            </p>
            <p class="mt-2 text-xs uppercase tracking-[0.2em] text-kwiin-soft-grey" data-i18n="home.thaiYears">Jahre Erfahrungstradition</p>
          </div>
          <div data-reveal-child>
            <p class="font-display text-5xl text-kwiin-gold-bright">
              <span data-counter="2019">2019</span>
            </p>
            <p class="mt-2 text-xs uppercase tracking-[0.2em] text-kwiin-soft-grey" data-i18n="home.thaiUnesco">UNESCO Anerkennung</p>
          </div>
          <div data-reveal-child>
            <p class="font-display text-5xl text-kwiin-gold-bright">
              <span data-counter="4">4</span>
            </p>
            <p class="mt-2 text-xs uppercase tracking-[0.2em] text-kwiin-soft-grey" data-i18n="home.thaiMedals">Medaillen 2026</p>
          </div>
        </SectionReveal>

        <SectionReveal class="mt-14">
          <a
            href={withBase("/studio")}
            class="inline-flex items-center gap-2 text-sm uppercase tracking-[0.16em] text-kwiin-gold-bright underline-offset-8 transition-colors hover:text-kwiin-ivory hover:underline"
          >
            <span data-i18n="home.thaiLink">Zur Signature Experience</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-4 w-4">
              <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </a>
        </SectionReveal>
      </div>
    </section>

    {/* ── VII. Voices ──────────────────────────────────────────────── */}
    <section class="mx-auto max-w-7xl px-5 py-28 lg:px-8">
      <SectionReveal class="mb-12 text-center">
        <p class="kwiin-eyebrow" data-i18n="home.voicesEyebrow">Stimmen</p>
        <h2 class="mt-5 font-display text-4xl text-kwiin-ivory sm:text-5xl">
          <span data-i18n="home.voicesTitleLead">Was Gäste </span><span class="kwiin-accent" data-i18n="home.voicesTitleAccent">sagen</span>
        </h2>
      </SectionReveal>
      <div class="grid gap-6 md:grid-cols-3">
        {testimonials.map((t) => <TestimonialCard testimonial={t} />)}
      </div>
    </section>

    {/* ── VIII. The invitation ─────────────────────────────────────── */}
    <section class="relative overflow-hidden py-28">
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(60%_80%_at_50%_100%,rgba(124,94,163,0.1),transparent_65%)]"
        aria-hidden="true"
      >
      </div>
      <SectionReveal class="relative mx-auto max-w-3xl px-5 text-center lg:px-8">
        <p class="kwiin-eyebrow" data-i18n="home.inviteEyebrow">Ihre Auszeit</p>
        <h2 class="mt-6 font-display text-4xl leading-tight text-kwiin-ivory text-balance sm:text-5xl">
          <span data-i18n="home.inviteTitleLead">Nehmen Sie sich einen Moment, </span><br />
          <span class="kwiin-accent" data-i18n="home.inviteTitleAccent">der nur Ihnen gehört.</span>
        </h2>
        <p class="mx-auto mt-6 max-w-xl text-base leading-relaxed text-kwiin-soft-grey" data-i18n="home.inviteCopy">
          Lassen Sie den Alltag kurz los und geben Sie Ihrem Körper die Ruhe, die er braucht.
        </p>
        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <WhatsAppButton message={WHATSAPP_MESSAGES.studioGeneric} label="Termin via WhatsApp" labelKey="common.whatsappAppointment" messageKey="common.studioWhatsApp" size="lg" />
          <a
            href={withBase("/about")}
            class="text-sm uppercase tracking-[0.12em] text-kwiin-ivory/80 underline-offset-4 transition-colors hover:text-kwiin-gold-bright hover:underline"
          >
            <span data-i18n="home.inviteHistory">Die Geschichte von KWIIN</span>
          </a>
        </div>
        <p class="mt-12 font-display text-xl italic text-kwiin-gold-bright/90" data-i18n="home.inviteWelcome">
          Willkommen bei KWIIN. Willkommen bei sich selbst.
        </p>
      </SectionReveal>
    </section>

    <PartnerStrip />
  </PageTransition>
</BaseLayout>

<style>
  .kwiin-portrait {
    max-height: 52vh;
    filter:
      drop-shadow(0 30px 50px rgba(0, 0, 0, 0.6))
      drop-shadow(0 0 60px rgba(201, 163, 92, 0.28));
    -webkit-mask-image: linear-gradient(to bottom, #000 78%, transparent 100%);
    mask-image: linear-gradient(to bottom, #000 78%, transparent 100%);
    animation: kwiin-float 7s ease-in-out infinite;
  }

  .kwiin-aura {
    position: absolute;
    left: 50%;
    top: 46%;
    width: min(90vw, 520px);
    aspect-ratio: 1;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(236, 210, 155, 0.3),
      rgba(201, 163, 92, 0.13) 38%,
      rgba(124, 94, 163, 0.12) 60%,
      transparent 72%
    );
    filter: blur(22px);
    animation: kwiin-breathe 6s ease-in-out infinite;
    z-index: 0;
  }

  .kwiin-aura-ground {
    position: absolute;
    left: 50%;
    bottom: 4%;
    width: min(70vw, 360px);
    height: 60px;
    transform: translateX(-50%);
    background: radial-gradient(ellipse, rgba(201, 163, 92, 0.22), transparent 70%);
    filter: blur(10px);
    z-index: 0;
  }

  @keyframes kwiin-breathe {
    0%, 100% { opacity: 0.72; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 1; transform: translate(-50%, -50%) scale(1.08); }
  }

  @keyframes kwiin-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .kwiin-portrait,
    .kwiin-aura { animation: none !important; }
  }
</style>
