---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageTransition from "../components/PageTransition.astro";
import SectionReveal from "../components/SectionReveal.astro";
import OrnamentDivider from "../components/OrnamentDivider.astro";
import GoldDust from "../components/GoldDust.astro";
import AwardCard from "../components/AwardCard.astro";
import LocationNote from "../components/LocationNote.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import LotusMark from "../components/LotusMark.astro";
import {
  awards,
  championshipName,
  championshipLocation,
} from "../data/awards";
import { WHATSAPP_MESSAGES } from "../utils/whatsapp";
import { brandLine } from "../data/contact";
import { withBase } from "../utils/base";

const title = "Über KWIIN | Die Geschichte, Philosophie und Gründerin";
const description =
  "Die Geschichte von KWIIN: King, Queen, Win. Erfahren Sie mehr über unsere Philosophie, unsere Vision und Pratana Halstrick, die preisgekrönte Gründerin von KWIIN.";

const pillars = [
  { word: "Selbstfürsorge", note: "Nehmen Sie Ihre Bedürfnisse ernst.", wordKey: "about.pillarLove", noteKey: "about.pillarLoveNote" },
  { word: "Respekt", note: "Jeder Mensch wird gleich behandelt.", wordKey: "about.pillarRespect", noteKey: "about.pillarRespectNote" },
  { word: "Mitgefühl", note: "Wir hören zu und nehmen uns Zeit.", wordKey: "about.pillarCare", noteKey: "about.pillarCareNote" },
  { word: "Stärke", note: "Ruhe kann neue Kraft geben.", wordKey: "about.pillarStrength", noteKey: "about.pillarStrengthNote" },
];

const values = [
  { word: "Eleganz", note: "Einfach und gut gemacht.", wordKey: "values.elegance", noteKey: "about.valueEleganceNote" },
  { word: "Qualität", note: "Qualität kommt vor Menge.", wordKey: "values.quality", noteKey: "about.valueQualityNote" },
  { word: "Achtsamkeit", note: "Wir nehmen uns Zeit.", wordKey: "values.mindfulness", noteKey: "about.valueMindfulnessNote" },
  { word: "Respekt", note: "Jeder Gast ist willkommen.", wordKey: "values.respect", noteKey: "about.valueRespectNote" },
  { word: "Authentizität", note: "Tradition und neue Ideen passen zusammen.", wordKey: "values.authenticity", noteKey: "about.valueAuthenticityNote" },
];
---

<BaseLayout title={title} description={description} page="about">
  <PageTransition>
    {/* ── 1. Die Geschichte von KWIIN ──────────────────────────────── */}
    <section class="relative overflow-hidden pb-20 pt-40">
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(70%_50%_at_50%_0%,rgba(201,163,92,0.12),transparent_60%)]"
        aria-hidden="true"
      >
      </div>
      <GoldDust />
      <div class="relative mx-auto max-w-4xl px-5 text-center lg:px-8">
        <p class="kwiin-eyebrow" data-i18n="about.eyebrow">Über KWIIN</p>
        <h1 class="mt-6 font-display text-5xl leading-[1.05] text-kwiin-ivory text-balance sm:text-6xl">
          <span data-i18n="about.titleLead">Die Geschichte von </span><span class="kwiin-accent text-gold-gradient" data-i18n="about.titleAccent">KWIIN</span>
        </h1>
        <p class="mx-auto mt-8 max-w-2xl font-display text-xl leading-relaxed text-kwiin-ivory-dim" data-words data-i18n="about.intro">
          Pratanas Weg begann in Bangkok und führte über Deutschland in die Schweiz.
        </p>
        <p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-kwiin-soft-grey" data-i18n="about.storyCopy">
          KWIIN ist aus Erfahrung, viel Übung und der Liebe zur Thai Massage entstanden. Pratana verbindet ihre Wurzeln mit einem ruhigen, persönlichen Service.
        </p>
      </div>
    </section>

    {/* ── 2. King · Queen · Win ────────────────────────────────────── */}
    <section class="relative border-y border-kwiin-gold/10 py-24">
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(60%_80%_at_50%_100%,rgba(124,94,163,0.08),transparent_60%)]"
        aria-hidden="true"
      >
      </div>
      <div class="relative mx-auto max-w-5xl px-5 text-center lg:px-8">
        <SectionReveal>
          <svg viewBox="0 0 48 26" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto h-8 w-auto text-kwiin-gold" aria-hidden="true">
            <path d="M6 20 L4 7 L14 13 L24 4 L34 13 L44 7 L42 20 Z"></path>
            <path d="M8 24 h32"></path>
          </svg>
        </SectionReveal>

        <SectionReveal stagger={true} class="mt-10 flex flex-col items-center justify-center gap-2 font-display sm:flex-row sm:gap-8">
          <span data-reveal-child class="text-5xl text-kwiin-ivory sm:text-6xl">King<span class="text-kwiin-gold">.</span></span>
          <span data-reveal-child class="text-5xl italic text-kwiin-gold-bright sm:text-6xl">Queen<span class="text-kwiin-gold">.</span></span>
          <span data-reveal-child class="text-5xl text-kwiin-ivory sm:text-6xl">Win<span class="text-kwiin-gold">.</span></span>
        </SectionReveal>

        <SectionReveal class="mx-auto mt-10 max-w-2xl">
          <p class="font-display text-xl leading-relaxed text-kwiin-ivory-dim" data-words data-i18n="about.nameCopy">
            KWIIN kommt von King, Queen und Win. Der Name erinnert daran, dass jeder Mensch Respekt und gute Betreuung verdient.
          </p>
          <p class="mt-5 text-base leading-relaxed text-kwiin-soft-grey" data-i18n="about.nameNote">
            Ganz gleich, wer Sie sind oder woher Sie kommen.
          </p>
        </SectionReveal>
      </div>
    </section>

    {/* ── 3. Unsere Philosophie ────────────────────────────────────── */}
    <section class="mx-auto max-w-6xl px-5 py-24 lg:px-8">
      <SectionReveal class="text-center">
        <p class="kwiin-eyebrow" data-i18n="about.philosophyEyebrow">Unsere Haltung</p>
        <h2 class="mx-auto mt-6 max-w-3xl font-display text-4xl leading-tight text-kwiin-ivory text-balance sm:text-5xl">
          <span data-i18n="about.philosophyTitleLead">Gute Behandlung beginnt mit </span><span class="kwiin-accent" data-i18n="about.philosophyTitleAccent">Respekt.</span>
        </h2>
      </SectionReveal>

      <SectionReveal stagger={true} class="mx-auto mt-14 grid max-w-4xl gap-px overflow-hidden rounded-3xl border border-kwiin-gold/15 bg-kwiin-gold/15 sm:grid-cols-2 lg:grid-cols-4">
        {
          pillars.map((pillar) => (
            <div data-reveal-child class="bg-kwiin-pearl/85 px-6 py-10 text-center">
              <LotusMark class="mx-auto h-5 w-auto text-kwiin-gold/70" strokeWidth={2} />
              <p class="mt-4 font-display text-2xl text-kwiin-ivory" data-i18n={pillar.wordKey}>{pillar.word}</p>
              <p class="mt-2 text-xs leading-relaxed text-kwiin-soft-grey" data-i18n={pillar.noteKey}>{pillar.note}</p>
            </div>
          ))
        }
      </SectionReveal>

      <SectionReveal class="mx-auto mt-14 max-w-2xl text-center">
        <p class="text-base leading-relaxed text-kwiin-soft-grey" data-i18n="about.philosophyCopy">
          Wir möchten, dass Sie sich sicher, verstanden und gut aufgehoben fühlen.
        </p>
        <p class="mt-8 font-display text-2xl italic leading-relaxed text-kwiin-gold-bright" data-words data-i18n="about.philosophyQuote">
          Jede Behandlung ist persönlich. Jeder Körper braucht etwas anderes.
        </p>
      </SectionReveal>
    </section>

    {/* ── 4. Unsere Vision ─────────────────────────────────────────── */}
    <section class="relative overflow-hidden border-y border-kwiin-purple/10 py-24">
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(80%_60%_at_50%_50%,rgba(201,163,92,0.06),transparent_70%)]"
        aria-hidden="true"
      >
      </div>
      <div class="relative mx-auto max-w-6xl px-5 lg:px-8">
        <SectionReveal class="mx-auto max-w-3xl text-center">
          <p class="kwiin-eyebrow" data-i18n="about.visionEyebrow">Unsere Vision</p>
          <h2 class="mt-6 font-display text-4xl leading-tight text-kwiin-ivory text-balance sm:text-5xl">
            <span data-i18n="about.visionTitleLead">Ein Ort, an dem Ihre Zeit </span><span class="kwiin-accent" data-i18n="about.visionTitleAccent">wieder Ihnen gehört.</span>
          </h2>
          <p class="mt-6 text-base leading-relaxed text-kwiin-soft-grey" data-i18n="about.visionCopy">
            Ruhe ist wichtig. Ein Termin bei KWIIN soll sich einfach gut anfühlen und Ihnen Zeit zum Abschalten geben.
          </p>
        </SectionReveal>

        <SectionReveal stagger={true} class="mx-auto mt-14 grid max-w-5xl gap-6 sm:grid-cols-2 lg:grid-cols-5">
          {
            values.map((value) => (
              <div data-reveal-child class="rounded-2xl border border-kwiin-purple/10 bg-white/35 px-5 py-7 text-center transition-colors duration-500 hover:border-kwiin-gold/30">
                <p class="font-display text-xl text-kwiin-gold-bright" data-i18n={value.wordKey}>{value.word}</p>
                <p class="mt-2 text-xs leading-relaxed text-kwiin-soft-grey" data-i18n={value.noteKey}>{value.note}</p>
              </div>
            ))
          }
        </SectionReveal>
      </div>
    </section>

    {/* ── 5. Die Gründerin ─────────────────────────────────────────── */}
    <section class="pt-24">
      <div class="mx-auto grid max-w-6xl gap-12 px-5 lg:grid-cols-2 lg:items-center lg:px-8">
        <SectionReveal>
          <p class="kwiin-eyebrow kwiin-eyebrow--bare" data-i18n="about.founderEyebrow">Die Gründerin</p>
          <h2 class="mt-4 font-display text-4xl text-kwiin-ivory sm:text-5xl">
            Pratana <span class="kwiin-accent">Halstrick</span>
          </h2>
          <p class="mt-6 text-base leading-relaxed text-kwiin-soft-grey" data-i18n="about.founderCopyOne">
            Pratana wurde 1990 in Bangkok geboren und wuchs in Thailand und Deutschland auf. Als Teenager begann sie, ihre Mutter zu massieren. Dabei merkte sie schnell, dass sie ein besonderes Gefühl für Druck und Bewegung hat.
          </p>
          <p class="mt-4 text-base leading-relaxed text-kwiin-soft-grey" data-i18n="about.founderCopyTwo">
            Später vertiefte sie ihr Handwerk in Deutschland und der Schweiz. Heute empfängt sie Gäste in Dübendorf und besucht sie mit dem Mobile Spa in der Region Zürich.
          </p>
          <div class="mt-8">
            <WhatsAppButton message={WHATSAPP_MESSAGES.studioGeneric} label="Termin via WhatsApp" labelKey="common.whatsappAppointment" messageKey="common.studioWhatsApp" />
          </div>
        </SectionReveal>

        <SectionReveal class="relative flex min-h-[22rem] items-center justify-center">
          <span
            class="pointer-events-none absolute left-1/2 top-1/2 h-[420px] w-[420px] max-w-full -translate-x-1/2 -translate-y-1/2 rounded-full bg-[radial-gradient(circle,rgba(201,163,92,0.18),transparent_65%)] blur-2xl"
            aria-hidden="true"
          >
          </span>
          <picture class="relative flex items-center justify-center">
            <source
              srcset={withBase("/assets/Pratana%20Portrait%20transparent%20optimised.webp")}
              type="image/webp"
            />
            <img
              src={withBase("/assets/pratana-portrait.png")}
              alt="Pratana Halstrick, Gründerin von KWIIN"
              data-i18n-alt="hero.portraitAlt"
              class="max-h-[30rem] w-auto object-contain drop-shadow-[0_30px_50px_rgba(0,0,0,0.6)]"
              loading="eager"
            />
          </picture>
        </SectionReveal>
      </div>

      <SectionReveal class="mx-auto max-w-5xl px-5 pb-4 pt-20 text-center lg:px-8">
        <p class="text-xs uppercase tracking-[0.2em] text-kwiin-gold-bright/80">
          {championshipName} &middot; <span data-i18n="about.finland">{championshipLocation}</span> &middot; <span data-i18n="about.awardsDate">13. bis 14. Juni 2026</span>
        </p>
        <h3 class="mx-auto mt-4 max-w-3xl font-display text-3xl text-kwiin-ivory text-balance sm:text-4xl" data-i18n="about.awardsTitle">
          Vier Medaillen für Erfahrung und saubere Technik.
        </h3>
        <p class="mx-auto mt-5 max-w-2xl text-sm leading-relaxed text-kwiin-soft-grey" data-i18n="about.awardsCopy">
          2026 gewann Pratana bei der Nordic Nuad Thai Massage Championship in Finnland vier Medaillen. Darunter waren Gold in Thai Massage und Sportmassage.
        </p>
        <div class="mx-auto mt-10 grid max-w-3xl grid-cols-2 gap-5 sm:grid-cols-4">
          {awards.map((award) => <AwardCard award={award} />)}
        </div>
      </SectionReveal>
    </section>

    {/* ── 6. Unsere Einladung ──────────────────────────────────────── */}
    <section class="relative overflow-hidden py-28">
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(60%_80%_at_50%_100%,rgba(201,163,92,0.1),transparent_65%)]"
        aria-hidden="true"
      >
      </div>
      <SectionReveal class="relative mx-auto max-w-3xl px-5 text-center lg:px-8">
        <p class="kwiin-eyebrow" data-i18n="about.inviteEyebrow">Unsere Einladung</p>
        <h2 class="mt-6 font-display text-4xl leading-tight text-kwiin-ivory text-balance sm:text-5xl">
          <span data-i18n="about.inviteTitle">Gönnen Sie sich echte Ruhe.</span>
        </h2>
        <p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-kwiin-soft-grey" data-i18n="about.inviteCopy">
          Pratana hört zuerst zu und passt jede Behandlung an Ihre Wünsche an. Fragen Sie einfach, wenn Sie unsicher sind, welche Massage zu Ihnen passt.
        </p>
        <div class="mt-10">
          <WhatsAppButton message={WHATSAPP_MESSAGES.studioGeneric} label="Termin via WhatsApp" labelKey="common.whatsappAppointment" messageKey="common.studioWhatsApp" size="lg" />
        </div>
        <OrnamentDivider class="mt-14" />
        <p class="mt-10 font-display text-2xl italic text-kwiin-gold-bright text-balance" data-words data-i18n="about.inviteWelcome">
          Willkommen bei KWIIN. Willkommen bei sich selbst.
        </p>
        <p class="mt-8 font-display text-base italic text-kwiin-soft-grey">“<span data-i18n="common.brandLine">{brandLine}</span>”</p>
        <div class="mt-10 flex justify-center">
          <LocationNote variant="full" />
        </div>
      </SectionReveal>
    </section>
  </PageTransition>
</BaseLayout>
