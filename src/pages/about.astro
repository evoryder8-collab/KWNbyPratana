---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageTransition from "../components/PageTransition.astro";
import SectionReveal from "../components/SectionReveal.astro";
import AwardCard from "../components/AwardCard.astro";
import TestimonialCard from "../components/TestimonialCard.astro";
import LocationNote from "../components/LocationNote.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import {
  awards,
  awardsSectionTitle,
  awardsSectionCopy,
  championshipName,
  championshipLocation,
  championshipDates,
} from "../data/awards";
import { testimonials } from "../data/testimonials";
import { WHATSAPP_MESSAGES } from "../utils/whatsapp";
import { brandLine } from "../data/contact";
import { withBase } from "../utils/base";

const title = "About Pratana Halstrick | Founder of KWIIN";
const description =
  "Meet Pratana Halstrick, founder of KWIIN, born in Bangkok, raised between Germany and Switzerland, and an award-winning Thai massage therapist.";
---

<BaseLayout title={title} description={description}>
  <PageTransition>
    <section class="pt-36 pb-16">
      <div class="mx-auto grid max-w-6xl gap-12 px-5 lg:grid-cols-2 lg:items-center lg:px-8">
        <SectionReveal>
          <p class="text-xs uppercase tracking-[0.2em] text-kwiin-gold-bright/80">
            The Founder of KWIIN
          </p>
          <h1 class="mt-4 font-display text-4xl text-kwiin-ivory sm:text-5xl">Pratana Halstrick</h1>
          <p class="mt-6 text-base leading-relaxed text-kwiin-soft-grey">
            Pratana's path into massage began at home. Born in Bangkok on October 1, 1990 and
            raised between Thailand and Germany, she discovered her gift as a teenager, first
            massaging her mother, then slowly realizing that her hands carried something rare: a
            natural sense for pressure, rhythm, and the body's need to release tension.
          </p>
          <p class="mt-4 text-base leading-relaxed text-kwiin-soft-grey">
            Years later, after building her craft across Germany and Switzerland, Pratana created
            KWIIN, her personal brand built on discipline, tradition, and a refined sense of
            luxury. Today, based in Switzerland, she welcomes clients in Dübendorf and travels to
            them through KWIIN Mobile Spa, bringing championship-level Thai massage to every
            session.
          </p>
          <div class="mt-8">
            <WhatsAppButton message={WHATSAPP_MESSAGES.studioGeneric} label="Book via WhatsApp" />
          </div>
        </SectionReveal>

        <SectionReveal class="kwiin-card flex min-h-[22rem] items-center justify-center rounded-3xl p-8">
          <picture class="flex items-center justify-center">
            <source
              srcset={withBase("/assets/Pratana%20Portrait%20transparent%20optimised.webp")}
              type="image/webp"
            />
            <img
              src={withBase("/assets/pratana-portrait.png")}
              alt="Pratana Halstrick, founder of KWIIN"
              class="max-h-[28rem] w-auto object-contain"
              loading="eager"
            />
          </picture>
        </SectionReveal>
      </div>
    </section>

    <SectionReveal class="mx-auto max-w-5xl px-5 pb-20 text-center lg:px-8">
      <p class="text-xs uppercase tracking-[0.2em] text-kwiin-gold-bright/80">
        {championshipName} &middot; {championshipLocation} &middot; {championshipDates}
      </p>
      <h2 class="mx-auto mt-4 max-w-3xl font-display text-3xl text-kwiin-ivory text-balance sm:text-4xl">
        {awardsSectionTitle}
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-sm leading-relaxed text-kwiin-soft-grey">
        {awardsSectionCopy}
      </p>
      <div class="mx-auto mt-10 grid max-w-3xl grid-cols-2 gap-5 sm:grid-cols-4">
        {awards.map((award) => <AwardCard award={award} />)}
      </div>
    </SectionReveal>

    <section class="mx-auto max-w-7xl px-5 pb-20 lg:px-8">
      <SectionReveal>
        <h2 class="mb-10 text-center font-display text-3xl text-kwiin-ivory sm:text-4xl">
          What Clients Feel
        </h2>
      </SectionReveal>
      <div class="grid gap-6 md:grid-cols-3">
        {testimonials.map((t) => <TestimonialCard testimonial={t} />)}
      </div>
    </section>

    <SectionReveal class="mx-auto max-w-3xl px-5 pb-24 text-center lg:px-8">
      <p class="font-display text-2xl italic text-kwiin-gold-bright text-balance">“{brandLine}”</p>
      <div class="mt-8 flex justify-center">
        <LocationNote variant="full" />
      </div>
    </SectionReveal>
  </PageTransition>
</BaseLayout>
